generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                 @id @default(autoincrement())
  nom                 String
  prenom              String?
  email               String              @unique
  password            String
  role                String              @default("operationnel")
  societe             String
  actif               Boolean             @default(true)
  force_pwd_change    Boolean             @default(false)
  last_login          DateTime?
  created_at          DateTime            @default(now())
  created_by          Int?
  logs                ActivityLog[]
  bons_approuves      BonProvisoir[]      @relation("BonApprover")
  bons_demandes       BonProvisoir[]      @relation("BonDemandeur")
  bons_reel_confirmes BonReel[]           @relation("BonReelConfirme")
  bons_reel_soumis    BonReel[]           @relation("BonReelSoumis")
  ecritures           EcritureComptable[]
  taches              Tache[]
  comments            TacheComment[]
  dossier_files       DossierFile[]
  dossier_comments    DossierComment[]
  notifications       Notification[]
  client_documents    ClientDocument[]    @relation("UserClientDocuments")
  dossiers_created    Dossier[]           @relation("DossierCreator")
}

model Client {
  id                Int              @id @default(autoincrement())
  nom               String
  niu               String?
  rccm              String?
  adresse           String?
  tel               String?
  societe           String
  documents         Document[]
  dossiers          Dossier[]
  representant      String?
  statut_initial    String?          @default("IMPORTATEUR")
  acf               String?
  email             String?
  ref_interne       String?
  client_documents  ClientDocument[] @relation("ClientDocuments")
  representants     Representant[] @relation("ClientRepresentants")
}

model Dossier {
  id              Int            @id @default(autoincrement())
  numero          String         @unique
  client_id       Int
  port            String
  nature          String
  etat            String
  bl              String         @default("")
  contenu         String?
  droits_douane   Float?
  validation      Boolean        @default(false)
  valeur_douane   Float?
  created_at      DateTime       @default(now())
  representant_libre String?
  representant_id   Int?
  representant_obj  Representant? @relation("DossierRepresentant", fields:[representant_id], references:[id])
  pipeline_status String         @default("CREE")
  archived_at     DateTime?
  bons_provisoir  BonProvisoir[]
  bons_reel       BonReel[]
  client          Client         @relation(fields: [client_id], references: [id], onDelete: Cascade)
  taches          Tache[]
  files           DossierFile[]
  comments        DossierComment[]
  created_by      Int?
  creator         User?          @relation("DossierCreator", fields:[created_by], references:[id])
}

model Tache {
  id             Int            @id @default(autoincrement())
  dossier_id     Int
  titre          String
  intervenant_id Int?
  etat           String
  observations   String?
  deadline       DateTime?
  created_at     DateTime       @default(now())
  archive        Boolean        @default(false)
  subtasks       SubTask[]
  dossier        Dossier        @relation(fields: [dossier_id], references: [id], onDelete: Cascade)
  intervenant    User?          @relation(fields: [intervenant_id], references: [id])
  comments       TacheComment[]
}

model TacheComment {
  id           Int      @id @default(autoincrement())
  tache_id     Int
  user_id      Int
  contenu      String
  is_next_step Boolean  @default(false)
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tache        Tache    @relation(fields: [tache_id], references: [id], onDelete: Cascade)
}

model SubTask {
  id         Int      @id @default(autoincrement())
  tache_id   Int
  titre      String
  fait       Boolean  @default(false)
  created_at DateTime @default(now())
  tache      Tache    @relation(fields: [tache_id], references: [id], onDelete: Cascade)
}

model Document {
  id         Int           @id @default(autoincrement())
  type       String
  numero     String        @unique
  client_id  Int
  societe    String
  total_ht   Float
  total_ttc  Float
  etat       String
  created_at DateTime      @default(now())
  client     Client        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  lines      InvoiceLine[]
  payments   Payment[]
}

model InvoiceLine {
  id            Int      @id @default(autoincrement())
  document_id   Int
  description   String
  quantite      Int
  prix_unitaire Float
  taxe_id       String
  total         Float
  document      Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
}

model Stock {
  id            Int     @id @default(autoincrement())
  nom           String
  quantite      Int
  stock_min     Int
  prix_vente    Float
  lieu_stockage String?
}

model Payment {
  id            Int      @id @default(autoincrement())
  document_id   Int
  montant       Float
  moyen         String
  date_paiement DateTime @default(now())
  document      Document @relation(fields: [document_id], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  user_id    Int
  action     String
  entity     String
  entity_id  String?
  meta       String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model CompteComptable {
  id          Int                 @id @default(autoincrement())
  code        String              @unique
  nom         String
  type        String
  sens_normal String
  societe     String
  actif       Boolean             @default(true)
  ecritures   EcritureComptable[]
}

model EcritureComptable {
  id         Int             @id @default(autoincrement())
  journal    String
  date       DateTime        @default(now())
  piece_ref  String
  compte_id  Int
  libelle    String
  debit      Float           @default(0)
  credit     Float           @default(0)
  societe    String
  created_by Int
  locked     Boolean         @default(false)
  user       User            @relation(fields: [created_by], references: [id])
  compte     CompteComptable @relation(fields: [compte_id], references: [id])
}

model PeriodeComptable {
  id      Int     @id @default(autoincrement())
  mois    Int
  annee   Int
  locked  Boolean @default(false)
  societe String

  @@unique([mois, annee, societe])
}

model TauxChange {
  id     Int      @id @default(autoincrement())
  devise String
  taux   Float
  date   DateTime @default(now())
}

model Fournisseur {
  id        Int                  @id @default(autoincrement())
  nom       String
  niu       String?
  rccm      String?
  adresse   String?
  tel       String?
  email     String?
  devise    String               @default("FCFA")
  societe   String
  actif     Boolean              @default(true)
  commandes BonCommande[]
  factures  FactureFournisseur[]
}

model BonCommande {
  id             Int                  @id @default(autoincrement())
  numero         String               @unique
  fournisseur_id Int
  date           DateTime             @default(now())
  date_livraison DateTime?
  etat           String               @default("Brouillon")
  total_ht       Float                @default(0)
  total_ttc      Float                @default(0)
  notes          String?
  societe        String
  created_by     Int
  fournisseur    Fournisseur          @relation(fields: [fournisseur_id], references: [id])
  factures       FactureFournisseur[]
  lignes         LigneBonCommande[]
}

model LigneBonCommande {
  id            Int         @id @default(autoincrement())
  commande_id   Int
  description   String
  quantite      Float
  prix_unitaire Float
  total         Float
  commande      BonCommande @relation(fields: [commande_id], references: [id], onDelete: Cascade)
}

model FactureFournisseur {
  id             Int                   @id @default(autoincrement())
  numero         String
  commande_id    Int?
  fournisseur_id Int
  date           DateTime              @default(now())
  echeance       DateTime?
  montant_ht     Float
  montant_ttc    Float
  etat           String                @default("En attente")
  societe        String
  commande       BonCommande?          @relation(fields: [commande_id], references: [id])
  fournisseur    Fournisseur           @relation(fields: [fournisseur_id], references: [id])
  paiements      PaiementFournisseur[]
}

model PaiementFournisseur {
  id         Int                @id @default(autoincrement())
  facture_id Int
  montant    Float
  moyen      String
  date       DateTime           @default(now())
  facture    FactureFournisseur @relation(fields: [facture_id], references: [id], onDelete: Cascade)
}

model BonProvisoir {
  id              Int       @id @default(autoincrement())
  numero          String    @unique
  dossier_id      Int
  service         String
  demandeur_id    Int
  objet           String
  montant_demande Float
  items_json      String?
  etat            String    @default("EN_ATTENTE")
  tick_pdg        Boolean   @default(false)
  tick_dg         Boolean   @default(false)
  tick_dga        Boolean   @default(false)
  tick_daf        Boolean   @default(false)
  tick_audit      Boolean   @default(false)
  tick_pdg_by     String?
  tick_dg_by      String?
  tick_dga_by     String?
  tick_daf_by     String?
  tick_audit_by   String?
  approved_by_id  Int?
  approved_at     DateTime?
  motif_rejet     String?
  created_at      DateTime  @default(now())
  approver        User?     @relation("BonApprover", fields: [approved_by_id], references: [id])
  demandeur       User      @relation("BonDemandeur", fields: [demandeur_id], references: [id])
  dossier         Dossier   @relation(fields: [dossier_id], references: [id])
  bon_reel        BonReel?
}

model BonReel {
  id                Int          @id @default(autoincrement())
  bon_provisoir_id  Int          @unique
  dossier_id        Int
  montant_provisoir Float
  montant_reel      Float
  ecart             Float
  observations      String?
  items_json        String?
  soumis_par_id     Int
  confirme_par_id   Int?
  confirme_at       DateTime?
  created_at        DateTime     @default(now())
  confirme_par      User?        @relation("BonReelConfirme", fields: [confirme_par_id], references: [id])
  soumis_par        User         @relation("BonReelSoumis", fields: [soumis_par_id], references: [id])
  dossier           Dossier      @relation(fields: [dossier_id], references: [id])
  bon_provisoir     BonProvisoir @relation(fields: [bon_provisoir_id], references: [id])
}

model DossierFile {
  id          Int      @id @default(autoincrement())
  dossier_id  Int
  user_id     Int
  filename    String
  original    String
  stage       String
  category    String
  comment     String?
  path        String
  created_at  DateTime @default(now())
  dossier     Dossier  @relation(fields:[dossier_id], references:[id], onDelete:Cascade)
  user        User     @relation(fields:[user_id], references:[id], onDelete:Cascade)
}

model DossierComment {
  id         Int      @id @default(autoincrement())
  dossier_id Int
  user_id    Int
  contenu    String
  stage      String
  created_at DateTime @default(now())
  dossier    Dossier  @relation(fields:[dossier_id], references:[id], onDelete:Cascade)
  user       User     @relation(fields:[user_id], references:[id], onDelete:Cascade)
}

model Notification {
  id            Int      @id @default(autoincrement())
  user_id       Int
  titre         String
  contenu       String
  lien          String?
  lu            Boolean  @default(false)
  browser_shown Boolean  @default(false)
  created_at    DateTime @default(now())
  user          User     @relation(fields:[user_id], references:[id], onDelete:Cascade)
}

model ClientDocument {
  id              Int           @id @default(autoincrement())
  client_id       Int
  user_id         Int
  filename        String
  original        String
  category        String
  comment         String?
  path            String
  created_at      DateTime      @default(now())
  client          Client        @relation("ClientDocuments", fields:[client_id], references:[id], onDelete:Cascade)
  user            User          @relation("UserClientDocuments", fields:[user_id], references:[id], onDelete:Cascade)
  representant_id Int?
  representant    Representant? @relation("RepresentantDocuments", fields:[representant_id], references:[id])
}

model Representant {
  id          Int       @id @default(autoincrement())
  client_id   Int
  nom         String
  prenom      String?
  tel         String?
  email       String?
  cni_numero  String?
  fonction    String?
  actif       Boolean   @default(true)
  created_at  DateTime  @default(now())
  client      Client    @relation("ClientRepresentants", fields:[client_id], references:[id], onDelete:Cascade)
  dossiers    Dossier[] @relation("DossierRepresentant")
  documents   ClientDocument[] @relation("RepresentantDocuments")
}

