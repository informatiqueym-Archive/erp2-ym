<%- include('../partials/header') %>

<div class="container my-5 py-5 text-center">
  <div class="row justify-content-center">
    <div class="col-md-7">
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="p-5 bg-danger text-white">
          <i class="bi bi-shield-lock-fill display-1"></i>
          <h1 class="mt-4 font-display text-uppercase tracking-wider">Accès Refusé</h1>
          <h4 class="text-white-50">Erreur 403 - Forbidden</h4>
        </div>
        <div class="card-body p-5">
          <p class="lead text-muted">
            <%= typeof message !== 'undefined' ? message : "Vous ne disposez pas des permissions ou habilitations de rôle requises pour consulter cette ressource." %>
          </p>
          <hr class="my-4">
          <p class="text-sm text-secondary">
            Si vous pensez qu'il s'agit d'une erreur d'attribution de vos droits d'accès, veuillez contacter votre Super Administrateur.
          </p>
          <div class="d-flex justify-content-center gap-3 mt-4">
            <a href="/dashboard" class="btn btn-primary btn-lg rounded-pill px-4">
              <i class="bi bi-speedometer2 me-2"></i>Tableau de bord
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
              <i class="bi bi-arrow-left me-2"></i>Retour
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
