<%- include('../partials/header') %>

<div class="container-fluid py-4 font-sans text-start">
  
  <!-- Message notifications at the very top -->
  <% if (typeof success_msg !== 'undefined' && success_msg) { %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 border-start border-4 border-success" role="alert">
      <div class="d-flex align-items-center">
        <i class="bi bi-check-circle-fill me-2 fs-5"></i>
        <div><strong>Succès !</strong> <%= success_msg %></div>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  <% if (typeof error_msg !== 'undefined' && error_msg) { %>
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 border-start border-4 border-danger" role="alert">
      <div class="d-flex align-items-center">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <div><strong>Erreur !</strong> <%= error_msg %></div>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <!-- Dashboard Welcome Title -->
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
      <h1 class="h3 text-slate-800 fw-bold mb-1">
        <i class="bi bi-speedometer2 text-primary me-2"></i>Tableau de bord ERP
      </h1>
      <p class="text-muted mb-0">Espace de pilotage et d'action — Connecté en tant que <strong><%= user ? user.nom : 'Utilisateur' %> <%= user && user.prenom ? user.prenom : '' %></strong> (<span class="badge bg-secondary text-uppercase"><%= role %></span>)</p>
    </div>
    <div class="d-flex gap-2">
      <% if (['super_admin', 'secretariat', 'secretaire'].includes(role)) { %>
        <a href="/dossiers/create" class="btn btn-primary d-inline-flex align-items-center rounded-pill px-3 shadow-sm">
          <i class="bi bi-folder-plus me-2"></i> Nouveau Dossier
        </a>
      <% } %>
      <% if (['super_admin', 'comptable', 'finances', 'facturation'].includes(role)) { %>
        <a href="/facturation" class="btn btn-outline-dark d-inline-flex align-items-center rounded-pill px-3 shadow-sm">
          <i class="bi bi-receipt me-2"></i> Gérer Factures
        </a>
      <% } %>
    </div>
  </div>

  <!-- ==================================================== -->
  <!-- SECTION A : Mon Espace de Travail (Urgent Action Cards) -->
  <!-- ==================================================== -->
  <div class="mb-5">
    <div class="border-bottom pb-2 mb-3">
      <h2 class="h5 fw-bold text-dark mb-1">
         <i class="bi bi-briefcase text-primary me-2"></i>Mon Espace de Travail <small class="text-muted"> (Mes dossiers & actions en cours)</small>
      </h2>
    </div>

    <% 
      let hasActions = false; 
    %>

    <!-- Secretariat actions -->
    <% if ((role === "secretariat" || role === "secretaire") && pendingWork) { %>
      <% if (pendingWork.length > 0) { hasActions = true; %>
        <div class="row g-3">
          <div class="col-12 col-md-4">
            <div class="card bg-info-subtle border-start border-4 border-info shadow-sm py-2 mb-3">
              <div class="card-body">
                <h6 class="text-info-emphasis fw-bold text-uppercase text-xs tracking-wider mb-1">Dossiers créés ce mois</h6>
                <p class="h3 fw-bold text-slate-800 mb-0"><%= extraData.createdThisMonthCount || 0 %></p>
              </div>
            </div>
          </div>
        </div>
        <div class="row g-3">
          <% pendingWork.forEach(d => { %>
            <div class="col-md-6 col-lg-4">
              <div class="card border-0 border-start border-4 border-warning shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="badge bg-warning text-dark text-xs"><%= d.numero %></span>
                      <small class="text-xs text-muted"><%= new Date(d.created_at).toLocaleDateString('fr-FR') %></small>
                    </div>
                    <h6 class="fw-bold text-slate-800 mb-1"><%= d.client ? d.client.nom : 'Client inconnu' %></h6>
                    <p class="text-muted text-xs mb-3">
                      <strong>Port :</strong> <%= d.port %> | <strong>Nature :</strong> <%= d.nature %>
                    </p>
                  </div>
                  <div>
                    <a href="/dossiers/<%= d.id %>" class="btn btn-outline-warning btn-sm w-full fw-semibold rounded-pill">
                      <i class="bi bi-box-arrow-in-right me-1"></i> Soumettre au GUCE
                    </a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <!-- GUCE actions -->
    <% } else if (role === "guce" && pendingWork) { %>
      <% if (pendingWork.length > 0) { hasActions = true; %>
        <div class="row g-3">
          <% pendingWork.forEach(d => { %>
            <div class="col-md-6 col-lg-4">
              <div class="card border-0 border-start border-4 border-primary shadow-sm h-100 animate-pulse">
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="badge bg-primary text-white text-xs"><%= d.numero %></span>
                      <small class="text-xs text-muted"><%= new Date(d.created_at).toLocaleDateString('fr-FR') %></small>
                    </div>
                    <h6 class="fw-bold text-slate-800 mb-1"><%= d.client ? d.client.nom : 'Client inconnu' %></h6>
                    <p class="text-muted text-xs mb-3">
                      <strong>Port :</strong> <%= d.port %> | <strong>Nature :</strong> <%= d.nature %>
                    </p>
                  </div>
                  <div>
                    <a href="/dossiers/<%= d.id %>" class="btn btn-primary btn-sm w-full fw-semibold rounded-pill">
                      <i class="bi bi-shield-check me-1"></i> Traiter ce dossier
                    </a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <!-- Validation actions -->
    <% } else if ((role === "validation" || role === "validation_role") && pendingWork) { %>
      <% if (pendingWork.length > 0) { hasActions = true; %>
        <div class="row g-3">
          <% pendingWork.forEach(d => { %>
            <div class="col-md-6 col-lg-4">
              <div class="card border-0 border-start border-4 border-danger shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="badge bg-danger text-white text-xs"><%= d.numero %></span>
                      <small class="text-xs text-muted"><%= new Date(d.created_at).toLocaleDateString('fr-FR') %></small>
                    </div>
                    <h6 class="fw-bold text-slate-800 mb-1"><%= d.client ? d.client.nom : 'Client inconnu' %></h6>
                    <p class="text-muted text-xs mb-3">
                      <strong>Port :</strong> <%= d.port %> | <strong>Nature :</strong> <%= d.nature %>
                    </p>
                  </div>
                  <div>
                    <a href="/dossiers/<%= d.id %>" class="btn btn-danger btn-sm w-full fw-semibold rounded-pill">
                      <i class="bi bi-check2-all me-1"></i> Valider ce dossier
                    </a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <!-- Acconage / Enlevement actions -->
    <% } else if ((role === "acconage" || role === "enlevement") && pendingWork) { %>
      <% 
        const { dossiersEnTraitement, myPendingBons, dossiersBonReel } = pendingWork;
        if (dossiersEnTraitement.length > 0 || myPendingBons.length > 0 || dossiersBonReel.length > 0) {
          hasActions = true;
      %>
        <!-- Sub-section 1: dossiersEnTraitement -->
        <% if (dossiersEnTraitement.length > 0) { %>
          <div class="mb-4">
            <h6 class="fw-bold text-primary mb-2"><i class="bi bi-truck me-1"></i> Dossiers en cours de livraison / transit (<%= dossiersEnTraitement.length %>)</h6>
            <div class="row g-3">
              <% dossiersEnTraitement.forEach(d => { %>
                <div class="col-md-6 col-lg-4">
                  <div class="card border-0 border-start border-4 border-primary shadow-sm h-100">
                    <div class="card-body d-flex flex-column justify-content-between">
                      <div>
                        <span class="badge bg-primary text-white text-xs mb-2"><%= d.numero %></span>
                        <h6 class="fw-bold text-slate-800 mb-1"><%= d.client ? d.client.nom : '' %></h6>
                        <small class="text-muted d-block mb-3">Nature: <%= d.nature %> | Port: <%= d.port %></small>
                      </div>
                      <a href="/dossiers/<%= d.id %>" class="btn btn-outline-primary btn-sm rounded-pill fw-bold">Faire un bon / Traiter</a>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <!-- Sub-section 2: myPendingBons -->
        <% if (myPendingBons.length > 0) { %>
          <div class="mb-4">
            <h6 class="fw-bold text-warning mb-2"><i class="bi bi-clock-history me-1"></i> Vos Demandes de Bons en signature (<%= myPendingBons.length %>)</h6>
            <div class="row g-3">
              <% myPendingBons.forEach(b => { %>
                <div class="col-md-6 col-lg-4">
                  <div class="card border-0 border-start border-4 border-warning shadow-sm h-100">
                    <div class="card-body">
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-warning text-dark text-xs"><%= b.numero %></span>
                        <small class="text-xs text-muted"><%= b.montant_demande.toLocaleString('fr-Fr') %> FCFA</small>
                      </div>
                      <h6 class="fw-bold text-slate-800 mb-1">Dossier: <%= b.dossier ? b.dossier.numero : 'N/A' %></h6>
                      <p class="text-xs text-muted mb-0">Objet: <%= b.objet %></p>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <!-- Sub-section 3: dossiersBonReel -->
        <% if (dossiersBonReel.length > 0) { %>
          <div class="mb-4">
            <h6 class="fw-bold text-danger mb-2"><i class="bi bi-check-circle me-1"></i> Régularisations Bons Réels en attente (<%= dossiersBonReel.length %>)</h6>
            <div class="row g-3">
              <% dossiersBonReel.forEach(d => { %>
                <div class="col-md-6 col-lg-4">
                  <div class="card border-0 border-start border-4 border-danger shadow-sm h-100">
                    <div class="card-body d-flex flex-column justify-content-between">
                      <div>
                        <span class="badge bg-danger text-white text-xs mb-2"><%= d.numero %></span>
                        <h6 class="fw-bold text-slate-800 mb-1"><%= d.client ? d.client.nom : '' %></h6>
                        <small class="text-xs text-muted d-block mb-3">Pièces jointes requises pour le terrain</small>
                      </div>
                      <a href="/dossiers/<%= d.id %>" class="btn btn-danger btn-sm rounded-pill fw-bold">Saisir le Bon Réel</a>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      <% } %>

    <!-- PDG / DG / DGA / DAF actions -->
    <% } else if (['pdg', 'dg', 'dga', 'daf'].includes(role) && pendingWork) { %>
      <% if (pendingWork.length > 0) { hasActions = true; %>
        <div class="row g-3">
          <% pendingWork.forEach(b => { %>
            <div class="col-md-6 col-lg-4">
              <div class="card border-0 border-start border-4 border-warning shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="badge bg-warning text-dark text-xs"><%= b.numero %></span>
                      <small class="text-xs text-muted"><%= new Date(b.created_at).toLocaleDateString('fr-FR') %></small>
                    </div>
                    <h6 class="fw-bold text-slate-800 mb-1">Dossier : <%= b.dossier ? b.dossier.numero : 'Non spécifié' %></h6>
                    <p class="text-xs text-slate-600 mb-2">Objet : <%= b.objet %></p>
                    <p class="mb-2 text-dark font-monospace small">
                      <strong>Montant :</strong> <span class="fw-bold text-danger"><%= b.montant_demande.toLocaleString('fr-FR') %></span> FCFA
                    </p>
                    <p class="text-xs text-secondary mb-3">Demandeur : <%= b.demandeur ? (b.demandeur.prenom + ' ' + b.demandeur.nom) : 'N/A' %></p>
                  </div>
                  <a href="/bons/provisoir/pending" class="btn btn-warning btn-sm w-full fw-bold rounded-pill">
                    <i class="bi bi-shield-lock-fill me-1"></i> Approuver / Rejeter
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <!-- Caisse / Agent payeur actions -->
    <% } else if (['caisse', 'agent_payeur'].includes(role) && pendingWork) { %>
      <% if (pendingWork.length > 0) { hasActions = true; %>
        <div class="row g-3">
          <% pendingWork.forEach(b => { %>
            <div class="col-md-6 col-lg-4">
              <div class="card border-0 border-start border-4 border-success shadow-sm h-100 animate-pulse">
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="badge bg-success text-white text-xs"><%= b.numero %></span>
                      <small class="text-xs text-success-emphasis fw-bold"><%= b.montant_demande.toLocaleString('fr-FR') %> FCFA</small>
                    </div>
                    <h6 class="fw-semibold text-slate-800 mb-1">Prêt au décaissement</h6>
                    <p class="text-xs text-muted mb-2">Demandeur : <%= b.demandeur ? (b.demandeur.prenom + ' ' + b.demandeur.nom) : 'N/A' %></p>
                    <p class="text-xs text-slate-700 mb-3">Dossier : <%= b.dossier ? b.dossier.numero : 'N/A' %></p>
                  </div>
                  <a href="/bons/provisoir/pending" class="btn btn-success btn-sm w-full fw-bold rounded-pill">
                    <i class="bi bi-cash me-1"></i> Libérer les fonds (Caisse)
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <!-- Finance / Facturation actions -->
    <% } else if (['finances', 'facturation'].includes(role) && pendingWork) { %>
      <% if (pendingWork.length > 0) { hasActions = true; %>
        <div class="row g-3">
          <% pendingWork.forEach(d => { %>
            <div class="col-md-6 col-lg-4">
              <div class="card border-0 border-start border-4 border-primary shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="badge bg-primary text-white text-xs"><%= d.numero %></span>
                      <small class="text-xs text-muted"><%= new Date(d.created_at).toLocaleDateString('fr-FR') %></small>
                    </div>
                    <h6 class="fw-bold text-slate-800 mb-1">Importateur : <%= d.client ? d.client.nom : 'Inconnu' %></h6>
                    <p class="text-xs text-muted mb-3">En attente d'émission de la facture de frais de transit.</p>
                  </div>
                  <a href="/facturation/new?dossier_id=<%= d.id %>" class="btn btn-outline-primary btn-sm w-full fw-bold rounded-pill">
                    <i class="bi bi-file-earmark-plus me-1"></i> Créer la facture
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <!-- Cloture actions -->
    <% } else if (role === "cloture" && pendingWork) { %>
      <% if (pendingWork.length > 0) { hasActions = true; %>
        <div class="row g-3">
          <% pendingWork.forEach(d => { %>
            <div class="col-md-6 col-lg-4">
              <div class="card border-0 border-start border-4 border-dark shadow-sm h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                  <div>
                    <span class="badge bg-dark text-white text-xs mb-2"><%= d.numero %></span>
                    <h6 class="fw-bold text-slate-800 mb-1"><%= d.client ? d.client.nom : 'Client inconnu' %></h6>
                    <p class="text-xs text-muted mb-3">Frais acquittés et livraison bouclée. Prêt pour clôture définitive.</p>
                  </div>
                  <a href="/dossiers/<%= d.id %>" class="btn btn-dark btn-sm w-full fw-bold rounded-pill">
                    <i class="bi bi-archive-fill me-1"></i> Clôturer ce dossier
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <!-- Archiviste actions -->
    <% } else if (role === "archiviste" && pendingWork) { %>
      <% hasActions = true; %>
      <div class="mb-3">
        <div class="card bg-slate-900 text-white p-3 mb-4 rounded border-0">
          <div class="d-flex align-items-center justify-content-between">
            <div>
              <span class="text-slate-400 text-xs text-uppercase fw-bold">Archives de transit</span>
              <h4 class="fw-bold text-white mb-0 mt-1"><%= extraData.archiveCount || 0 %> dossiers archivés au total</h4>
            </div>
            <i class="bi bi-archive-fill text-primary" style="font-size: 2.2rem;"></i>
          </div>
        </div>
        <h6 class="fw-bold mb-2 text-dark"><i class="bi bi-clock-history"></i> Derniers dossiers archivés (Lecture Seule)</h6>
        <div class="table-responsive bg-white rounded shadow-sm border">
          <table class="table align-middle mb-0" style="font-size: 0.85rem;">
            <thead class="table-light">
              <tr>
                <th class="ps-3">Numéro</th>
                <th>Client</th>
                <th>Port</th>
                <th>Nature</th>
                <th class="text-end pe-3">Lier</th>
              </tr>
            </thead>
            <tbody>
              <% pendingWork.forEach(d => { %>
                <tr>
                  <td class="ps-3 fw-bold"><%= d.numero %></td>
                  <td><%= d.client ? d.client.nom : '' %></td>
                  <td><%= d.port %></td>
                  <td><%= d.nature %></td>
                  <td class="text-end pe-3">
                    <a href="/dossiers/<%= d.id %>" class="btn btn-outline-dark btn-xs px-2.5 py-0.5 rounded-pill" style="font-size: 0.72rem;">Consulter</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    <!-- Analyste / Auditeur actions -->
    <% } else if (['analyste', 'auditeur1', 'auditeur2'].includes(role) && pendingWork) { %>
      <% hasActions = true; %>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="card border-0 border-start border-4 border-primary bg-light shadow-sm h-100">
            <div class="card-body">
              <div class="text-xs text-muted text-uppercase font-bold mb-1">Dossiers créés ce mois</div>
              <h3 class="fw-bold text-slate-800 mb-1"><%= pendingWork.dossiersThisMonth %></h3>
              <p class="text-muted text-xs mb-0">Cumul mensuel des importations</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 border-start border-4 border-success bg-light shadow-sm h-100">
            <div class="card-body">
              <div class="text-xs text-muted text-uppercase font-bold mb-1">Facturé ce mois</div>
              <h3 class="fw-bold text-success mb-1"><%= pendingWork.totalInvoicedThisMonth.toLocaleString('fr-FR') %> <small class="fs-6 fw-normal text-muted">FCFA</small></h3>
              <p class="text-muted text-xs mb-0">Total des factures émises TTC</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 border-start border-4 border-warning bg-light shadow-sm h-100">
            <div class="card-body">
              <div class="text-xs text-muted text-uppercase font-bold mb-1">Bons en attente de visa</div>
              <h3 class="fw-bold text-warning-emphasis mb-1"><%= pendingWork.pendingBonsCount %></h3>
              <p class="text-muted text-xs mb-0">En attente de revue par direction</p>
            </div>
          </div>
        </div>
        <div class="col-12 mt-3">
          <a href="/analytics" class="btn btn-outline-primary d-inline-flex align-items-center rounded-pill">
            <i class="bi bi-graph-up-arrow me-2"></i> Consulter l'Analyse complete
          </a>
        </div>
      </div>

    <!-- Comptable actions -->
    <% } else if (['comptable', 'comptable_ops'].includes(role) && pendingWork) { %>
      <% hasActions = true; %>
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <div class="card border-0 border-start border-4 border-danger shadow-sm">
            <div class="card-body">
              <div class="text-xs text-muted text-uppercase font-bold mb-1">Crances Clients en Attente</div>
              <h3 class="fw-bold text-dark mb-1"><%= pendingWork.unpaidCount %> factures</h3>
              <p class="text-xs mb-0 text-muted">Montant restant : <strong class="text-danger"><%= pendingWork.unpaidTotal.toLocaleString('fr-Fr') %> FCFA</strong></p>
            </div>
          </div>
        </div>
        <div class="col-md-6 d-flex align-items-end">
          <a href="/accounting/journal" class="btn btn-primary rounded-pill px-4 me-2">
            <i class="bi bi-journal-text me-1"></i> Ouvrir le Livre Journal
          </a>
          <a href="/facturation" class="btn btn-outline-secondary rounded-pill px-4">
             Enregistrer un versement
          </a>
        </div>
      </div>
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light py-2.5 border-0">
          <span class="fw-bold text-dark small"><i class="bi bi-journal-text me-2"></i> Dernières écritures comptables imputées</span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table align-middle mb-0 text-start" style="font-size: 0.85rem;">
              <thead class="table-light">
                <tr>
                  <th class="ps-3">Date</th>
                  <th>Journal</th>
                  <th>Réf Pièce</th>
                  <th>N° Compte</th>
                  <th>Libellé écriture</th>
                  <th class="text-end">Débit</th>
                  <th class="text-end pe-3">Crédit</th>
                </tr>
              </thead>
              <tbody>
                <% if (pendingWork.recentEntries && pendingWork.recentEntries.length > 0) { %>
                  <% pendingWork.recentEntries.forEach(e => { %>
                    <tr>
                      <td class="ps-3"><%= new Date(e.date).toLocaleDateString('fr-FR') %></td>
                      <td><span class="badge bg-secondary"><%= e.journal %></span></td>
                      <td><strong class="font-monospace"><%= e.piece_ref %></strong></td>
                      <td><%= e.compte ? e.compte.code : '' %></td>
                      <td><%= e.libelle %></td>
                      <td class="text-end font-monospace text-emerald-700"><%= e.debit > 0 ? e.debit.toLocaleString('fr-FR') : '-' %></td>
                      <td class="text-end font-monospace text-rose-700 pe-3"><%= e.credit > 0 ? e.credit.toLocaleString('fr-FR') : '-' %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="7" class="text-center text-muted py-4">Aucune imputation comptable récente.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    <!-- Super Admin general default panel -->
    <% } else if (role === "super_admin") { %>
      <% hasActions = true; %>
      <div class="card bg-slate-900 text-white rounded p-4 mb-3 border-0">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
          <div>
            <h4 class="fw-bold mb-1">Espace Super-Contrôle Admin</h4>
            <p class="text-slate-400 text-sm mb-0">Tous les modules opérationnels et administratifs de l'agence YM-TRANSIT sont sous votre commandement direct.</p>
          </div>
          <div class="d-flex gap-2">
            <a href="/admin/users" class="btn btn-primary rounded-pill"><i class="bi bi-people me-1"></i> Gérer Utilisateurs</a>
            <a href="/dashboard" class="btn btn-outline-light rounded-pill"><i class="bi bi-arrow-repeat me-1"></i> Actualiser</a>
          </div>
        </div>
      </div>
    <% } %>

    <!-- If there is absolutely nothing pending for the user's role -->
    <% if (!hasActions) { %>
      <div class="card border-0 border-start border-4 border-success bg-white shadow-sm rounded-3 p-4 text-center">
        <div class="d-flex align-items-center justify-content-center flex-column gap-2 text-success">
          <i class="bi bi-check-circle-fill" style="font-size: 2.5rem;"></i>
          <h5 class="fw-bold text-success mb-1">✅ Tout est à jour</h5>
          <p class="text-muted mb-0">Aucune action opérationnelle ou validation n'est en attente pour votre rôle actuellement.</p>
        </div>
      </div>
    <% } %>
  </div>

  <!-- ==================================================== -->
  <!-- SECTION B : Vue d'Ensemble de l'Entreprise -->
  <!-- ==================================================== -->
  <div class="mb-4">
    <div class="border-bottom pb-2 mb-4">
      <h2 class="h5 fw-bold text-dark mb-1">
         <i class="bi bi-globe2 text-indigo-700 me-2"></i>Vue d'Ensemble de l'Entreprise
      </h2>
    </div>

    <!-- KPI cards only for administrative roles -->
    <% if (isAdminRole && adminMetrics) { %>
      <div class="row g-3 mb-4">
        <!-- Revenue this month -->
        <div class="col-md-4">
          <div class="card h-100 border-0 border-start border-4 border-success shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-uppercase text-muted fw-bold text-xs">C.A. Facturé (Mois)</span>
                <span class="bg-success-subtle text-success p-1.5 rounded-circle fs-5 d-inline-flex"><i class="bi bi-cash-stack"></i></span>
              </div>
              <h3 class="fw-bold text-dark mb-1">
                <%= adminMetrics.monthlyRevenue.toLocaleString('fr-FR') %> <small class="text-muted fs-6 font-normal">FCFA</small>
              </h3>
              <p class="text-xs text-muted mb-0"><i class="bi bi-calendar-check me-1 text-success"></i> Chiffre d'Affaires Mensuel TTC (Sauf Annulées)</p>
            </div>
          </div>
        </div>

        <!-- Pending bons amount -->
        <div class="col-md-4">
          <div class="card h-100 border-0 border-start border-4 border-warning shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-uppercase text-muted fw-bold text-xs">Encours Bons Provisoires</span>
                <span class="bg-warning-subtle text-warning-emphasis p-1.5 rounded-circle fs-5 d-inline-flex"><i class="bi bi-wallet2"></i></span>
              </div>
              <h3 class="fw-bold text-warning-emphasis mb-1">
                <%= adminMetrics.totalPendingBonsAmount.toLocaleString('fr-FR') %> <small class="text-muted fs-6 font-normal">FCFA</small>
              </h3>
              <p class="text-xs text-muted mb-0"><i class="bi bi-exclamation-circle me-1 text-warning"></i> Bons réclamés en cours d'approbation</p>
            </div>
          </div>
        </div>

        <!-- Overdue invoices count -->
        <div class="col-md-4">
          <div class="card h-100 border-0 border-start border-4 border-danger shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-uppercase text-muted fw-bold text-xs">Factures Clients en Retard</span>
                <span class="bg-danger-subtle text-danger p-1.5 rounded-circle fs-5 d-inline-flex"><i class="bi bi-exclamation-triangle-fill"></i></span>
              </div>
              <h3 class="fw-bold text-danger mb-1"><%= adminMetrics.overdueCount %></h3>
              <p class="text-xs text-muted mb-0"><i class="bi bi-calendar-x me-1 text-danger"></i> Factures non réglées au-delà de 30 jours</p>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Pipeline summary widgets -->
    <div class="card border-0 bg-slate-50 shadow-sm p-4 rounded mb-4">
      <h6 class="fw-bold text-slate-700 mb-3"><i class="bi bi-arrow-repeat me-1 text-primary"></i> Synthèse du Pipeline Opérationnel (Suivi Global)</h6>
      <div class="row g-2">
        <% 
          const stagesDef = [
            { key: "CREE", label: "Créé", colorBg: "bg-secondary" },
            { key: "GUCE", label: "Saisie GUCE", colorBg: "bg-warning text-dark" },
            { key: "VALIDATION", label: "Validation", colorBg: "bg-info text-dark" },
            { key: "EN_TRAITEMENT", label: "Traitement", colorBg: "bg-primary text-white" },
            { key: "BON_PROVISOIR", label: "B. Provisoire", colorBg: "bg-warning-emphasis text-white" },
            { key: "BON_REEL", label: "B. Réel", colorBg: "bg-success text-white" },
            { key: "FACTURATION", label: "Facturation", colorBg: "bg-indigo-700 text-white" },
            { key: "CLOTURE", label: "Clôture", colorBg: "bg-dark text-white" }
          ];
        %>
        <% stagesDef.forEach(st => { %>
          <div class="col-6 col-md-3 col-lg-2">
            <a href="/dossiers?pipeline_status=<%= st.key %>" class="text-decoration-none translate-transform hover:scale-102">
              <div class="card border border-light shadow-sm text-center">
                <div class="card-body py-2.5 px-2">
                  <div class="text-muted fw-bold text-xs"><%= st.label %></div>
                  <div class="d-flex align-items-center justify-content-center gap-2 mt-1">
                    <span class="badge <%= st.colorBg %> rounded-pill text-xs fw-bold px-2.5 py-1">
                      <%= pipelineSummary[st.key] || 0 %>
                    </span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Last 5 dossiers table -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
        <span class="fw-bold text-indigo-950 font-sans"><i class="bi bi-clock-history text-indigo-700 me-2"></i>Derniers Dossiers Enregistrés</span>
        <a href="/dossiers" class="btn btn-sm btn-link text-decoration-none fw-bold text-xs">Accéder au Registre Complet</a>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table align-middle mb-0 text-start" style="font-size: 0.88rem;">
            <thead class="table-light">
              <tr>
                <th class="ps-4">No Dossier</th>
                <th>Client</th>
                <th>Date d'ouverture</th>
                <th>Port de transit</th>
                <th>Marchandise (Nature)</th>
                <th class="text-end pe-4">Étape</th>
              </tr>
            </thead>
            <tbody>
              <% if (last5Dossiers && last5Dossiers.length > 0) { %>
                <% last5Dossiers.forEach(ds => { %>
                  <tr>
                    <td class="ps-4 font-bold">
                      <a href="/dossiers/<%= ds.id %>" class="text-indigo-700 text-decoration-none fw-bold"><%= ds.numero %></a>
                    </td>
                    <td class="fw-semibold text-slate-800"><%= ds.client ? ds.client.nom : 'Inconnu' %></td>
                    <td class="text-muted text-xs"><%= new Date(ds.created_at).toLocaleDateString('fr-FR') %></td>
                    <td><%= ds.port %></td>
                    <td><small class="text-secondary"><%= ds.nature %></small></td>
                    <td class="text-end pe-4">
                      <% if (ds.pipeline_status === "CREE") { %>
                        <span class="badge bg-secondary">Créé</span>
                      <% } else if (ds.pipeline_status === "GUCE") { %>
                        <span class="badge bg-warning text-dark">GUCE</span>
                      <% } else if (ds.pipeline_status === "VALIDATION") { %>
                        <span class="badge bg-info text-dark">Validation</span>
                      <% } else if (ds.pipeline_status === "EN_TRAITEMENT") { %>
                        <span class="badge bg-primary">Traitement</span>
                      <% } else if (ds.pipeline_status === "BON_PROVISOIR") { %>
                        <span class="badge bg-warning text-dark">Bon Provisoire</span>
                      <% } else if (ds.pipeline_status === "BON_REEL") { %>
                        <span class="badge bg-success">Bon Réel</span>
                      <% } else if (ds.pipeline_status === "FACTURATION") { %>
                        <span class="badge bg-purple-700 text-white">Facturation</span>
                      <% } else if (ds.pipeline_status === "CLOTURE") { %>
                        <span class="badge bg-dark">Clôturé</span>
                      <% } else { %>
                        <span class="badge bg-light text-dark"><%= ds.pipeline_status %></span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center text-muted py-4">Aucun dossier enregistré pour le moment.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div>

<%- include('../partials/footer') %>
