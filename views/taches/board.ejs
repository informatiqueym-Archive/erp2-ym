<%- include('../partials/header') %>

<div class="row mb-4">
  <div class="col-12 py-2 text-start">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2" style="font-size: 0.85rem;">
        <li class="breadcrumb-item"><a href="/dashboard">Tableau de bord</a></li>
        <li class="breadcrumb-item active" aria-current="page">Suivi des tâches</li>
      </ol>
    </nav>
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1 class="h3 mb-1 text-slate-800 font-sans fw-bold">
          <i class="bi bi-kanban text-primary me-2"></i>Tableau de Suivi Douanier (Kanban)
        </h1>
        <p class="text-muted mb-0">Drag & drop interactif pour un workflow de dédouanement fluide</p>
      </div>
      <div class="d-flex gap-2">
        <a href="/taches/mine" class="btn btn-outline-primary d-inline-flex align-items-center rounded-pill px-3">
          <i class="bi bi-person-check-fill me-1.5"></i> Mes tâches
        </a>
        <a href="/taches/archives" class="btn btn-outline-secondary d-inline-flex align-items-center rounded-pill px-3">
          <i class="bi bi-archive-fill me-1.5"></i> Archives
        </a>
        <a href="/taches/create" class="btn btn-primary d-inline-flex align-items-center rounded-pill px-3">
          <i class="bi bi-plus-lg me-1.5"></i> Nouvelle Tâche
        </a>
      </div>
    </div>
  </div>
</div>

<%
  const now = new Date();
  const isOverdue = (createdDate, state) => {
    if (!createdDate || state !== 'EN_COURS') return false;
    const diffHours = (now.getTime() - new Date(createdDate).getTime()) / (1000 * 60 * 60);
    return diffHours > 48;
  };

  const enCoursTasks = taches.filter(t => t.etat === 'EN_COURS');
  const attenteTasks = taches.filter(t => t.etat === 'ATTENTE_VALIDATION');
  const faitTasks = taches.filter(t => t.etat === 'FAIT' || t.etat === 'TERMINE');
%>

<!-- Kanban Board Row -->
<div class="row g-3" id="kanban-board">
  
  <!-- Column 1: En cours -->
  <div class="col-lg-4 font-sans">
    <div class="card border-0 bg-light-subtle shadow-sm h-100" style="min-height: 600px; background-color: #f8fafc;">
      <div class="card-header border-0 py-3 d-flex align-items-center justify-content-between text-white" style="background-color: #2563eb; border-radius: 8px 8px 0 0;">
        <div class="d-flex align-items-center">
          <span class="badge bg-white text-primary me-2 rounded-circle font-monospace" id="count-en-cours" style="width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.8rem;"><%= enCoursTasks.length %></span>
          <h6 class="mb-0 fw-bold">En cours</h6>
        </div>
        <i class="bi bi-collection-play-fill"></i>
      </div>
      <div class="card-body p-2  kanban-column" id="EN_COURS" ondragover="allowDrop(event)" ondrop="drop(event)" style="overflow-y: auto;">
        <% if (enCoursTasks.length > 0) { %>
          <% enCoursTasks.forEach(t => { %>
            <div class="card border-0 shadow-sm mb-3 p-3 kanban-card text-start position-relative" 
                 id="task-<%= t.id %>" 
                 draggable="true" 
                 ondragstart="drag(event)"
                 style="cursor: grab; border-left: <%= isOverdue(t.created_at, t.etat) ? '4px solid #ef4444' : '4px solid #2563eb' %> !important; border-radius: 6px;">
              
              <% if (isOverdue(t.created_at, t.etat)) { %>
                <span class="badge bg-danger mb-2 py-1 px-2 d-inline-block" style="font-size: 0.65rem;" title="Créé il y a plus de 48 heures">
                  <i class="bi bi-exclamation-triangle"></i> Retard (+48h)
                </span>
              <% } %>
              
              <div class="text-xs text-uppercase fw-bold text-muted mb-1 d-flex align-items-center justify-content-between">
                <span>Dossier: <strong class="text-secondary"><%= t.dossier.numero %></strong></span>
                <span class="d-flex align-items-center gap-1">
                  <!-- Action Archiver -->
                  <form action="/taches/<%= t.id %>/archive" method="POST" class="d-inline m-0">
                    <button type="submit" class="btn btn-link btn-xs p-0 text-slate-400 hover:text-secondary border-0" title="Envoyer aux archives" onclick="return confirm('Archiver cette tâche ?')">
                      <i class="bi bi-archive-fill" style="font-size: 0.85rem;"></i>
                    </button>
                  </form>
                </span>
              </div>
              <h6 class="fw-bold text-slate-800 mb-2" style="font-size: 0.92rem; line-height: 1.35;">
                <a href="/taches/<%= t.id %>" class="text-slate-800 text-decoration-none hover:text-primary transition-colors d-flex align-items-start justify-content-between" title="Ouvrir la discussion: <%= t.titre %>">
                  <span><%= t.titre %></span>
                  <i class="bi bi-chat-left-text text-slate-400 ms-1 hover:text-primary animate__animated animate__pulse animate__infinite" style="font-size: 0.8rem;"></i>
                </a>
              </h6>
              
              <% if (t.observations) { %>
                <p class="text-muted text-xs mb-2 text-truncate-custom" style="max-height: 48px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;"><%= t.observations %></p>
              <% } %>

              <!-- Section des sous-tâches -->
              <div class="mt-2.5 pt-2.5 border-top">
                <div class="fw-bold text-slate-600 text-xs mb-1">
                  <i class="bi bi-check2-square text-primary me-1"></i>Sous-étapes
                </div>
                <div class="subtasks-container" id="subtasks-container-<%= t.id %>">
                  <% if (t.subtasks && t.subtasks.length > 0) { %>
                    <% t.subtasks.forEach(s => { %>
                      <div class="d-flex align-items-center justify-content-between mb-1 text-xs py-0.5 subtask-item" id="subtask-item-<%= s.id %>">
                        <label class="d-inline-flex align-items-center mb-0 gap-1.5 cursor-pointer text-slate-800" style="word-break: break-all;">
                          <input type="checkbox" class="form-check-input subtask-checkbox" data-id="<%= s.id %>" <%= s.fait ? 'checked' : '' %> style="width: 12px; height: 12px; margin-top: 0;">
                          <span class="subtask-title <%= s.fait ? 'text-decoration-line-through text-muted' : '' %>" style="font-size: 0.78rem;"><%= s.titre %></span>
                        </label>
                        <button type="button" class="btn btn-link btn-xs p-0 text-danger border-0 opacity-75 hover:opacity-100 delete-subtask-btn" data-id="<%= s.id %>" title="Supprimer">
                          <i class="bi bi-x"></i>
                        </button>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
                <!-- Dynamic formulation input -->
                <div class="input-group input-group-sm mt-2 dynamic-subtask-form">
                  <input type="text" class="form-control form-control-sm border-end-0 subtask-input" placeholder="Sous-étape..." data-task-id="<%= t.id %>" style="font-size: 0.72rem; height: 26px;">
                  <button class="btn btn-outline-secondary add-subtask-btn px-2 border-slate-300" type="button" data-task-id="<%= t.id %>" style="height: 26px; display: inline-flex; align-items: center; justify-content: center; background-color: #fff;">
                    <i class="bi bi-plus-lg text-primary" style="font-size: 0.72rem;"></i>
                  </button>
                </div>
              </div>
              
              <div class="d-flex align-items-center justify-content-between border-top pt-2 mt-2.5" style="font-size: 0.75rem;">
                <div class="text-slate-600">
                  <i class="bi bi-person-fill text-muted me-1"></i><%= t.intervenant ? t.intervenant.nom : 'Non assigné' %>
                </div>
                <div class="text-muted text-xs">
                  <i class="bi bi-calendar-event me-1"></i><%= new Date(t.created_at).toLocaleDateString('fr-FR') %>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

