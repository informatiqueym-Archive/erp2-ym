<!-- Drop status notification banner (Fixed bottom notification badge) -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 2000;">
  <div id="toastNotification" class="toast align-items-center text-white bg-dark border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex">
      <div class="toast-body d-flex align-items-center">
        <i class="bi bi-lightning-charge text-warning me-2" id="toastIcon"></i>
        <span id="toastMessage">Modification du statut enregistrée !</span>
      </div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fermer"></button>
    </div>
  </div>
</div>

<script>
  function allowDrop(ev) {
    ev.preventDefault();
  }

  function drag(ev) {
    ev.dataTransfer.setData("text/plain", ev.currentTarget.id);
  }

  function drop(ev) {
    ev.preventDefault();
    const data = ev.dataTransfer.getData("text/plain");
    const card = document.getElementById(data);
    if (!card) return;

    // Déterminer la colonne cible
    let targetColumn = ev.target;
    // Remonter le DOM si on a lâché sur un enfant
    while (targetColumn && !targetColumn.classList.contains("kanban-column")) {
      targetColumn = targetColumn.parentElement;
    }

    if (!targetColumn) return;

    const newStatus = targetColumn.id;
    const taskId = data.replace("task-", "");

    // Déplacer l'élément visuellement
    targetColumn.appendChild(card);

    // Mettre à jour visuellement les bordures et décorations de la carte
    if (newStatus === "EN_COURS") {
      card.style.borderLeft = "4px solid #2563eb";
      card.style.opacity = "1";
      const titleEl = card.querySelector("h6");
      if (titleEl) titleEl.classList.remove("text-decoration-line-through");
    } else if (newStatus === "ATTENTE_VALIDATION") {
      card.style.borderLeft = "4px solid #ea580c";
      card.style.opacity = "1";
      const titleEl = card.querySelector("h6");
      if (titleEl) titleEl.classList.remove("text-decoration-line-through");
    } else if (newStatus === "FAIT") {
      card.style.borderLeft = "4px solid #16a34a";
      card.style.opacity = "0.85";
      const titleEl = card.querySelector("h6");
      if (titleEl) titleEl.classList.add("text-decoration-line-through");
    }

    // Mettre à jour le décompte des colonnes
    updateCountIndicators();

    // Effectuer l'appel PATCH sans rechargement
    fetch(`/taches/${taskId}/status`, {
      method: "PATCH",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ etat: newStatus })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        showActivityToast(`Tâche mise à jour avec succès : "${newStatus === 'FAIT' ? 'Fait' : newStatus === 'ATTENTE_VALIDATION' ? 'Validation' : 'En cours'}"`);
      } else {
        console.error("Erreur retournée par le serveur :", data.message);
        showActivityToast("Erreur lors de l'enregistrement de l'opération.");
      }
    })
    .catch(error => {
      console.error("Erreur de communication :", error);
      showActivityToast("Échec de synchronisation avec le serveur.");
    });
  }

  function updateCountIndicators() {
    document.getElementById("count-en-cours").textContent = document.getElementById("EN_COURS").querySelectorAll(".kanban-card").length;
    document.getElementById("count-attente").textContent = document.getElementById("ATTENTE_VALIDATION").querySelectorAll(".kanban-card").length;
    document.getElementById("count-fait").textContent = document.getElementById("FAIT").querySelectorAll(".kanban-card").length;
  }

  function showActivityToast(message) {
    const toastMessage = document.getElementById("toastMessage");
    const toastEl = document.getElementById("toastNotification");
    toastMessage.textContent = message;
    
    // Bootstrap Toast initialization and show
    const bsToast = new bootstrap.Toast(toastEl, { delay: 3000 });
    bsToast.show();
  }

  // Gestionnaires pour les sous-tâches (Ajout, Toggle, Suppression)
  document.addEventListener("DOMContentLoaded", () => {
    const board = document.getElementById("kanban-board");
    if (board) {
      // 1. Bouton d'ajout de sous-tâche
      board.addEventListener("click", async (e) => {
        const addBtn = e.target.closest(".add-subtask-btn");
        if (addBtn) {
          const taskId = addBtn.getAttribute("data-task-id");
          const container = addBtn.closest(".dynamic-subtask-form");
          const input = container.querySelector(".subtask-input");
          await addSubtaskAction(taskId, input);
        }

        // 2. Bouton de suppression de sous-tâche
        const deleteBtn = e.target.closest(".delete-subtask-btn");
        if (deleteBtn) {
          const subtaskId = deleteBtn.getAttribute("data-id");
          if (confirm("Supprimer cette sous-étape ?")) {
            await deleteSubtaskAction(subtaskId);
          }
        }
      });

      // 3. Touche Entrée sur l'input de sous-tâche
      board.addEventListener("keydown", async (e) => {
        if (e.target.classList.contains("subtask-input") && e.key === "Enter") {
          e.preventDefault();
          const taskId = e.target.getAttribute("data-task-id");
          await addSubtaskAction(taskId, e.target);
        }
      });

      // 4. Case à cocher pour changer l'état
      board.addEventListener("change", async (e) => {
        if (e.target.classList.contains("subtask-checkbox")) {
          const subtaskId = e.target.getAttribute("data-id");
          await toggleSubtaskAction(subtaskId, e.target);
        }
      });
    }
  });

  // Action: Ajouter une sous-tâche
  async function addSubtaskAction(taskId, inputElement) {
    const titre = inputElement.value.trim();
    if (!titre) return;

    try {
      const response = await fetch(`/taches/${taskId}/subtasks`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ titre })
      });
      const data = await response.json();
      if (data.success) {
        const sub = data.subtask;
        const container = document.getElementById(`subtasks-container-${taskId}`);
        
        // Créer l'élément de la sous-tâche
        const item = document.createElement("div");
        item.className = "d-flex align-items-center justify-content-between mb-1 text-xs py-0.5 subtask-item";
        item.id = `subtask-item-${sub.id}`;
        item.innerHTML = `
          <label class="d-inline-flex align-items-center mb-0 gap-1.5 cursor-pointer text-slate-800" style="word-break: break-all;">
            <input type="checkbox" class="form-check-input subtask-checkbox" data-id="${sub.id}" style="width: 12px; height: 12px; margin-top: 0;">
            <span class="subtask-title" style="font-size: 0.78rem;">${escapeHTML(sub.titre)}</span>
          </label>
          <button type="button" class="btn btn-link btn-xs p-0 text-danger border-0 opacity-75 hover:opacity-100 delete-subtask-btn" data-id="${sub.id}" title="Supprimer">
            <i class="bi bi-x"></i>
          </button>
        `;
        
        container.appendChild(item);
        inputElement.value = "";
        showActivityToast("Sous-étape ajoutée !");
      } else {
        showActivityToast("Erreur lors de la création.");
      }
    } catch (e) {
      console.error(e);
      showActivityToast("Échec de communication.");
    }
  }

  // Action: Toggle sous-tâche
  async function toggleSubtaskAction(subtaskId, checkboxElement) {
    try {
      const response = await fetch(`/subtasks/${subtaskId}/toggle`, {
        method: "POST"
      });
      const data = await response.json();
      if (data.success) {
        const labelText = checkboxElement.closest("label").querySelector(".subtask-title");
        if (data.subtask.fait) {
          labelText.classList.add("text-decoration-line-through", "text-muted");
        } else {
          labelText.classList.remove("text-decoration-line-through", "text-muted");
        }
        showActivityToast("Sous-étape mise à jour.");
      } else {
        checkboxElement.checked = !checkboxElement.checked; // revert
        showActivityToast("Erreur de modification.");
      }
    } catch (e) {
      checkboxElement.checked = !checkboxElement.checked; // revert
      console.error(e);
    }
  }

  // Action: Supprimer sous-tâche
  async function deleteSubtaskAction(subtaskId) {
    try {
      const response = await fetch(`/subtasks/${subtaskId}/delete`, {
        method: "POST"
      });
      const data = await response.json();
      if (data.success) {
        document.getElementById(`subtask-item-${subtaskId}`).remove();
        showActivityToast("Sous-étape supprimée.");
      } else {
        showActivityToast("Erreur lors de la suppression.");
      }
    } catch (e) {
      console.error(e);
    }
  }

  function escapeHTML(str) {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }
</script>

