<%- include('../partials/header') %>

<div class="row mb-4">
  <div class="col-12 py-2 text-start">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2" style="font-size: 0.85rem;">
        <li class="breadcrumb-item"><a href="/dashboard">Tableau de bord</a></li>
        <li class="breadcrumb-item"><a href="/taches">Suivi des tâches</a></li>
        <li class="breadcrumb-item active" aria-current="page">Mes tâches assignées</li>
      </ol>
    </nav>
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1 class="h3 mb-1 text-slate-800 font-sans fw-bold">
          <i class="bi bi-person-workspace text-primary me-2"></i>Mon Bureau - Opérations Logistiques
        </h1>
        <p class="text-muted mb-0">Liste complète de vos actions de transit en cours d'exécution</p>
      </div>
      <div>
        <a href="/taches" class="btn btn-primary d-inline-flex align-items-center rounded-pill px-3">
          <i class="bi bi-kanban me-1.5"></i> Voir le Tableau Kanban
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Simple elegant list card table -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
    <h5 class="mb-0 fw-bold font-sans text-dark" style="font-size: 1rem;">
      <i class="bi bi-list-task text-primary me-2"></i>Vos Tâches en Charge (<%= taches ? taches.length : 0 %>)
    </h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 text-start" style="font-size: 0.9rem;">
        <thead class="table-light">
          <tr>
            <th class="ps-4" style="width: 15%;">N° Dossier</th>
            <th style="width: 40%;">Opération / Démarche de Transit</th>
            <th style="width: 15%;">État Actuel</th>
            <th style="width: 15%;">Date d'attribution</th>
            <th style="width: 15%;">Observations</th>
          </tr>
        </thead>
        <tbody>
          <% if (taches && taches.length > 0) { %>
            <% taches.forEach(t => { %>
              <tr>
                <td class="ps-4">
                  <span class="badge bg-light text-dark border font-monospace py-1 px-2"><%= t.dossier.numero %></span>
                </td>
                <td>
                  <div class="fw-bold text-slate-800" style="font-size: 0.95rem;"><%= t.titre %></div>
                  <% if (t.subtasks && t.subtasks.length > 0) { %>
                    <div class="mt-1.5 d-flex flex-wrap gap-1.5">
                      <% t.subtasks.forEach(sub => { %>
                        <span class="badge rounded-pill <%= sub.fait ? 'bg-success-subtle text-success border border-success-subtle' : 'bg-light text-muted border border-light-subtle' %>" style="font-size: 0.72rem; font-weight: normal; padding: 3px 8px;">
                          <i class="bi <%= sub.fait ? 'bi-check-circle-fill' : 'bi-circle' %> me-1"></i>
                          <%= sub.titre %>
                        </span>
                      <% }) %>
                    </div>
                  <% } %>
                </td>
                <td>
                  <% if (t.etat === 'EN_COURS') { %>
                    <span class="badge bg-primary-subtle text-primary border py-1.5 px-2.5" style="font-size: 0.75rem;"><i class="bi bi-collection-play-fill"></i> EN COURS</span>
                  <% } else if (t.etat === 'ATTENTE_VALIDATION') { %>
                    <span class="badge bg-warning-subtle text-warning border py-1.5 px-2.5" style="font-size: 0.75rem;"><i class="bi bi-hourglass-split"></i> VALIDATION</span>
                  <% } else if (t.etat === 'FAIT' || t.etat === 'TERMINE') { %>
                    <span class="badge bg-success-subtle text-success border py-1.5 px-2.5" style="font-size: 0.75rem;"><i class="bi bi-check-circle-fill"></i> TERMINE</span>
                  <% } else { %>
                    <span class="badge bg-secondary-subtle text-secondary border py-1.5 px-2.5" style="font-size: 0.75rem;"><%= t.etat %></span>
                  <% } %>
                </td>
                <td class="text-muted small">
                  <%= new Date(t.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                </td>
                <td>
                  <% if (t.observations) { %>
                    <span class="text-muted d-inline-block text-truncate" style="max-width: 200px;" title="<%= t.observations %>">
                      <%= t.observations %>
                    </span>
                  <% } else { %>
                    <span class="text-xs text-muted font-sans font-normal italic">Aucune consigne</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-5">
                <i class="bi bi-postcard-heart display-4 text-slate-300 d-block mb-3"></i>
                Félicitations ! Vous n'avez aucune tâche assignée en cours de traitement.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
