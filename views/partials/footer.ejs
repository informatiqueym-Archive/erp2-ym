    </main>

    <!-- Footer bar -->
    <footer class="bg-white border-top py-3 px-4 text-center mt-auto">
      <p class="text-muted mb-0" style="font-size: 0.85rem;">
        &copy; 2026 YM-TRANSIT ERP. Tous droits réservés. Conçu pour le Transit Douanier & Logistique Multimodale au Cameroun.
      </p>
    </footer>
