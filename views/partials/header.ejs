<!DOCTYPE html>
<html lang="fr" class="h-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | YM-TRANSIT ERP' : 'YM-TRANSIT ERP - Transit & Logistique' %></title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet">
  
  <style>
    :root {
      --bana-primary: #1e3a8a; /* Deep blue corporate */
      --bana-secondary: #0f172a; /* Slate dark */
      --bana-accent: #2563eb; /* Active highlight */
      --bana-light: #f8fafc;
      --bana-success: #10b981;
      --bana-warning: #f59e0b;
      --bana-danger: #ef4444;
      --font-display: 'Space Grotesk', sans-serif;
      --font-sans: 'Inter', sans-serif;
    }

    body {
      font-family: var(--font-sans);
      background-color: #f1f5f9;
      color: #334155;
    }

    h1, h2, h3, h4, h5, .display-logo {
      font-family: var(--font-display);
      font-weight: 600;
    }

    .wrapper {
      display: flex;
      width: 100%;
      align-items: stretch;
      min-height: 100vh;
    }

    /* Sidebar styling */
    #sidebar {
      min-width: 260px;
      max-width: 260px;
      background: var(--bana-secondary);
      color: #94a3b8;
      transition: all 0.3s;
      display: flex;
      flex-direction: column;
    }

    #sidebar .sidebar-header {
      padding: 1.5rem;
      background: #020617;
      border-bottom: 1px solid #1e293b;
    }

    #sidebar .sidebar-header h3 {
      color: #f8fafc;
      margin-bottom: 0;
      font-size: 1.4rem;
      letter-spacing: 0.5px;
    }

    #sidebar ul.components {
      padding: 1.5rem 0;
      flex-grow: 1;
    }

    #sidebar ul li {
      padding: 0 1rem;
      margin-behavior: smooth;
    }

    #sidebar ul li a {
      padding: 0.75rem 1rem;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      color: #94a3b8;
      border-radius: 0.375rem;
      text-decoration: none;
      transition: all 0.2s ease-in-out;
      margin-bottom: 0.25rem;
    }

    #sidebar ul li a i {
      font-size: 1.1rem;
      margin-right: 0.85rem;
    }

    #sidebar ul li a:hover {
      color: #f1f5f9;
      background: #1e293b;
    }

    #sidebar ul li.active a {
      color: #ffffff;
      background: var(--bana-accent);
    }

    .sidebar-footer {
      padding: 1rem;
      background: #020617;
      border-top: 1px solid #1e293b;
      font-size: 0.8rem;
    }

    /* Page Content */
    #content {
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Top navbar */
    .top-navbar {
      background-color: #ffffff;
      border-bottom: 1px solid #e2e8f0;
      padding: 0.75rem 2rem;
    }

    .card {
      border: none;
      border-radius: 0.5rem;
      box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
    }

    .card-header {
      background-color: transparent;
      border-bottom: 1px solid #f1f5f9;
      font-weight: 600;
    }

    .btn-primary {
      background-color: var(--bana-accent);
      border-color: var(--bana-accent);
    }

    .btn-primary:hover {
      background-color: #1d4ed8;
      border-color: #1d4ed8;
    }

    .bg-primary-subtle {
      background-color: #eff6ff !important;
      color: var(--bana-accent) !important;
    }

    /* Badge specific statuses in Douala / Kribi contexts */
    .badge-import {
      background-color: #ede9fe;
      color: #6d28d9;
    }
    .badge-export {
      background-color: #ecfdf5;
      color: #047857;
    }
    .badge-transit {
      background-color: #fff7ed;
      color: #c2410c;
    }
  </style>
</head>
<body class="h-100">

<div class="wrapper">
  <!-- Sidebar -->
  <nav id="sidebar">
    <div class="sidebar-header d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center">
        <div class="bg-primary text-white rounded p-2 me-2 d-flex align-items-center justify-content-center" style="width: 44px; height: 40px;">
          <span class="fw-bold fs-6 display-logo text-white">YM</span>
        </div>
        <div>
          <h3 class="display-logo text-light" style="font-size: 1.25rem;">YM-TRANSIT</h3>
          <small class="text-xs text-muted" style="font-size: 0.7rem;">Cameroun Transit</small>
        </div>
      </div>
    </div>

    <% const currentPath = typeof path !== 'undefined' ? path : ''; %>
    
    <%
      const menuItems = [
        { 
          label: "Tableau de bord", 
          icon: "bi-grid", 
          href: "/dashboard", 
          roles: ["*"]  // everyone
        },
        { 
          label: "Dossiers de Transit", 
          icon: "bi-folder2-open", 
          href: "/dossiers", 
          roles: ["*"]  // everyone can VIEW
        },
        { 
          label: "Tiers / Clients", 
          icon: "bi-people", 
          href: "/clients", 
          roles: ["*"]  // everyone can VIEW
        },
        { 
          label: "Archives", 
          icon: "bi-archive", 
          href: "/dossiers/archives", 
          roles: ["*"]  // everyone
        },
        { 
          label: "Bons de Débours", 
          icon: "bi-cash-stack", 
          href: "/bons/provisoir/pending", 
          roles: ["acconage", "enlevement", "pdg", "dg", "dga", "daf", "auditeur1", "auditeur2", "caisse", "agent_payeur", "super_admin"],
          lockedLabel: "Réservé au service Acconage, Enlèvement et Livraison et Direction"
        },
        { 
          label: "Factures & Devis", 
          icon: "bi-receipt", 
          href: "/facturation", 
          roles: ["finances", "facturation", "comptable", "comptable_ops", "pdg", "dg", "dga", "daf", "auditeur1", "caisse", "super_admin"],
          lockedLabel: "Réservé au service Facturation et Comptabilité"
        },
        { 
          label: "Suivi des Tâches", 
          icon: "bi-check2-square", 
          href: "/taches", 
          roles: ["*"]
        },
        { 
          label: "Analyses & Rapports", 
          icon: "bi-graph-up-arrow", 
          href: "/analytics", 
          roles: ["analyste", "auditeur1", "auditeur2", "pdg", "dg", "dga", "daf", "comptable", "comptable_ops", "super_admin", "fiscalite"],
          lockedLabel: "Réservé aux Analystes, Auditeurs et Direction"
        },
        { 
          label: "Livre Journal", 
          icon: "bi-journal-text", 
          href: "/accounting/journal", 
          roles: ["comptable", "comptable_ops", "daf", "auditeur1", "super_admin", "caisse"],
          lockedLabel: "Réservé à la Comptabilité et au DAF"
        },
        { 
          label: "Stock", 
          icon: "bi-boxes", 
          href: "/stock", 
          roles: ["magasinier", "comptable", "super_admin", "daf"],
          lockedLabel: "Réservé au Magasinier et à la Comptabilité"
        },
        { 
          label: "Fournisseurs", 
          icon: "bi-building-add", 
          href: "/fournisseurs", 
          roles: ["comptable", "comptable_ops", "daf", "super_admin"],
          lockedLabel: "Réservé à la Comptabilité et au DAF"
        },
        { 
          label: "Administration", 
          icon: "bi-shield-lock", 
          href: "/admin/users", 
          roles: ["super_admin", "pdg", "dg"],
          lockedLabel: "Réservé aux Super Administrateurs et à la Direction"
        }
      ];
    %>

    <ul class="list-unstyled components text-start">
      <% if (typeof user !== "undefined") { %>
        <% menuItems.forEach(item => { %>
          <% 
            const hasAccess = item.roles.includes("*") || item.roles.includes(user.role);
            let isActive = false;
            if (item.href === "/dashboard") {
              isActive = (currentPath === "/dashboard");
            } else {
              isActive = currentPath.startsWith(item.href) || (item.href === "/dossiers/archives" && currentPath === "/archives");
            }
          %>
          <li class="<%= isActive ? 'active' : '' %>" style="list-style-type: none;">
            <% if (hasAccess) { %>
              <a href="<%= item.href %>">
                <i class="bi <%= item.icon %>"></i>
                <span class="ms-1"><%= item.label %></span>
              </a>
            <% } else { %>
              <a href="#" 
                 class="opacity-50 text-muted" 
                 style="cursor: not-allowed;"
                 data-bs-toggle="tooltip" 
                 data-bs-placement="right" 
                 title="<%= item.lockedLabel || 'Accès restreint pour votre rôle' %>"
                 onclick="showLockedMessage('<%= item.label %>', '<%= item.lockedLabel %>'); return false;">
                <i class="bi <%= item.icon %>"></i>
                <span class="ms-1 text-muted"><%= item.label %></span>
                <i class="bi bi-lock-fill ms-auto small text-warning" style="font-size: 0.75rem;"></i>
              </a>
            <% } %>
          </li>
        <% }) %>
      <% } %>
    </ul>

    <div class="sidebar-footer">
      <div class="text-muted text-center">YM-TRANSIT ERP v1.1.0</div>
    </div>
  </nav>

  <!-- Page Content -->
  <div id="content">
    <!-- Top Navbar -->
    <header class="top-navbar d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center">
        <span class="text-muted me-3">
          <i class="bi bi-building"></i> <strong><%= typeof user !== 'undefined' ? user.societe : 'YM-TRANSIT Logistics' %></strong>
        </span>
        <span class="badge bg-secondary-subtle text-secondary py-1.5 px-3 rounded-pill">
          <i class="bi bi-clock"></i> <%= new Date().toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
        </span>
      </div>
      
      <div class="d-flex align-items-center font-sans">
        <% if (typeof user !== 'undefined') { %>
          
          <!-- Notification Bell Dropdown -->
          <div class="dropdown me-3">
            <button class="btn btn-link link-secondary position-relative p-1 text-decoration-none border-0" type="button" id="notifDropdownBtn" data-bs-toggle="dropdown" aria-expanded="false" onclick="loadNotificationsList()">
              <i class="bi bi-bell-fill fs-5 text-dark"></i>
              <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none; font-size: 0.65rem; padding: 0.25em 0.5em;">0</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-0" aria-labelledby="notifDropdownBtn" style="width: 320px; max-height: 400px; overflow-y: auto; z-index: 1050;">
              <li class="p-2 border-bottom d-flex align-items-center justify-content-between bg-light">
                <span class="fw-bold small text-dark">Notifications récentes</span>
                <button onclick="markAllNotificationsAsRead(event)" class="btn btn-xs btn-link text-decoration-none p-0 fw-bold text-xs" style="font-size: 0.75rem;">Tout marquer lu</button>
              </li>
              <div id="notif-list-container" class="overflow-auto" style="max-height: 320px;">
                <div class="text-center py-3 text-muted"><em>Chargement...</em></div>
              </div>
            </ul>
          </div>

          <div class="dropdown">
            <button class="btn btn-link text-decoration-none text-dark dropdown-toggle d-flex align-items-center" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
              <div class="bg-dark text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                <i class="bi bi-person"></i>
              </div>
              <div class="text-start me-1">
                <div class="fw-bold" style="font-size: 0.85rem;"><%= user.nom %></div>
                <div class="text-muted" style="font-size: 0.75rem;"><%= user.role %></div>
              </div>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="profileDropdown">
              <li><div class="dropdown-header text-muted border-bottom mb-1 font-sans">Compte YM-TRANSIT ERP</div></li>
              <li><a class="dropdown-item py-2" href="/profile"><i class="bi bi-gear me-2"></i>Mon Profil</a></li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item py-2 text-danger" href="/logout">
                  <i class="bi bi-box-arrow-right me-2"></i>Se déconnecter
                </a>
              </li>
            </ul>
          </div>
        <% } else { %>
          <a href="/login" class="btn btn-outline-primary btn-sm rounded-pill px-3">Connexion</a>
        <% } %>
      </div>
    </header>

    <!-- Modal for locked section details (Always present in DOM if header is included) -->
    <div class="modal fade animate-scale-in" id="accessDeniedModal" tabindex="-1" aria-labelledby="accessDeniedModalLabel" aria-hidden="true" style="z-index: 2000;">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
          <div class="modal-header bg-danger text-white border-0">
            <h5 class="modal-title font-display" id="accessDeniedModalLabel">
              <i class="bi bi-shield-lock me-2"></i>Accès Verrouillé
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4 text-center">
            <div class="d-inline-flex bg-danger-subtle p-3 rounded-circle text-danger mb-3">
              <i class="bi bi-lock-fill" style="font-size: 2.5rem;"></i>
            </div>
            <h5 class="fw-bold mt-2 mb-2" id="lockedSectionName">Section</h5>
            <p class="text-muted text-sm mb-0" id="lockedSectionReason">Cette section est réservée.</p>
          </div>
          <div class="modal-footer border-0 bg-light">
            <button type="button" class="btn btn-secondary rounded-pill w-100 fw-bold" data-bs-dismiss="modal">Compris</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Frontend notifications and tooltip hooks scripts -->
    <script>
      // Global functions for lock notification
      function showLockedMessage(label, reason) {
        document.getElementById('lockedSectionName').innerText = label;
        document.getElementById('lockedSectionReason').innerText = reason || 'Accès non autorisé pour votre rôle.';
        
        try {
          const modalEl = document.getElementById('accessDeniedModal');
          if (window.bootstrap && modalEl) {
            const myModal = new bootstrap.Modal(modalEl);
            myModal.show();
          } else {
            alert(`Section Verrouillée : ${label}\n${reason}`);
          }
        } catch (e) {
          alert(`Section Verrouillée : ${label}\n${reason}`);
        }
      }

      // Bell badge count updater
      async function pollNotifications() {
        try {
          const res = await fetch("/api/notifications/poll");
          const data = await res.json();
          if (!data.ok) return;

          const badge = document.getElementById("notif-badge");
          if (badge) {
            badge.textContent = data.unreadCount > 9 ? "9+" : data.unreadCount;
            badge.style.display = data.unreadCount > 0 ? "inline-flex" : "none";
          }

          if (data.notifications && data.notifications.length > 0) {
            for (const notif of data.notifications) {
              if ("Notification" in window && Notification.permission === "granted") {
                const n = new Notification("YM-TRANSIT ERP", {
                  body: notif.titre + "\n" + notif.contenu,
                  icon: "/favicon.ico",
                  tag: "notif-" + notif.id
                });
                n.onclick = () => {
                  window.focus();
                  if (notif.lien) window.location.href = notif.lien;
                  n.close();
                };
                setTimeout(() => n.close(), 8000);
              }
              showToast(notif.titre, notif.contenu);
            }
          }
        } catch (e) {
          console.warn("Poll notifications failure:", e);
        }
      }

      function showToast(titre, contenu) {
        const toast = document.createElement("div");
        toast.style.cssText = `
          position: fixed; bottom: 20px; right: 20px; z-index: 9999;
          background: #1e293b; color: white; border-left: 4px solid #2563eb;
          padding: 12px 16px; border-radius: 8px; max-width: 320px;
          box-shadow: 0 4px 20px rgba(0,0,0,0.3); font-size: 0.85rem;
          transition: all 0.5s ease;
        `;
        toast.innerHTML = `
          <div style="font-weight:600;margin-bottom:4px">🔔 ${titre}</div>
          <div style="opacity:0.85">${contenu}</div>
        `;
        document.body.appendChild(toast);
        setTimeout(() => {
          toast.style.opacity = "0";
          toast.style.transform = "translateY(20px)";
          setTimeout(() => toast.remove(), 500);
        }, 5500);
      }

      // Soft load of populating notifications drop menu
      async function loadNotificationsList() {
        const container = document.getElementById("notif-list-container");
        if (!container) return;
        try {
          const data = await fetch("/api/notifications/list").then(r => r.json());
          if (!data.ok || !data.notifications || data.notifications.length === 0) {
            container.innerHTML = `<div class="text-center py-4 text-muted small"><i class="bi bi-bell-slash d-block fs-4 mb-1 text-secondary"></i>Aucune notification.</div>`;
            return;
          }
          
          container.innerHTML = "";
          data.notifications.forEach(notif => {
            const item = document.createElement("li");
            item.style.cssText = `cursor: pointer; transition: all 0.2s; border-bottom: 1px solid #f1f5f9; list-style-type: none;`;
            item.className = `p-3 notif-item ${notif.lu ? 'bg-white opacity-75' : 'bg-info-subtle'}`;
            
            const timeStr = new Date(notif.created_at).toLocaleString('fr-FR', { hour: '2-digit', minute: '2-digit' });
            item.innerHTML = `
              <div class="d-flex justify-content-between align-items-start mb-1">
                <strong class="text-dark small" style="font-size:0.83rem">${notif.titre}</strong>
                <small class="text-muted font-monospace" style="font-size:0.75rem">${timeStr}</small>
              </div>
              <div class="text-secondary text-xs mb-2" style="font-size:0.8rem; line-height: 1.3;">${notif.contenu}</div>
              ${!notif.lu ? `<button class="btn btn-xs btn-outline-primary py-0 px-2 text-xs rounded-pill" onclick="markAsRead(event, ${notif.id}${notif.lien ? `, '${notif.lien}'` : ''})" style="font-size: 0.72rem;">Marquer lu</button>` : ''}
            `;
            
            item.onclick = (e) => {
              if (e.target.tagName !== "BUTTON") {
                markAsRead(e, notif.id, notif.lien);
              }
            };
            container.appendChild(item);
          });
        } catch (e) {
          container.innerHTML = `<div class="text-center py-3 text-danger"><small>Erreur de récuperation</small></div>`;
        }
      }

      async function markAsRead(event, id, lien) {
        if (event) event.stopPropagation();
        try {
          await fetch(`/api/notifications/${id}/read`, { method: "PATCH" });
          pollNotifications();
          loadNotificationsList();
          if (lien) {
            window.location.href = lien;
          }
        } catch (e) {
          console.error("Error marking read:", e);
        }
      }

      async function markAllNotificationsAsRead(event) {
        if (event) event.stopPropagation();
        try {
          await fetch("/api/notifications/read-all", { method: "PATCH" });
          pollNotifications();
          loadNotificationsList();
        } catch (e) {
          console.error("Error marking all read:", e);
        }
      }

      // Initialize tooltips and fast-poll
      document.addEventListener("DOMContentLoaded", () => {
        // Initialize Bootstrap custom tooltips passive
        if (window.bootstrap) {
          const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
          tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
          });
        }
        
        // Request HTML5 notification permission
        if ("Notification" in window && Notification.permission === "default") {
          Notification.requestPermission();
        }

        // Count fetch on startup
        pollNotifications();
        // Hook poll checking within our local scope to refresh bell badge
        setInterval(pollNotifications, 15000);
      });
    </script>

    <!-- App Messages (flash messages style) -->
    <main class="container-fluid py-4 flex-grow-1">
      <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert" id="glbErrAlert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error_msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>
      <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert" id="glbSucAlert">
          <i class="bi bi-check-circle-fill me-2"></i><%= success_msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>
