<%- include('../partials/header') %>

<% if (dossier.pipeline_status === "ARCHIVE" || dossier.etat === "CLOTURE") { %>
  <div class="alert alert-success border-0 shadow-sm d-flex align-items-center gap-3 p-4 mb-4 rounded-3 text-start bg-success-subtle text-success-emphasis border-start border-success border-4" id="dossier-archive-banner">
    <i class="bi bi-archive-fill fs-3 text-success"></i>
    <div class="flex-grow-1">
      <h6 class="fw-bold mb-1">Dossier de Transit ARCHIVÉ</h6>
      <span class="text-xs">Ce dossier de transit est entièrement <strong>ARCHIVÉ</strong>. Toutes les opérations logistiques, financières, et tous les contrôles d'étape sont verrouillés pour l'historique permanent. Toutes les sections sont accessibles en lecture seule.</span>
    </div>
  </div>
<% } %>

<div class="row mb-4">
  <div class="col-12 py-2 text-start">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2" style="font-size: 0.85rem;">
        <li class="breadcrumb-item"><a href="/dashboard">Tableau de bord</a></li>
        <li class="breadcrumb-item"><a href="/dossiers">Dossiers de Transit</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= dossier.numero %></li>
      </ol>
    </nav>
    
    <!-- 1. HEADER section -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 border-bottom pb-3">
      <div>
        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
          <h1 class="h3 mb-0 text-slate-800 font-sans fw-bold">
            <i class="bi bi-folder2-open text-primary me-2"></i>Dossier <%= dossier.numero %>
          </h1>
          <span class="badge rounded-pill bg-slate-100 text-slate-800 border px-3 py-1 text-xs fw-semibold">
            <i class="bi bi-anchor me-1"></i> <%= dossier.port %>
          </span>
          <span class="badge rounded-pill bg-primary-subtle text-primary border border-primary-subtle px-3 py-1 text-xs fw-bold">
            <i class="bi bi-truck me-1"></i> <%= dossier.nature %>
          </span>
          <% if (dossier.etat === 'CLOTURE') { %>
            <span class="badge rounded-pill bg-success text-white px-3 py-1 text-xs fw-bold" id="dossier-state-badge">
              <i class="bi bi-lock-fill me-1"></i> CLÔTURÉ
            </span>
          <% } else if (dossier.etat === 'FIN DE TRANSIT') { %>
            <span class="badge rounded-pill bg-info text-dark px-3 py-1 text-xs fw-bold" id="dossier-state-badge">
              <i class="bi bi-check-circle-fill me-1"></i> FIN DE TRANSIT
            </span>
          <% } else if (dossier.etat === 'EN_COURS') { %>
            <span class="badge rounded-pill bg-warning text-dark px-3 py-1 text-xs fw-bold" id="dossier-state-badge">
              <i class="bi bi-arrow-repeat me-1 animate-spin"></i> EN COURS
            </span>
          <% } else { %>
            <span class="badge rounded-pill bg-secondary text-white px-3 py-1 text-xs fw-bold" id="dossier-state-badge">
              <i class="bi bi-folder-fill me-1"></i> OUVERT
            </span>
          <% } %>
        </div>
        <p class="text-muted mb-0">
          Client donneur d'ordre : <strong class="text-dark"><%= dossier.client.nom %></strong> 
          • Date de création : <span class="font-monospace text-xs"><%= new Date(dossier.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
        </p>
      </div>
      <div class="d-flex align-items-center gap-2">
        <!-- Change State form -->
        <form action="/dossiers/update-status/<%= dossier.id %>" method="POST" class="d-inline-flex gap-1 align-items-center">
          <select name="etat" class="form-select form-select-sm" style="width: 170px;" onchange="this.form.submit()">
            <option value="OUVERT" <%= dossier.etat === 'OUVERT' ? 'selected' : '' %>>OUVERT / ATTENTE</option>
            <option value="EN_COURS" <%= dossier.etat === 'EN_COURS' ? 'selected' : '' %>>EN COURS</option>
            <option value="FIN DE TRANSIT" <%= dossier.etat === 'FIN DE TRANSIT' ? 'selected' : '' %>>FIN DE TRANSIT</option>
            <option value="CLOTURE" <%= dossier.etat === 'CLOTURE' ? 'selected' : '' %>>CLÔTURÉ & ARCHIVÉ</option>
          </select>
        </form>
        <a href="/dossiers" class="btn btn-outline-secondary d-inline-flex align-items-center rounded-pill px-3 btn-sm">
          <i class="bi bi-chevron-left me-1"></i> Retour
        </a>
      </div>
    </div>
  </div>
</div>

<%
  const pipelineSteps = [
    { key: "CREE", label: "Créé" },
    { key: "GUCE", label: "GUCE" },
    { key: "VALIDATION", label: "Validation" },
    { key: "EN_TRAITEMENT", label: "En traitement" },
    { key: "BON_PROVISOIR", label: "Bon Provisoir" },
    { key: "BON_REEL", label: "Bon Réel" },
    { key: "FACTURATION", label: "Facturation" },
    { key: "CLOTURE", label: "Clôturé" },
    { key: "ARCHIVE", label: "Archivé" }
  ];

  const currentStatus = dossier.pipeline_status || "CREE";
  const currentStepIndex = pipelineSteps.findIndex(s => s.key === currentStatus);
  const approvedBP = dossier.bons_provisoir ? dossier.bons_provisoir.find(b => b.etat === "APPROUVE") : null;
%>

<!-- A. PIPELINE STATUS TRACKER BAR -->
<div class="card border-0 shadow-sm rounded-3 mb-4 text-start">
  <div class="card-body p-4 pb-3">
    <h6 class="text-xs text-uppercase text-muted tracking-wider mb-4 fw-bold">
      <i class="bi bi-bezier2 me-1.5 text-primary"></i>Pipeline opérationnel de Transit & Bons de caisse
    </h6>
    <div class="d-flex justify-content-between align-items-center position-relative flex-wrap gap-y-4">
      <!-- Track Background Line -->
      <div class="position-absolute top-50 start-0 translate-middle-y w-100 bg-secondary-subtle d-none d-md-block" style="height: 4px; z-index: 1;"></div>
      <!-- Progress Fill Line -->
      <div class="position-absolute top-50 start-0 translate-middle-y bg-success d-none d-md-block" style="height: 4px; z-index: 1; width: <%= (currentStepIndex / (pipelineSteps.length - 1)) * 100 %>%; transition: width 0.4s ease-in-out;"></div>

      <% pipelineSteps.forEach((step, idx) => { %>
        <% 
          const isCompleted = idx < currentStepIndex;
          const isActive = idx === currentStepIndex;
          
          let circleBg = "bg-white border text-muted";
          let labelClass = "text-muted small";
          if (isActive) {
            circleBg = "bg-primary border border-primary text-white shadow";
            labelClass = "text-primary fw-bold";
          } else if (isCompleted) {
            circleBg = "bg-success border border-success text-white";
            labelClass = "text-success fw-semibold";
          }
        %>
        <div class="d-flex flex-column align-items-center position-relative text-center flex-grow-1" style="z-index: 2; min-width: 90px;">
          <div class="rounded-circle d-flex align-items-center justify-content-center <%= circleBg %>" style="width: 32px; height: 32px; transition: all 0.3s;">
            <% if (isCompleted) { %>
              <i class="bi bi-check-lg" style="font-size: 1rem;"></i>
            <% } else { %>
              <span style="font-size: 0.85rem;" class="fw-bold"><%= idx + 1 %></span>
            <% } %>
          </div>
          <span class="mt-2 <%= labelClass %>" style="font-size: 0.8rem;"><%= step.label %></span>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<% 
  // Trouver s'il y a une demande de correction active sur ce dossier
  const backtrackTask = (dossier.taches && dossier.taches.length > 0) ? dossier.taches.find(t => t.titre.startsWith("[Demande de modification]") && t.etat !== "FAIT" && t.etat !== "TERMINE") : null;
%>
<% if (backtrackTask) { %>
  <div class="alert alert-warning border-0 shadow-sm d-flex align-items-start gap-3 p-3.5 mb-4 rounded-3 text-start" style="background-color: #fffbeb; border-left: 4px solid #f59e0b !important;">
    <span class="fs-4">⚠️</span>
    <div>
      <h6 class="fw-bold text-amber-950 mb-1">Dossier Rétrogadé - Demande de Correction active</h6>
      <p class="text-sm text-slate-700 mb-2">Ce dossier fait l'objet d'un retour en arrière pour corrections.</p>
      <div class="bg-white bg-opacity-70 p-2.5 rounded border border-warning-subtle small font-monospace text-slate-800">
        <%= backtrackTask.titre %>
      </div>
      <span class="text-xs text-muted d-block mt-2">L'acteur concerné a été notifié en temps réel. Veuillez effectuer les modifications requises et valider la tâche associée pour reprendre le pipeline d'approbation.</span>
    </div>
  </div>
<% } %>

<!-- B. CONDITIONAL ACTION SYSTEM BOARD -->
<div class="card border-0 shadow-sm rounded-3 mb-4 text-start border-start border-primary border-4">
  <div class="card-body p-4">
    <div class="d-sm-flex justify-content-between align-items-center gap-3">
      <div>
        <h5 class="fw-bold text-slate-800 mb-1"><i class="bi bi-gear-fill me-1.5 text-primary"></i>Contrôle d'Étape Dossier</h5>
        <p class="text-sm text-muted mb-0">Rôle actif : <strong class="text-slate-700 font-sans uppercase"><%= user.role %></strong> • Étape courante : <strong class="text-primary"><%= pipelineSteps[currentStepIndex].label %></strong></p>
      </div>
      <div class="mt-3 mt-sm-0">
        <span class="badge bg-primary-subtle text-primary border px-3 py-1.5 rounded-pill text-xs fw-semibold lowercase">
          status: <%= currentStatus %>
        </span>
      </div>
    </div>
    <hr class="my-3">

    <div class="workflow-actions-area">
      <% if (currentStatus === "CREE") { %>
        <% if (["secretariat", "super_admin", "pdg", "dg", "dga"].includes(user.role)) { %>
          <div class="p-3 bg-light rounded border d-sm-flex justify-content-between align-items-center">
            <div>
              <h6 class="fw-bold mb-1">Transmission au service GUCE</h6>
              <p class="text-xs text-muted mb-0">Veuillez soumettre le dossier au service GUCE pour l'enregistrement des frais d'assurances, DESC et RVC.</p>
            </div>
            <form action="/dossiers/<%= dossier.id %>/pipeline/soumettre-guce" method="POST" class="mt-2 mt-sm-0">
              <button type="submit" class="btn btn-primary rounded-pill px-4 btn-sm fw-bold">
                <i class="bi bi-send-check-fill me-1"></i>Transmettre au GUCE
              </button>
            </form>
          </div>
        <% } else { %>
          <div class="text-muted italic small py-2"><i class="bi bi-info-circle me-1"></i>En attente de transmission par le secrétariat administratif.</div>
        <% } %>

      <% } else if (currentStatus === "GUCE") { %>
        <% if (["guce", "super_admin", "pdg", "dg", "dga", "auditeur1"].includes(user.role)) { %>
          <div class="p-3 bg-light rounded border">
            <h6 class="fw-bold mb-2"><i class="bi bi-bank2 text-primary me-1"></i>Formalités Administratives du GUCE</h6>
            <p class="text-xs text-muted mb-3">Veuillez renseigner les frais réglés aux guichets d'assurances, RVC et DESC, puis d'attacher le Manifeste CAMCIS ci-dessous.</p>
            
            <form action="/dossiers/<%= dossier.id %>/pipeline/valider-guce" method="POST" enctype="multipart/form-data" class="row g-2 text-start">
              <div class="col-md-3">
                <label class="form-label text-xs fw-bold">Montant Assurance (FCFA)</label>
                <input type="number" name="assurance_montant" class="form-control form-control-sm bg-white" placeholder="Ex: 125000" min="0">
              </div>
              <div class="col-md-3">
                <label class="form-label text-xs fw-bold">Montant DESC (FCFA)</label>
                <input type="number" name="desc_montant" class="form-control form-control-sm bg-white" placeholder="Ex: 85000" min="0">
              </div>
              <div class="col-md-3">
                <label class="form-label text-xs fw-bold">Montant RVC (FCFA)</label>
                <input type="number" name="rvc_montant" class="form-control form-control-sm bg-white" placeholder="Ex: 60000" min="0">
              </div>
              <div class="col-md-3">
                <label class="form-label text-xs fw-bold">Statut de Manifestation</label>
                <div class="form-check form-switch mt-1.5">
                  <input class="form-check-input" type="checkbox" name="manifeste_checked" id="chManifest" checked>
                  <label class="form-check-label text-xs fw-semibold" for="chManifest">Déclaré Manifesté</label>
                </div>
              </div>
              
              <!-- Added local uploads for GUCE quittances -->
              <div class="col-12 mt-2">
                <div class="row g-2">
                  <div class="col-md-4">
                    <div class="p-2 border rounded bg-white">
                      <label class="form-label text-xs fw-bold text-slate-700 mb-1"><i class="bi bi-file-earmark-pdf text-danger me-1"></i>Pièce Assurance (PDF/Image)</label>
                      <input type="file" name="fichier_assurance" class="form-control form-control-sm" accept=".pdf,image/*">
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="p-2 border rounded bg-white">
                      <label class="form-label text-xs fw-bold text-slate-700 mb-1"><i class="bi bi-file-earmark-pdf text-danger me-1"></i>Pièce DESC (PDF/Image)</label>
                      <input type="file" name="fichier_desc" class="form-control form-control-sm" accept=".pdf,image/*">
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="p-2 border rounded bg-white">
                      <label class="form-label text-xs fw-bold text-slate-700 mb-1"><i class="bi bi-file-earmark-pdf text-danger me-1"></i>Pièce RVC (PDF/Image)</label>
                      <input type="file" name="fichier_rvc" class="form-control form-control-sm" accept=".pdf,image/*">
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-12 mt-3 fs-7 text-muted border-top pt-2">
                <i class="bi bi-info-circle-fill text-info"></i> Les documents téléversés seront archivés directement dans le **Dossier d'Archives PDF** à droite pour audit.
              </div>
              <div class="col-12 mt-2 text-end">
                <button type="submit" class="btn btn-success rounded-pill px-4 btn-sm fw-bold">
                  <i class="bi bi-shield-check me-1"></i>Enregistrer & Transmettre à la Validation
                </button>
              </div>
            </form>
          </div>
        <% } else { %>
          <div class="text-muted italic small py-2"><i class="bi bi-clock-history me-1"></i>En attente de traitement et validation des formalités par le service GUCE.</div>
        <% } %>

      <% } else if (currentStatus === "VALIDATION") { %>
        <% if (["validation", "validation_role", "super_admin", "pdg", "dg", "dga", "auditeur1"].includes(user.role)) { %>
          <div class="p-3 bg-light rounded border text-start">
            <h6 class="fw-bold mb-2">Décision administrative requise (CAMCIS)</h6>
            <p class="text-xs text-muted mb-3">Vérifiez les pièces jointes importées (Notamment les quittances d'assurances / douane) puis joignez les documents CAMCIS validés ci-dessous.</p>
            
            <form action="/dossiers/<%= dossier.id %>/pipeline/approuver" method="POST" enctype="multipart/form-data" class="mb-3">
              <div class="mb-3 p-2 bg-white border rounded">
                <label class="form-label text-xs fw-bold text-slate-700 mb-1"><i class="bi bi-file-earmark-pdf text-danger me-1"></i>Joindre documents CAMCIS (PDF/Image, multi-sélection)</label>
                <input type="file" name="fichiers_camcis" class="form-control form-control-sm" accept=".pdf,image/*" multiple>
              </div>
              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success rounded-pill px-4 btn-sm fw-bold">
                  <i class="bi bi-check-circle-fill me-1"></i>Approuver (Valider en CAMCIS)
                </button>
              </div>
            </form>

            <form action="/dossiers/<%= dossier.id %>/pipeline/rejeter" method="POST">
              <button type="submit" class="btn btn-danger rounded-pill px-4 btn-sm fw-bold">
                <i class="bi bi-x-circle-fill me-1"></i>Rejeter (Retour au GUCE)
              </button>
            </form>
          </div>
        <% } else { %>
          <div class="text-warning italic small py-2"><i class="bi bi-clock-history me-1"></i>Dossier en attente de visa réglementaire par l'agent de validation.</div>
        <% } %>

      <% } else if (currentStatus === "EN_TRAITEMENT") { %>
        <% if (["acconage", "enlevement", "super_admin"].includes(user.role)) { %>
          <div class="p-3 bg-light rounded border text-start">
            <h6 class="fw-bold text-slate-800 mb-2"><i class="bi bi-cash-stack text-success me-1"></i>Créer une Demande d'Avance (Bon Provisoire)</h6>
            
            <form action="/bons/provisoir" method="POST" enctype="multipart/form-data" id="provisoirBonForm">
              <input type="hidden" name="dossier_id" value="<%= dossier.id %>">
              <input type="hidden" id="bp_items_json" name="items_json" value="[]">
              
              <div class="mb-3">
                <label class="form-label text-xs fw-bold text-muted">Objet global du décaissement <span class="text-danger">*</span></label>
                <input type="text" name="objet" class="form-control form-control-sm" placeholder="Ex: Frais acconage et manutention pour conteneurs..." required>
              </div>

              <!-- Added local upload input for Operational agents -->
              <div class="mb-3">
                <div class="p-2 border rounded bg-white">
                  <label class="form-label text-xs fw-bold text-slate-700 mb-1"><i class="bi bi-file-earmark-pdf text-danger me-1"></i>Joindre Proforma, Facture ou Devis estimatif (PDF, Optionnel)</label>
                  <input type="file" name="pdf_file" class="form-control form-control-sm" accept=".pdf">
                </div>
              </div>

              <!-- Lignes de charges -->
              <div class="table-responsive mb-2">
                <table class="table table-bordered table-sm align-middle fs-7 mb-1" id="bpItemsTable">
                  <thead class="table-light">
                    <tr>
                      <th class="ps-2" style="width: 70%;">Désignation de la charge</th>
                      <th style="width: 25%;">Montant (FCFA)</th>
                      <th style="width: 5%;" class="text-center">#</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="bp-item-row">
                      <td class="p-1">
                        <input type="text" class="form-control form-control-xs bp-desc-input" placeholder="Ex: Manutention Guichet Unique" required>
                      </td>
                      <td class="p-1">
                        <input type="number" class="form-control form-control-xs bp-amount-input text-end" placeholder="0" min="0" required>
                      </td>
                      <td class="p-1 text-center">
                        <button type="button" class="btn btn-outline-danger btn-xs border-0 py-0 px-1 remove-bp-row" disabled><i class="bi bi-trash"></i></button>
                      </td>
                    </tr>
                  </tbody>
                  <tfoot>
                    <tr>
                      <td class="text-end fw-bold ps-2 py-2">TOTAL AUTOMATIQUE :</td>
                      <td class="text-end p-1">
                        <span id="bp_calculated_total" class="fw-bold text-primary font-monospace fs-6">0</span> <small class="text-muted">F</small>
                        <input type="hidden" name="montant_demande" id="bp_montant_demande_input" value="0">
                      </td>
                      <td></td>
                    </tr>
                  </tfoot>
                </table>
              </div>
              <div class="text-start mb-1 d-flex justify-content-between align-items-center">
                <button type="button" class="btn btn-outline-primary btn-xs" id="addBPItemBtn">
                  <i class="bi bi-plus-lg me-1"></i>Ajouter une ligne de dépense
                </button>
                <button type="submit" class="btn btn-success btn-sm rounded-pill px-4 fw-bold">
                  <i class="bi bi-plus-lg me-1"></i>Émettre le Bon Provisoire
                </button>
              </div>
            </form>
          </div>
        <% } else { %>
          <div class="text-muted italic small py-2"><i class="bi bi-info-circle me-1"></i>Dossier en traitement logistique. En attente de demande de fonds (Bons) par le service d'acconage ou d'enlèvement.</div>
        <% } %>

      <% } else if (currentStatus === "BON_PROVISOIR") { %>
        <% 
          // Find the active pending BP
          const pendingBP = dossier.bons_provisoir ? dossier.bons_provisoir.find(b => b.etat === "EN_ATTENTE") : null;
        %>
        <% if (pendingBP) { %>
          <% 
            const allTicksApproved = pendingBP.tick_pdg && pendingBP.tick_dg && pendingBP.tick_dga && pendingBP.tick_daf && pendingBP.tick_audit;
          %>
          <% if (user.role === "agent_payeur" && !allTicksApproved) { %>
            <div class="p-3 bg-light text-muted rounded border border-secondary text-start">
              <h6 class="fw-bold mb-1 text-slate-800"><i class="bi bi-shield-lock-fill text-danger me-1"></i>Contrôle de conformité de la Caisse</h6>
              <p class="small mb-0 mt-2 text-italic"><i class="bi bi-hourglass me-1 text-warning"></i>Ce bon provisoire est en cours de traitement par le management. Ses détails et son PDF ne seront visibles pour la Caisse qu'une fois les 5 visas obligatoires validés.</p>
            </div>
          <% } else { %>
            <div class="p-3 bg-warning-subtle text-slate-800 rounded border border-warning text-start">
              <h6 class="fw-bold mb-1 text-slate-950 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-file-earmark-lock-fill me-1"></i>Bon Provisoire <%= pendingBP.numero %> en cours de signature</span>
                <a href="/bons/<%= pendingBP.id %>/pdf" target="_blank" class="btn btn-xs btn-outline-danger font-bold rounded-pill">
                  <i class="bi bi-file-earmark-pdf-fill me-1"></i> Consulter l'Imprimé PDF
                </a>
              </h6>
              <div class="small my-2">
                <strong>Demandeur :</strong> <%= pendingBP.demandeur.prenom || '' %> <%= pendingBP.demandeur.nom %> (<%= pendingBP.service %>)<br>
                <strong>Objet :</strong> <%= pendingBP.objet %><br>
                <strong>Montant demandé :</strong> <strong class="fs-6 text-primary"><%= pendingBP.montant_demande.toLocaleString('fr-FR') %> F</strong>
              </div>

            <!-- Visas checking block (PDG, DG, DGA, DAF, Audit) -->
            <div class="row g-2 my-2.5 p-2 bg-white rounded border text-start">
              <div class="col-12 border-bottom pb-1 mb-1">
                <span class="text-xs fw-bold text-slate-700 uppercase" style="font-size: 0.72rem;"><i class="bi bi-shield-check text-success me-1"></i>Contrôle de conformité des visas requis :</span>
              </div>
              <% 
                const ticks = [
                  { key: 'pdg', label: 'Visa PDG', val: pendingBP.tick_pdg, by: pendingBP.tick_pdg_by },
                  { key: 'dg', label: 'Visa DG', val: pendingBP.tick_dg, by: pendingBP.tick_dg_by },
                  { key: 'dga', label: 'Visa DGA', val: pendingBP.tick_dga, by: pendingBP.tick_dga_by },
                  { key: 'daf', label: 'Visa DAF', val: pendingBP.tick_daf, by: pendingBP.tick_daf_by },
                  { key: 'audit', label: 'Visa Audit', val: pendingBP.tick_audit, by: pendingBP.tick_audit_by }
                ];
              %>
              <% ticks.forEach(tick => { %>
                <div class="col-6 col-md-2" style="width: 20%;">
                  <div class="p-1 px-2 border rounded bg-light d-flex align-items-center justify-content-between" style="font-size: 0.72rem;">
                    <div>
                      <span class="fw-bold text-slate-800 d-block" style="font-size: 0.72rem;"><%= tick.label %></span>
                      <% if (tick.by) { %>
                        <span class="text-muted d-block text-truncate" style="font-size: 0.6rem; max-width: 65px;" title="Signé par <%= tick.by %>">Par: <%= tick.by.split(' ')[0] %></span>
                      <% } else { %>
                        <span class="text-danger d-block text-italic" style="font-size: 0.6rem;">Absent</span>
                      <% } %>
                    </div>
                    <div class="form-check form-switch p-0 m-0">
                      <%
                        let isAuthorizedToTick = false;
                        if (user.role === "super_admin") {
                          isAuthorizedToTick = true;
                        } else {
                          if (tick.key === "pdg" && user.role === "pdg") isAuthorizedToTick = true;
                          if (tick.key === "dg" && user.role === "dg") isAuthorizedToTick = true;
                          if (tick.key === "dga" && user.role === "dga") isAuthorizedToTick = true;
                          if (tick.key === "daf" && user.role === "daf") isAuthorizedToTick = true;
                          if (tick.key === "audit" && (user.role === "auditeur1" || user.role === "auditeur2")) isAuthorizedToTick = true;
                        }
                      %>
                      <input class="form-check-input ms-0 top-mgmt-checkbox" type="checkbox" 
                             data-bon-id="<%= pendingBP.id %>" data-tick-key="<%= tick.key %>"
                             style="width: 1.5rem; height: 0.75rem; cursor: pointer;"
                             <%= tick.val ? 'checked' : '' %>
                             <%= !isAuthorizedToTick ? 'disabled' : '' %>>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>

            <% 
              const allTicksApproved = pendingBP.tick_pdg && pendingBP.tick_dg && pendingBP.tick_dga && pendingBP.tick_daf && pendingBP.tick_audit;
            %>

            <% if (["direction", "super_admin", "pdg", "dg", "dga", "daf", "auditeur1", "auditeur2"].includes(user.role)) { %>
              <div class="d-flex gap-2 mt-3">
                <button onclick="workflowApproveBP(<%= pendingBP.id %>)" class="btn btn-success btn-sm rounded-pill px-3 fw-bold" <%= !allTicksApproved ? 'disabled title="Veuillez d\'abord cocher les 5 visas obligatoires"' : '' %>>
                  <i class="bi bi-check-lg me-1"></i>Approuver et autoriser le décaissement
                </button>
                <button onclick="workflowRejectBP(<%= pendingBP.id %>, '<%= pendingBP.numero %>')" class="btn btn-danger btn-sm rounded-pill px-3 fw-bold">
                  <i class="bi bi-x-lg me-1"></i>Rejeter avec motif
                </button>
              </div>
            <% } else if (user.role === "agent_payeur") { %>
               <% if (allTicksApproved) { %>
                  <div class="mt-3 p-3 bg-success-subtle border border-success rounded text-success-emphasis text-start">
                    <p class="small mb-2 fw-medium"><i class="bi bi-check-circle-fill me-1"></i>Tous les visas du Top Management ont été vérifiés et visés. Vous pouvez décaisser les fonds aux guichets.</p>
                    <button onclick="workflowApproveBP(<%= pendingBP.id %>)" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">
                      <i class="bi bi-cash-coin me-1"></i>Valider et décaisser les fonds du Bon
                    </button>
                  </div>
               <% } else { %>
                  <div class="text-danger small mt-3 fw-bold p-2.5 border border-danger rounded bg-danger-subtle text-start animate-pulse">
                    <i class="bi bi-shield-slash-fill me-1"></i>CONTRÔLE CAISSE : Décaissement non autorisé. Les signatures des 5 Directeurs (PDG, DG, DGA, DAF, Audit) ne sont pas au complet sur le document.
                  </div>
               <% } %>
            <% } else { %>
              <div class="text-amber-800 small text-italic mt-2">
                <i class="bi bi-hourglass text-amber-600 me-1"></i>En attente de visa par le directeur ou de décaissement par la Caisse.
              </div>
            <% } %>
          </div>
          <% } %>
        <% } else { %>
          <div class="text-muted italic small py-2"><i class="bi bi-exclamation-triangle me-1"></i>Aucun bon provisoire actif trouvé au statut 'En attente'. Transitionnement intermédiaire.</div>
        <% } %>

      <% } else if (currentStatus === "BON_REEL") { %>
        <% 
          // Uses the globally defined approvedBP
        %>
        
        <% if (approvedBP && !approvedBP.bon_reel) { %>
          <% if (["acconage", "enlevement", "super_admin"].includes(user.role)) { %>
            <div class="p-3 bg-light rounded border text-start">
              <h6 class="fw-bold text-slate-800 mb-1"><i class="bi bi-receipt-cutoff me-1 text-primary"></i>Saisir l'utilisation réelle des fonds (Justificatif d'Écart)</h6>
              <p class="text-xs text-muted mb-3">Enregistrez les montants dépensés pour le Bon Provisoire <strong class="text-primary"><%= approvedBP.numero %></strong> afin de restituer le reliquat ou acter le dépassement.</p>
              
              <form action="/bons/reel" method="POST" enctype="multipart/form-data" id="reelBonForm">
                <input type="hidden" name="bon_provisoir_id" value="<%= approvedBP.id %>">
                <input type="hidden" id="br_items_json" name="items_json" value="[]">

                <div class="row g-3 mb-3 text-start">
                  <div class="col-md-6">
                    <label class="form-label text-xs fw-bold text-muted">Observations de clôture / Raisons d'écart <span class="text-danger">*</span></label>
                    <input type="text" name="observations" class="form-control form-control-sm" placeholder="Ex: Justificatif douane et quittances jointes..." required>
                  </div>
                  <div class="col-md-6 border-start text-end">
                    <span class="text-muted small">Avance provisoire perçue :</span>
                    <strong class="text-primary font-monospace fs-6 d-block mt-1"><%= approvedBP.montant_demande.toLocaleString('fr-FR') %> F CFA</strong>
                  </div>
                </div>

                <!-- Added multiple file upload field for port receipts (scan or photo) -->
                <div class="mb-3">
                  <div class="p-2 border rounded bg-white">
                    <label class="form-label text-xs fw-bold text-slate-700 mb-1"><i class="bi bi-file-earmark-check-fill text-success me-1"></i>Joindre les reçus / quittances du port (scan ou photo)</label>
                    <input type="file" name="fichiers_justificatifs" class="form-control form-control-sm" accept=".pdf,image/*" multiple required>
                  </div>
                </div>

                <!-- Lignes de charges réelles -->
                <div class="table-responsive mb-2">
                  <table class="table table-bordered table-sm align-middle fs-7 mb-1" id="brItemsTable">
                    <thead class="table-light">
                      <tr>
                        <th class="ps-2" style="width: 70%;">Prestation / Dépense réelle</th>
                        <th style="width: 25%;">Montant Réel (FCFA)</th>
                        <th style="width: 5%;" class="text-center">#</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% 
                        let bpItems = [];
                        if (approvedBP.items_json) {
                          try {
                            bpItems = JSON.parse(approvedBP.items_json);
                          } catch(e){}
                        }
                        if (bpItems.length === 0) {
                          bpItems = [{ designation: approvedBP.objet, montant: approvedBP.montant_demande }];
                        }
                        bpItems.forEach((it, idx) => {
                      %>
                        <tr class="br-item-row">
                          <td class="p-1">
                            <input type="text" class="form-control form-control-xs br-desc-input" value="<%= it.designation %>" placeholder="Ex: Manutention" required>
                          </td>
                          <td class="p-1">
                            <input type="number" class="form-control form-control-xs br-amount-input text-end" value="<%= it.montant %>" placeholder="0" min="0" required>
                          </td>
                          <td class="p-1 text-center">
                            <button type="button" class="btn btn-outline-danger btn-xs border-0 py-0 px-1 remove-br-row" <%= bpItems.length <= 1 ? 'disabled' : '' %>><i class="bi bi-trash"></i></button>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                    <tfoot>
                      <tr>
                        <td class="text-end fw-bold ps-2 py-2">TOTAL DEPENSES REELLES :</td>
                        <td class="text-end p-1">
                          <span id="br_calculated_total" class="fw-bold text-success font-monospace fs-6">0</span> <small class="text-muted">F</small>
                          <input type="hidden" name="montant_reel" id="br_montant_reel_input" value="0">
                        </td>
                        <td></td>
                      </tr>
                      <tr>
                        <td class="text-end fw-bold ps-2 py-1 text-secondary">ÉCART PREVISIONNEL/REEL :</td>
                        <td class="text-end p-1">
                          <span id="br_calculated_ecart" class="fw-bold font-monospace">0</span> <small class="text-muted">F</small>
                        </td>
                        <td></td>
                      </tr>
                    </tfoot>
                  </table>
                </div>
                <div class="text-start mb-1.5 d-flex justify-content-between align-items-center">
                  <button type="button" class="btn btn-outline-primary btn-xs" id="addBRItemBtn">
                    <i class="bi bi-plus-lg me-1"></i>Ajouter un article de charge réelle
                  </button>
                  <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">
                    <i class="bi bi-file-earmark-check me-1"></i>Soumettre le Bon Réel Définitif
                  </button>
                </div>
              </form>
            </div>
          <% } else { %>
            <div class="text-muted italic small py-2"><i class="bi bi-info-circle me-1"></i>En attente de justificatifs réels d'utilisation par l'agent de terrain.</div>
          <% } %>
        <% } else if (approvedBP && approvedBP.bon_reel) { %>
          <!-- If Bon Reel exists but has not been confirmed yet -->
          <div class="p-3 bg-info-subtle border border-info rounded text-slate-800 text-start">
            <h6 class="fw-bold text-slate-900 mb-1"><i class="bi bi-cash me-1"></i>Justificatifs de frais soumis</h6>
            <div class="small my-2">
              <strong>Fonds Avancés :</strong> <%= approvedBP.montant_demande.toLocaleString('fr-FR') %> F<br>
              <strong>Fonds Dépensés :</strong> <%= approvedBP.bon_reel.montant_reel.toLocaleString('fr-FR') %> F<br>
              <strong>Écart de caisse :</strong> 
              <% if (approvedBP.bon_reel.ecart >= 0) { %>
                <span class="text-success fw-bold">+<%= approvedBP.bon_reel.ecart.toLocaleString('fr-FR') %> F CFA (Reliquat versé en caisse)</span>
              <% } else { %>
                <span class="text-danger fw-bold"><%= approvedBP.bon_reel.ecart.toLocaleString('fr-FR') %> F CFA (Remboursement requis)</span>
              <% } %>
            </div>

            <% if (["agent_payeur", "super_admin"].includes(user.role)) { %>
              <div class="mt-3 text-start">
                <button onclick="workflowConfirmDecaissement(<%= approvedBP.bon_reel.id %>)" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">
                  <i class="bi bi-check-circle-fill me-1"></i>Confirmer décaissement et valider le bon de caisse
                </button>
              </div>
            <% } else { %>
              <div class="text-info-emphasis text-italic small mt-2">
                <i class="bi bi-clock-history me-1"></i>En attente de confirmation finale de caisse par le Trésorier payeur.
              </div>
            <% } %>
          </div>
        <% } %>

      <% } else if (currentStatus === "FACTURATION") { %>
        <% if (["comptable", "commercial", "super_admin", "comptable_ops", "finances"].includes(user.role)) { %>
          <div class="p-3 bg-light rounded border d-sm-flex justify-content-between align-items-center text-start">
            <div>
              <h6 class="fw-bold mb-1 col-md-9" style="font-size: 0.9rem;">Régularisation Complétée • Facturation Client d'Honoraires</h6>
              <p class="text-xs text-muted mb-0">Tous les bons de dépenses sont clos. Veuillez marquer l'envoi de la facture client d'honoraires pour clore logistiquement ce dossier.</p>
            </div>
            <div class="d-flex gap-2 mt-2 mt-sm-0 flex-shrink-0">
              <a href="/documents/create?dossier_id=<%= dossier.id %>" class="btn btn-outline-primary rounded-pill px-3 btn-sm fw-bold d-inline-flex align-items-center">
                <i class="bi bi-file-earmark-plus-fill me-1"></i>Facturer le Transit
              </a>
              <form action="/dossiers/<%= dossier.id %>/pipeline/facturer" method="POST">
                <button type="submit" class="btn btn-success rounded-pill px-3 btn-sm fw-bold">
                  <i class="bi bi-lock-fill me-1"></i>Clôture Logistique
                </button>
              </form>
            </div>
          </div>
        <% } else { %>
          <div class="text-muted italic small py-2"><i class="bi bi-info-circle me-1"></i>Traitement opérationnel clos. Les comptes de transit organisent la facturation d'honoraires globale pour le client.</div>
        <% } %>

      <% } else if (currentStatus === "CLOTURE") { %>
        <% if (["comptable_ops", "super_admin", "direction", "comptable"].includes(user.role)) { %>
          <div class="p-3 bg-light rounded border d-sm-flex justify-content-between align-items-center text-start">
            <div>
              <h6 class="fw-bold mb-1">Passer à l'archivage définitif</h5>
              <p class="text-xs text-muted mb-0">Tous les règlements comptables et factures sont payés. Marquez le dossier comme Archivé pour l'archivage réglementaire.</p>
            </div>
            <form action="/dossiers/<%= dossier.id %>/pipeline/cloturer" method="POST" class="mt-2 mt-sm-0">
              <button type="submit" class="btn btn-dark rounded-pill px-4 btn-sm fw-bold">
                <i class="bi bi-archive-fill me-1"></i>Archiver Définitivement
              </button>
            </form>
          </div>
        <% } else { %>
          <div class="text-muted italic small py-2"><i class="bi bi-info-circle me-1"></i>Facturation validée. En attente de l'archivage comptable définitif par le comptable général maritime.</div>
        <% } %>

      <% } else if (currentStatus === "ARCHIVE") { %>
        <div class="p-3 bg-success-subtle text-success rounded border border-success d-flex align-items-center">
          <i class="bi bi-archive-fill me-2 fs-5"></i>
          <div>
            <strong>Dossier clôturé administrativement et archivé officiellement</strong>
            <% if (dossier.archived_at) { %>
              <div class="text-xs text-muted mt-0.5">Le <%= new Date(dossier.archived_at).toLocaleString('fr-FR') %></div>
            <% } %>
          </div>
        </div>
      <% } %>

      <% if (currentStatus !== "CREE" && currentStatus !== "ARCHIVE") { %>
        <div class="mt-3.5 pt-3 border-top d-flex justify-content-between align-items-center">
          <div class="text-xs text-muted">
            <i class="bi bi-info-circle me-1"></i>Une information d'une étape validée est erronée ?
          </div>
          <button type="button" class="btn btn-outline-warning btn-xs rounded-pill px-3 fw-semibold" data-bs-toggle="modal" data-bs-target="#retourArriereModal">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Demander une correction (Rétrograder)
          </button>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Modal Demande de retour arrière / Correction -->
<div class="modal fade" id="retourArriereModal" tabindex="-1" aria-hidden="true" style="text-align: left;">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-warning text-dark py-3">
        <h5 class="modal-title fw-bold"><i class="bi bi-arrow-counterclockwise me-2"></i>Demander une modification rétroactive</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/dossiers/<%= dossier.id %>/pipeline/retour-arriere" method="POST">
        <div class="modal-body p-4 text-start">
          <p class="small text-muted mb-3">
            Le renvoi du dossier à l'étape précédente verrouillera les étapes futures et créera une tâche automatique de correction urgente. Vous ne pouvez modifier que vos propres informations correspondantes.
          </p>
          <div class="mb-3">
            <label class="form-label fw-bold small text-slate-700">Raison / Motif de la demande de correction <span class="text-danger">*</span></label>
            <textarea name="motif" class="form-control text-sm" rows="3" placeholder="Ex: Ajustement de la valeur en douane suite aux nouvelles consignes..." required></textarea>
          </div>
        </div>
        <div class="modal-footer p-3 bg-light border-top-0">
          <button type="button" class="btn btn-secondary rounded-pill px-3" data-bs-dismiss="modal">Annuler</button>
          <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold">Rétrograder l'étape</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Reject BP inside Dossier Detail page -->
<div class="modal fade" id="workflowRejectModal" tabindex="-1" aria-hidden="true" style="text-align: left;">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-danger text-white py-3">
        <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Rejeter le Bon Provisoire <span id="workflowRejectBonNum"></span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <div class="mb-3">
          <label class="form-label fw-bold">Motif du rejet <span class="text-danger">*</span></label>
          <textarea id="workflowMotifRejetInput" class="form-control" rows="3" placeholder="Saisissez la raison précise du rejet..." required></textarea>
        </div>
      </div>
      <div class="modal-footer p-3 bg-light border-top-0">
        <button type="button" class="btn btn-secondary rounded-pill px-3" data-bs-dismiss="modal">Annuler</button>
        <button type="button" id="workflowConfirmRejectBtn" class="btn btn-danger rounded-pill px-4">Soumettre le rejet</button>
      </div>
    </div>
  </div>
</div>

<script>
  let wRejectId = null;

  async function workflowApproveBP(bpId) {
    if(!confirm("Voulez-vous approuver formellement ce bon provisoire d'avance ?")) return;
    try {
      const res = await fetch(`/bons/provisoir/${bpId}/approuver`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" }
      });
      const data = await res.json();
      if(data.ok) {
        alert("Bon provisoire approuvé avec succès ! Le dossier passe au statut 'Bon Réel'.");
        window.location.reload();
      } else {
        alert("Erreur: " + data.message);
      }
    } catch(e) {
      console.error(e);
      alert("Une erreur de communication est survenue.");
    }
  }

  function workflowRejectBP(bpId, numero) {
    wRejectId = bpId;
    document.getElementById("workflowRejectBonNum").innerText = numero;
    document.getElementById("workflowMotifRejetInput").value = "";
    const modal = new bootstrap.Modal(document.getElementById("workflowRejectModal"));
    modal.show();
  }

  document.getElementById("workflowConfirmRejectBtn").addEventListener("click", async () => {
    const motif = document.getElementById("workflowMotifRejetInput").value;
    if(!motif || motif.trim() === "") {
      alert("Le motif de rejet est obligatoire.");
      return;
    }
    try {
      const res = await fetch(`/bons/provisoir/${wRejectId}/rejeter`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ motif_rejet: motif })
      });
      const data = await res.json();
      if(data.ok) {
        alert("Bon provisoire rejeté. Le dossier d'exploitation a été rétrogradé au statut 'En traitement'.");
        window.location.reload();
      } else {
        alert("Erreur: " + data.message);
      }
    } catch(e) {
      console.error(e);
      alert("Une erreur est survenue.");
    }
  });

  async function workflowConfirmDecaissement(bonReelId) {
    if(!confirm("Êtes-vous sûr de vouloir confirmer que les fonds justificatifs ont été décaissés pour ce règlement réel ?")) return;
    try {
      const res = await fetch(`/bons/reel/${bonReelId}/confirmer`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" }
      });
      const data = await res.json();
      if(data.ok) {
        alert(data.message);
        window.location.reload();
      } else {
        alert("Erreur: " + data.message);
      }
    } catch(e) {
      console.error(e);
      alert("Une erreur de communication est survenue.");
    }
  }

  // ----------------------------------------------------
  // Dynamic items table management for Bon Provisoire
  // ----------------------------------------------------
  document.addEventListener("DOMContentLoaded", function() {
    const bpTable = document.getElementById("bpItemsTable");
    const addBPBtn = document.getElementById("addBPItemBtn");
    const bpItemsJsonInput = document.getElementById("bp_items_json");
    const bpMontantDemandeInput = document.getElementById("bp_montant_demande_input");
    const bpCalculatedTotalSpan = document.getElementById("bp_calculated_total");
    const provisoirForm = document.getElementById("provisoirBonForm");

    function calculateBPTotals() {
      if (!bpTable) return;
      const rows = bpTable.querySelectorAll(".bp-item-row");
      let total = 0;
      const items = [];

      rows.forEach(row => {
        const descInput = row.querySelector(".bp-desc-input");
        const amountInput = row.querySelector(".bp-amount-input");
        if (descInput && amountInput) {
          const desc = descInput.value.trim();
          const amt = parseFloat(amountInput.value) || 0;
          total += amt;
          if (desc) {
            items.push({ designation: desc, montant: amt });
          }
        }
      });

      if (bpCalculatedTotalSpan) {
        bpCalculatedTotalSpan.textContent = total.toLocaleString("fr-FR");
      }
      if (bpMontantDemandeInput) {
        bpMontantDemandeInput.value = total;
      }
      if (bpItemsJsonInput) {
        bpItemsJsonInput.value = JSON.stringify(items);
      }

      // Enable/disable delete buttons
      const removeButtons = bpTable.querySelectorAll(".remove-bp-row");
      removeButtons.forEach(btn => {
        btn.disabled = rows.length <= 1;
      });
    }

    if (addBPBtn) {
      addBPBtn.addEventListener("click", () => {
        const tbody = bpTable.querySelector("tbody");
        const newRow = document.createElement("tr");
        newRow.className = "bp-item-row";
        newRow.innerHTML = `
          <td class="p-1">
            <input type="text" class="form-control form-control-xs bp-desc-input" placeholder="Ex: Manutention Guichet Unique" required>
          </td>
          <td class="p-1">
            <input type="number" class="form-control form-control-xs bp-amount-input text-end" placeholder="0" min="0" required>
          </td>
          <td class="p-1 text-center">
            <button type="button" class="btn btn-outline-danger btn-xs border-0 py-0 px-1 remove-bp-row"><i class="bi bi-trash"></i></button>
          </td>
        `;
        tbody.appendChild(newRow);
        calculateBPTotals();

        // Listeners
        newRow.querySelector(".bp-desc-input").addEventListener("input", calculateBPTotals);
        newRow.querySelector(".bp-amount-input").addEventListener("input", calculateBPTotals);
        newRow.querySelector(".remove-bp-row").addEventListener("click", () => {
          newRow.remove();
          calculateBPTotals();
        });
      });
    }

    if (bpTable) {
      bpTable.querySelectorAll(".bp-desc-input").forEach(el => el.addEventListener("input", calculateBPTotals));
      bpTable.querySelectorAll(".bp-amount-input").forEach(el => el.addEventListener("input", calculateBPTotals));
      bpTable.querySelectorAll(".remove-bp-row").forEach(el => {
        el.addEventListener("click", function() {
          this.closest("tr").remove();
          calculateBPTotals();
        });
      });
      calculateBPTotals();
    }

    if (provisoirForm) {
      provisoirForm.addEventListener("submit", function(e) {
        calculateBPTotals();
        const total = parseFloat(bpMontantDemandeInput.value) || 0;
        if (total <= 0) {
          e.preventDefault();
          alert("Veuillez saisir au moins une ligne de charge avec un montant valide (> 0).");
        }
      });
    }


    // ----------------------------------------------------
    // Dynamic items table management for Bon Réel
    // ----------------------------------------------------
    const brTable = document.getElementById("brItemsTable");
    const addBRBtn = document.getElementById("addBRItemBtn");
    const brItemsJsonInput = document.getElementById("br_items_json");
    const brMontantReelInput = document.getElementById("br_montant_reel_input");
    const brCalculatedTotalSpan = document.getElementById("br_calculated_total");
    const brCalculatedEcartSpan = document.getElementById("br_calculated_ecart");
    const reelForm = document.getElementById("reelBonForm");

    // Fetch approved value if it exists
    const brApprovedMontant = <%= approvedBP ? approvedBP.montant_demande : 0 %>;

    function calculateBRTotals() {
      if (!brTable) return;
      const rows = brTable.querySelectorAll(".br-item-row");
      let total = 0;
      const items = [];

      rows.forEach(row => {
        const descInput = row.querySelector(".br-desc-input");
        const amountInput = row.querySelector(".br-amount-input");
        if (descInput && amountInput) {
          const desc = descInput.value.trim();
          const amt = parseFloat(amountInput.value) || 0;
          total += amt;
          if (desc) {
            items.push({ designation: desc, montant: amt });
          }
        }
      });

      if (brCalculatedTotalSpan) {
        brCalculatedTotalSpan.textContent = total.toLocaleString("fr-FR");
      }
      if (brMontantReelInput) {
        brMontantReelInput.value = total;
      }
      if (brItemsJsonInput) {
        brItemsJsonInput.value = JSON.stringify(items);
      }

      // Ecart calculation: Avance minus Real expenses
      const ecart = brApprovedMontant - total;
      if (brCalculatedEcartSpan) {
        if (ecart >= 0) {
          brCalculatedEcartSpan.className = "fw-bold text-success font-monospace";
          brCalculatedEcartSpan.textContent = "+" + ecart.toLocaleString("fr-FR");
        } else {
          brCalculatedEcartSpan.className = "fw-bold text-danger font-monospace";
          brCalculatedEcartSpan.textContent = ecart.toLocaleString("fr-FR");
        }
      }

      // Enable/disable delete buttons
      const removeButtons = brTable.querySelectorAll(".remove-br-row");
      removeButtons.forEach(btn => {
        btn.disabled = rows.length <= 1;
      });
    }

    if (addBRBtn) {
      addBRBtn.addEventListener("click", () => {
        const tbody = brTable.querySelector("tbody");
        const newRow = document.createElement("tr");
        newRow.className = "br-item-row";
        newRow.innerHTML = `
          <td class="p-1">
            <input type="text" class="form-control form-control-xs br-desc-input" placeholder="Ex: Frais de manutention" required>
          </td>
          <td class="p-1">
            <input type="number" class="form-control form-control-xs br-amount-input text-end" placeholder="0" min="0" required>
          </td>
          <td class="p-1 text-center">
            <button type="button" class="btn btn-outline-danger btn-xs border-0 py-0 px-1 remove-br-row"><i class="bi bi-trash"></i></button>
          </td>
        `;
        tbody.appendChild(newRow);
        calculateBRTotals();

        // Listeners
        newRow.querySelector(".br-desc-input").addEventListener("input", calculateBRTotals);
        newRow.querySelector(".br-amount-input").addEventListener("input", calculateBRTotals);
        newRow.querySelector(".remove-br-row").addEventListener("click", () => {
          newRow.remove();
          calculateBRTotals();
        });
      });
    }

    if (brTable) {
      brTable.querySelectorAll(".br-desc-input").forEach(el => el.addEventListener("input", calculateBRTotals));
      brTable.querySelectorAll(".br-amount-input").forEach(el => el.addEventListener("input", calculateBRTotals));
      brTable.querySelectorAll(".remove-br-row").forEach(el => {
        el.addEventListener("click", function() {
          this.closest("tr").remove();
          calculateBRTotals();
        });
      });
      calculateBRTotals();
    }

    if (reelForm) {
      reelForm.addEventListener("submit", function(e) {
        calculateBRTotals();
        const total = parseFloat(brMontantReelInput.value) || 0;
        if (total <= 0) {
          e.preventDefault();
          alert("Veuillez saisir au moins une ligne de frais réel.");
        }
      });
    }


    // ----------------------------------------------------
    // Top Management Approval Ticks AJAX Toggle Toter
    // ----------------------------------------------------
    document.querySelectorAll(".top-mgmt-checkbox").forEach(chk => {
      chk.addEventListener("change", async function() {
        const bpId = this.getAttribute("data-bon-id");
        const tickKey = this.getAttribute("data-tick-key");
        const isChecked = this.checked;

        try {
          const response = await fetch(`/bons/provisoir/${bpId}/tick`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({
              tick_key: tickKey,
              checked: isChecked
            })
          });

          const resData = await response.json();
          if (resData.ok) {
            // Real-time quick reload for state updates and security checklist checks!
            window.location.reload();
          } else {
            this.checked = !isChecked;
            alert("Erreur visa : " + (resData.message || "Impossible de mettre à jour le visa de direction."));
          }
        } catch (e) {
          this.checked = !isChecked;
          console.error("Error toggling direction visa:", e);
          alert("Erreur de connexion réseau lors du visa.");
        }
      });
    });
  });
</script>

