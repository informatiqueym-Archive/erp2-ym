<div class="row g-4 text-start">
  <!-- Left Column: Tasks and Invoices -->
  <div class="col-lg-8">
    
    <!-- 3. TASK CHECKLIST section -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white py-3 border-bottom border-light d-flex align-items-center justify-content-between flex-wrap gap-2">
        <h5 class="mb-0 fw-bold font-sans text-dark" style="font-size: 1rem;">
          <i class="bi bi-bookmark-star-fill text-warning me-2"></i>Manifeste des Étapes & Émissions Douanières
        </h5>
        <% if (dossier.pipeline_status !== "ARCHIVE" && dossier.etat !== "CLOTURE") { %>
        <button class="btn btn-primary btn-sm rounded-pill px-3 d-inline-flex align-items-center text-xs" data-bs-toggle="modal" data-bs-target="#quickTaskModal">
          <i class="bi bi-plus-lg me-1"></i> Ajouter Jalon
        </button>
        <% } %>
      </div>
      <div class="card-body p-0">
        <ul class="list-group list-group-flush" id="task-checklist-group">
          <% if (dossier.taches && dossier.taches.length > 0) { %>
            <% dossier.taches.forEach((t) => { %>
              <% const isDone = t.etat.toUpperCase() === 'FAIT' || t.etat.toUpperCase() === 'TERMINE'; %>
              <li class="list-group-item p-3 d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 task-item-container transition-all" 
                  data-tname="<%= t.titre.toLowerCase() %>" 
                  style="<%= isDone ? 'background-color: #fbfdfb; opacity: 0.9;' : '' %>"
                  id="task-row-<%= t.id %>">
                
                <div class="d-flex align-items-start gap-2.5 flex-grow-1">
                  <!-- Checkbox triggers patching instantly -->
                  <div class="form-check p-0 m-0 d-flex align-items-center" style="min-height: 24px;">
                    <input class="form-check-input task-toggle-checkbox bg-white" 
                           type="checkbox" 
                           id="chk-<%= t.id %>" 
                           data-task-id="<%= t.id %>"
                           style="width: 1.2rem; height: 1.2rem; cursor: pointer;" 
                           <%= isDone ? 'checked' : '' %> <%= (dossier.pipeline_status === 'ARCHIVE' || dossier.etat === 'CLOTURE') ? 'disabled' : '' %>>
                  </div>
                  <div class="ms-1">
                    <label class="fw-bold mb-0 text-slate-800 d-block cursor-pointer task-label <%= isDone ? 'text-decoration-line-through text-slate-500' : '' %>" 
                           for="chk-<%= t.id %>" 
                           id="label-text-<%= t.id %>">
                      <%= t.titre %>
                    </label>
                    <div class="d-flex flex-wrap gap-2 mt-1 align-items-center small text-slate-500">
                      <% if (t.intervenant) { %>
                        <span class="badge rounded bg-light text-slate-800 border font-sans" style="font-size: 0.7rem;">
                          <i class="bi bi-person text-slate-500"></i> <%= t.intervenant.nom %>
                        </span>
                      <% } %>
                      <% if (t.deadline) { %>
                        <span class="font-monospace text-xs <%= new Date(t.deadline) < new Date() && !isDone ? 'text-danger fw-bold' : '' %>" style="font-size: 0.72rem;">
                          <i class="bi bi-calendar-event me-1"></i> Échéance : <%= new Date(t.deadline).toLocaleDateString('fr-FR') %>
                        </span>
                      <% } %>
                    </div>
                    <% if (t.observations) { %>
                      <p class="text-slate-600 small mb-0 mt-2 bg-light p-2 rounded border border-light-subtle italic" style="font-size: 0.8rem; line-height: 1.3;">
                        <i class="bi bi-chat-left-quote text-muted me-1"></i>Réf: <%= t.observations %>
                      </p>
                    <% } %>
                  </div>
                </div>

                <div class="d-flex align-items-center gap-1.5 ms-auto">
                  <a href="/taches/<%= t.id %>" class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-1 px-2.5 rounded-pill border-light-subtle" title="Ouvrir le fil de discussion" style="font-size: 0.75rem;">
                    <i class="bi bi-chat-left-text-fill"></i>
                    <span class="d-none d-md-inline" style="font-weight: 600;">Suivi & Discussion</span>
                  </a>

                  <span class="badge rounded-pill px-2.5 py-1 text-xs font-monospace fw-bold <%= isDone ? 'bg-success text-white' : 'bg-warning text-dark' %>" 
                        id="status-badge-<%= t.id %>">
                    <%= isDone ? 'VALIDÉ' : 'EN COURS' %>
                  </span>
                  
                  <% if (dossier.pipeline_status !== 'ARCHIVE' && dossier.etat !== 'CLOTURE') { %>
                  <button class="btn btn-light btn-sm text-slate-500 p-1 rounded-circle" 
                          data-bs-toggle="modal" 
                          data-bs-target="#editTaskModal<%= t.id %>" 
                          title="Modifier les observations ou l'intervenant">
                    <i class="bi bi-pencil-fill" style="font-size: 0.8rem;"></i>
                  </button>

                  <form action="/dossiers/<%= dossier.id %>/taches/<%= t.id %>/modifier" method="POST" class="d-inline" onsubmit="return confirm('Retirer définitivement cette étape ?');">
                    <input type="hidden" name="delete_task" value="yes">
                    <button type="submit" class="btn btn-light btn-sm text-danger p-1 rounded-circle" title="Enlever">
                      <i class="bi bi-trash-fill" style="font-size: 0.8rem;"></i>
                    </button>
                  </form>
                  <% } %>
                </div>
              </li>

              <!-- Modal Edit per Task -->
              <div class="modal fade" id="editTaskModal<%= t.id %>" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                  <div class="modal-content shadow border-0 text-start">
                    <div class="modal-header bg-slate-900 text-white">
                      <h5 class="modal-title fw-bold text-white fs-6">Modifier Jalon : <%= t.titre %></h5>
                      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form action="/dossiers/<%= dossier.id %>/taches/<%= t.id %>/modifier" method="POST">
                      <div class="modal-body">
                        <div class="mb-3">
                          <label class="form-label small fw-semibold">Description / Titre du jalon <span class="text-danger">*</span></label>
                          <input type="text" class="form-control" name="titre" value="<%= t.titre %>" required>
                        </div>
                        <div class="mb-3">
                          <label class="form-label small fw-semibold">Réf / Observations douanières ou BL :</label>
                          <textarea class="form-control font-monospace" name="observations" rows="3" placeholder="Saisir observations..." style="font-size: 0.85rem;"><%= t.observations %></textarea>
                        </div>
                        <div class="mb-3">
                          <label class="form-label small fw-semibold">Assigner cet agent transitaire :</label>
                          <select class="form-select" name="intervenant_id">
                            <option value="">-- Non assigné --</option>
                            <% if (users && users.length > 0) { %>
                              <% users.forEach(u => { %>
                                <option value="<%= u.id %>" <%= t.intervenant_id === u.id ? 'selected' : '' %>><%= u.nom %> (<%= u.role %>)</option>
                              <% }) %>
                            <% } %>
                          </select>
                        </div>
                      </div>
                      <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Fermer</button>
                        <button type="submit" class="btn btn-primary btn-sm">Enregistrer</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="text-center text-muted py-5 px-3">
              <i class="bi bi-card-checklist display-4 text-slate-300 d-block mb-3"></i>
              Aucun jalon configuré pour ce convoi.
              <p class="small mb-0">Ajoutez les étapes clés pour lancer le planning réglementaire.</p>
            </div>
          <% } %>
        </ul>
      </div>
    </div>

    <!-- 4. LINKED INVOICES section -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white py-3 border-bottom border-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold font-sans text-dark" style="font-size: 1rem;">
          <i class="bi bi-receipt-cutoff text-primary me-2"></i>Facturation & Devis Associés (<%= linkedInvoices ? linkedInvoices.length : 0 %>)
        </h5>
        <% if (dossier.pipeline_status !== "ARCHIVE" && dossier.etat !== "CLOTURE") { %>
        <a href="/facturation?action=new&client_id=<%= dossier.client_id %>" class="btn btn-outline-primary btn-sm rounded-pill px-3 text-xs">
          <i class="bi bi-file-earmark-plus"></i> Facturer le Client
        </a>
        <% } %>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
            <thead class="table-light">
              <tr>
                <th class="ps-4">N° Pièce</th>
                <th>Type</th>
                <th>Date d'émission</th>
                <th>Montant Global</th>
                <th>Statut Règlement</th>
                <th class="text-end pe-4">Fiche</th>
              </tr>
            </thead>
            <tbody>
              <% if (linkedInvoices && linkedInvoices.length > 0) { %>
                <% linkedInvoices.forEach(inv => { %>
                  <tr>
                    <td class="ps-4 fw-bold font-monospace text-primary"><%= inv.numero %></td>
                    <td>
                      <span class="badge <%= inv.type === 'FACTURE' ? 'bg-primary-subtle text-primary border border-primary-subtle' : 'bg-secondary-subtle text-secondary border border-secondary-subtle' %> rounded" style="font-size: 0.72rem;">
                        <%= inv.type %>
                      </span>
                    </td>
                    <td class="text-muted"><%= new Date(inv.created_at).toLocaleDateString('fr-FR') %></td>
                    <td class="fw-bold font-monospace"><%= inv.total_ttc.toLocaleString('fr-FR') %> FCFA</td>
                    <td>
                      <% if (inv.etat === 'PAYE') { %>
                        <span class="badge bg-success text-white px-2 py-1" style="font-size: 0.75rem;"><i class="bi bi-check-circle"></i> SOLDÉ</span>
                      <% } else if (inv.etat === 'EMIS') { %>
                        <span class="badge bg-warning text-dark px-2 py-1" style="font-size: 0.75rem;"><i class="bi bi-clock"></i> EN ATTENTE</span>
                      <% } else if (inv.etat === 'BROUILLON') { %>
                        <span class="badge bg-secondary text-white px-2 py-1" style="font-size: 0.75rem;">BROUILLON</span>
                      <% } else { %>
                        <span class="badge bg-danger text-white px-2 py-1" style="font-size: 0.75rem;">ANNULÉ</span>
                      <% } %>
                    </td>
                    <td class="text-end pe-4">
                      <a href="/facturation/<%= inv.id %>" class="btn btn-sm btn-light text-dark rounded-circle" title="Ouvrir">
                        <i class="bi bi-eye"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center text-muted py-4">
                    <i class="bi bi-cash display-6 text-slate-300 d-block mb-2"></i>
                    Aucun document financier n'a été rattaché à la référence <strong class="text-secondary"><%= dossier.numero %></strong>.
                    <p class="text-slate-500 text-xs mb-0 mt-1">Créez une facture portant la mention de ce dossier dans son détail.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Column: Document Attachments and Logs Activity -->
  <div class="col-lg-4">

    <!-- Global Discussion Card -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white py-3 border-bottom border-light">
        <h5 class="mb-0 fw-bold font-sans text-dark" style="font-size: 0.95rem;">
          <i class="bi bi-chat-right-text-fill text-primary me-2"></i>Discussion du Dossier
        </h5>
      </div>
      <div class="card-body p-0">
        <!-- Comments List Container -->
        <div id="dossier-comments-container" class="px-3 pt-3" style="max-height: 400px; overflow-y: auto; background-color: #f8fafc;">
          <% if (dossier.comments && dossier.comments.length > 0) { %>
            <% dossier.comments.forEach(comment => { %>
              <% 
                const initials = (comment.user.nom || "U").substring(0, 2).toUpperCase();
                let avatarBg = "#4b5563";
                if (comment.user.role === "super_admin") avatarBg = "#e11d48";
                else if (["pdg", "dg", "dga"].includes(comment.user.role)) avatarBg = "#7c3aed";
                else if (["validation", "validation_role"].includes(comment.user.role)) avatarBg = "#059669";
                else if (comment.user.role === "guce") avatarBg = "#d97706";
              %>
              <div class="d-flex mb-3 align-items-start text-start dossier-comment-item">
                <!-- Avatar Initials -->
                <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold d-inline-block text-center flex-shrink-0" 
                     style="width: 32px; height: 32px; line-height: 32px; background-color: <%= avatarBg %>; font-size: 0.75rem;" 
                     title="<%= comment.user.nom %> (<%= comment.user.role %>)">
                  <%= initials %>
                </div>
                <!-- Comment Content Block -->
                <div class="ms-2 bg-white p-2.5 rounded shadow-sm border flex-grow-1" style="min-width: 0; margin-left: 10px !important;">
                  <div class="d-flex justify-content-between align-items-center flex-wrap gap-1 mb-1">
                    <span class="fw-bold text-slate-800" style="font-size: 0.82rem;"><%= comment.user.nom %></span>
                    <span class="badge bg-slate-100 text-slate-600 border text-xxs font-sans" style="font-size: 0.7rem;">
                      Écrit lors de l'étape : <%= comment.stage %>
                    </span>
                  </div>
                  <p class="mb-1 text-slate-700 text-sm break-words" style="font-size: 0.85rem; line-height: 1.4; word-wrap: break-word;"><%= comment.contenu %></p>
                  <div class="text-xxs text-slate-400 font-monospace text-end" style="font-size: 0.7rem;">
                    <%= new Date(comment.created_at).toLocaleDateString('fr-FR', {day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit'}) %>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div id="no-comments-indicator" class="text-center text-muted py-5">
              <i class="bi bi-chat-dots text-slate-300 display-6 d-block mb-2"></i>
              Aucun commentaire sur ce dossier. Lancez la discussion !
            </div>
          <% } %>
        </div>

        <!-- Comment Form / Input Fields -->
        <% if (dossier.etat !== "ARCHIVE" && dossier.pipeline_status !== "ARCHIVE") { %>
          <div class="p-3 border-top bg-white">
            <form id="dossier-comment-form">
              <div class="input-group">
                <input type="text" id="dossier-comment-input" class="form-control form-control-sm bg-light" placeholder="Créer une note ou poser une question..." required autocomplete="off">
                <button class="btn btn-primary btn-sm px-3" type="submit">
                  <i class="bi bi-send-fill"></i>
                </button>
              </div>
            </form>
          </div>
        <% } else { %>
          <div class="p-2.5 bg-slate-100 border-top text-center text-xs text-muted font-sans">
            <i class="bi bi-lock-fill me-1"></i> Dossier archivé • Discussion fermée
          </div>
        <% } %>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const commentForm = document.getElementById('dossier-comment-form');
        const commentInput = document.getElementById('dossier-comment-input');
        const commentsContainer = document.getElementById('dossier-comments-container');
        const noCommentsIndicator = document.getElementById('no-comments-indicator');

        // Scroll to end of discussion thread
        if (commentsContainer) {
          commentsContainer.scrollTop = commentsContainer.scrollHeight;
        }

        if (commentForm) {
          commentForm.addEventListener('submit', function (e) {
            e.preventDefault();
            const content = commentInput.value.trim();
            if (!content) return;

            commentInput.disabled = true;
            const submitBtn = commentForm.querySelector('button[type="submit"]');
            if (submitBtn) submitBtn.disabled = true;

            fetch('/dossiers/<%= dossier.id %>/comment', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ contenu: content })
            })
            .then(res => res.json())
            .then(data => {
              if (data.ok) {
                commentInput.value = '';
                if (noCommentsIndicator) {
                  noCommentsIndicator.remove();
                }

                const comment = data.comment;
                const initials = (comment.user.nom || "U").substring(0, 2).toUpperCase();
                let avatarBg = "#4b5563";
                if (comment.user.role === "super_admin") avatarBg = "#e11d48";
                else if (["pdg", "dg", "dga"].includes(comment.user.role)) avatarBg = "#7c3aed";
                else if (["validation", "validation_role"].includes(comment.user.role)) avatarBg = "#059669";
                else if (comment.user.role === "guce") avatarBg = "#d97706";

                const dateStr = new Date(comment.created_at).toLocaleDateString('fr-FR', {
                  day: 'numeric',
                  month: 'short',
                  hour: '2-digit',
                  minute: '2-digit'
                });

                const commentEl = document.createElement('div');
                commentEl.className = 'd-flex mb-3 align-items-start text-start dossier-comment-item';
                commentEl.innerHTML = `
                  <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold d-inline-block text-center flex-shrink-0" 
                       style="width: 32px; height: 32px; line-height: 32px; background-color: ${avatarBg}; font-size: 0.75rem;" 
                       title="${comment.user.nom} (${comment.user.role})">
                    ${initials}
                  </div>
                  <div class="ms-2 bg-white p-2.5 rounded shadow-sm border flex-grow-1" style="min-width: 0; margin-left: 10px !important;">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-1 mb-1">
                      <span class="fw-bold text-slate-800" style="font-size: 0.82rem;">${comment.user.nom}</span>
                      <span class="badge bg-slate-100 text-slate-600 border text-xxs font-sans" style="font-size: 0.7rem;">
                        Écrit lors de l'étape : ${comment.stage}
                      </span>
                    </div>
                    <p class="mb-1 text-slate-700 text-sm break-words" style="font-size: 0.85rem; line-height: 1.4; word-wrap: break-word;">${comment.contenu}</p>
                    <div class="text-xxs text-slate-400 font-monospace text-end" style="font-size: 0.7rem;">
                      ${dateStr}
                    </div>
                  </div>
                `;

                commentsContainer.appendChild(commentEl);
                commentsContainer.scrollTop = commentsContainer.scrollHeight;
              } else {
                alert("Erreur: " + (data.error || "Impossible d'ajouter le commentaire."));
              }
            })
            .catch(err => {
              console.error(err);
              alert("Une erreur de communication est survenue.");
            })
            .finally(() => {
              commentInput.disabled = false;
              if (submitBtn) submitBtn.disabled = false;
              commentInput.focus();
            });
          });
        }
      });
    </script>
    
    <!-- 5. DOCUMENTS DU DOSSIER section (All uploaded files visible to everyone) -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white py-3 border-bottom border-light">
        <h5 class="mb-0 fw-bold font-sans text-dark" style="font-size: 0.95rem;">
          <i class="bi bi-folder-fill text-warning me-2"></i>Documents du Dossier
        </h5>
      </div>
      <div class="card-body">
        <p class="text-xs text-muted mb-3 text-start">Retrouvez ci-dessous l'ensemble des documents justificatifs administratifs et de transit triés par catégorie.</p>

        <% if (dossier.etat !== "ARCHIVE" && dossier.pipeline_status !== "ARCHIVE") { %>
          <!-- Collapse/Button trigger for generic upload -->
          <div class="mb-4 text-start">
            <button class="btn btn-outline-primary d-inline-flex align-items-center fw-bold text-xs rounded-pill" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUploadForm" aria-expanded="false" aria-controls="collapseUploadForm">
              <i class="bi bi-plus-circle-fill me-1.5"></i> Joindre un document au dossier
            </button>
            
            <div class="collapse mt-3" id="collapseUploadForm">
              <div class="p-3 border rounded-3 bg-white text-start shadow-sm generic-upload-card">
                <h6 class="fw-bold mb-3 border-bottom pb-2 text-primary" style="font-size: 0.85rem;">
                  <i class="bi bi-file-earmark-arrow-up-fill me-1"></i> Nouveau document justificatif
                </h6>
                
                <form action="/dossiers/<%= dossier.id %>/upload" method="POST" enctype="multipart/form-data" class="row g-3">
                  <!-- File selection -->
                  <div class="col-12">
                    <label class="form-label text-xs fw-semibold text-slate-700 mb-1">Document (PDF, JPG, PNG - Max 20Mo) *</label>
                    <input type="file" name="pdf_file" class="form-control form-control-sm" accept=".pdf,image/*" required>
                  </div>
                  
                  <!-- Category selection -->
                  <div class="col-md-6">
                    <label class="form-label text-xs fw-semibold text-slate-700 mb-1">Catégorie de pièce *</label>
                    <select name="category" class="form-select form-select-sm" required>
                      <option value="ASSURANCE">ASSURANCE</option>
                      <option value="DESC">DESC</option>
                      <option value="RVC">RVC</option>
                      <option value="CAMCIS">CAMCIS</option>
                      <option value="RECU_PORT">REÇUS PORT</option>
                      <option value="FACTURE">FACTURE</option>
                      <option value="AUTRE" selected>AUTRE</option>
                    </select>
                  </div>
                  
                  <!-- Comment field -->
                  <div class="col-md-6">
                    <label class="form-label text-xs fw-semibold text-slate-700 mb-1">Commentaire / Précision (Optionnel)</label>
                    <input type="text" name="comment" class="form-control form-control-sm" placeholder="Ex: Quittance, Facture acquittée, etc...">
                  </div>
                  
                  <!-- Submit button -->
                  <div class="col-12 text-end border-top pt-2.5">
                    <button class="btn btn-secondary btn-xs me-1.5" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUploadForm">Annuler</button>
                    <button class="btn btn-success btn-xs fw-bold" type="submit">
                      <i class="bi bi-cloud-upload me-1"></i> Envoyer le document
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% } %>

        <%
          const categoriesList = [
            { key: "ASSURANCE", label: "ASSURANCE", icon: "bi-shield-check", color: "text-primary" },
            { key: "DESC", label: "DESC", icon: "bi-file-earmark-medical", color: "text-info" },
            { key: "RVC", label: "RVC", icon: "bi-receipt", color: "text-success" },
            { key: "CAMCIS", label: "CAMCIS", icon: "bi-bank", color: "text-purple" },
            { key: "RECU_PORT", label: "REÇUS PORT", icon: "bi-anchor", color: "text-warning" },
            { key: "FACTURE", label: "FACTURE", icon: "bi-file-earmark-ruled", color: "text-danger" },
            { key: "AUTRE", label: "AUTRE", icon: "bi-file-earmark-zip", color: "text-secondary" }
          ];
        %>

        <div class="categories-container text-start">
          <% categoriesList.forEach(cat => { %>
            <% 
              const catFiles = (dossier.files || []).filter(f => f.category === cat.key);
            %>
            <div class="mb-3.5">
              <div class="d-flex align-items-center mb-1.5 pb-1 border-bottom">
                <i class="bi <%= cat.icon %> <%= cat.color %> me-2" style="font-size: 1rem;"></i>
                <span class="fw-bold text-slate-800 text-xs tracking-wider" style="font-size: 0.78rem;"><%= cat.label %></span>
                <span class="badge rounded bg-slate-100 border text-slate-600 ms-1.5 px-2 text-xxs" style="font-size: 0.65rem;"><%= catFiles.length %></span>
              </div>
              
              <% if (catFiles.length > 0) { %>
                <div class="list-group list-group-flush border rounded overflow-hidden shadow-xs mb-2">
                  <% catFiles.forEach(file => { %>
                    <div class="list-group-item list-group-item-action py-2 px-2.5 d-flex align-items-center justify-content-between text-start" style="font-size: 0.82rem;">
                      <div class="text-truncate min-w-0 flex-grow-1 me-2 pb-0.5">
                        <a href="/dossiers/<%= dossier.id %>/download/<%= file.filename %>" class="fw-semibold text-slate-800 d-inline-flex align-items-center text-decoration-none hover:text-success text-truncate max-w-100 font-sans" title="<%= file.original %>">
                          <%
                            const isImage = /\.(jpg|jpeg|png)$/i.test(file.original);
                            const icon = isImage ? 'bi-file-earmark-image text-info' : 'bi-file-earmark-pdf text-danger';
                          %>
                          <i class="bi <%= icon %> me-1.5 flex-shrink-0"></i>
                          <span class="text-truncate"><%= file.original %></span>
                        </a>
                        <% if (file.comment) { %>
                          <span class="d-block text-xs text-slate-600 italic bg-light p-1 rounded border-start border-3 border-primary/35 mt-1 text-truncate max-w-100" style="font-size: 0.73rem;"><%= file.comment %></span>
                        <% } %>
                        <div class="text-slate-500 font-monospace text-xxs mt-1" style="font-size: 0.7rem;">
                          <span class="badge bg-slate-200 text-slate-700 px-1" style="font-size: 0.62rem;">Étape : <%= file.stage %></span> •
                          Déposé par <%= file.user ? file.user.nom : 'Système' %> (<%= file.user ? file.user.role : 'Robot' %>) le <%= new Date(file.created_at).toLocaleDateString('fr-FR', {day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit'}) %>
                        </div>
                      </div>
                      <div class="flex-shrink-0 ms-1">
                        <a href="/dossiers/<%= dossier.id %>/download/<%= file.filename %>" class="btn btn-xs btn-outline-success rounded-circle p-1 d-inline-flex align-items-center justify-content-center" style="width:24px; height:24px" title="Télécharger">
                          <i class="bi bi-download" style="font-size: 0.75rem;"></i>
                        </a>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="text-xs text-muted italic text-center py-2 bg-light/50 rounded border border-dashed text-slate-400 mb-2 font-sans" style="font-size: 0.75rem;">
                  Aucun justificatif enregistré.
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>

        <% if (attachments && attachments.length > 0) { %>
        <div class="border-top pt-3 text-start">
          <button class="btn btn-link py-0 px-0 fw-bold border-0 text-slate-600 text-xs text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAttachmentsOld" aria-expanded="false" aria-controls="collapseAttachmentsOld">
            <i class="bi bi-chevron-down me-1.5"></i> Pièces de bord historiques (Physique) :
          </button>
          
          <div class="collapse show mt-2" id="collapseAttachmentsOld">
            <div class="list-group list-group-flush border rounded overflow-hidden shadow-xs" style="max-height: 200px; overflow-y: auto;">
              <% attachments.forEach(file => { %>
                <div class="list-group-item list-group-item-action py-2 px-2.5 d-flex align-items-center justify-content-between text-start" style="font-size: 0.82rem;">
                  <div class="text-truncate min-w-0 flex-grow-1 me-2 pb-0.5">
                    <% 
                      const baseName = file.name.substring(file.name.indexOf('-') + 1);
                      const cleanLabel = baseName.substring(baseName.indexOf('-') + 1);
                    %>
                    <a href="/dossiers/<%= dossier.id %>/download/<%= file.name %>" class="fw-semibold text-slate-700 hover:text-success text-decoration-none text-truncate d-block" title="<%= cleanLabel %>">
                      <i class="bi bi-file-earmark-zip text-slate-400 me-1.5"></i><%= cleanLabel %>
                    </a>
                    <div class="text-xxs text-slate-400 font-monospace mt-0.5" style="font-size: 0.7rem;">
                      <%= file.size %> • <%= file.uploadedAt %>
                    </div>
                  </div>
                  <div>
                    <a href="/dossiers/<%= dossier.id %>/download/<%= file.name %>" class="btn btn-xs btn-outline-secondary rounded-circle p-1" style="width:24px; height:24px" title="Télécharger">
                      <i class="bi bi-download" style="font-size: 0.75rem;"></i>
                    </a>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
        <% } %>

      </div>
    </div>

    <!-- Section D — Bons de débours (Avances et Régularisations) -->
    <div class="card border-0 shadow-sm mb-4 mt-4">
      <div class="card-header bg-white py-3 border-bottom border-light">
        <h5 class="mb-0 fw-bold font-sans text-dark" style="font-size: 1rem;">
          <i class="bi bi-cash-stack text-success me-2"></i>Section D — Bons de débours (Avances et Régularisations)
        </h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
            <thead class="table-light">
              <tr>
                <th class="ps-4">N° Bon Provisoire</th>
                <th>Demandeur (Service)</th>
                <th>Objet</th>
                <th>Montant Demandé</th>
                <th>Statut</th>
                <th>Approbation (Quand)</th>
                <th>N° Bon Réel (Régularisation)</th>
                <th>Montant Réel</th>
                <th>Écart</th>
                <th class="pe-4">Statut Réel / Confirmateur</th>
              </tr>
            </thead>
            <tbody>
              <% if (dossier.bons_provisoir && dossier.bons_provisoir.length > 0) { %>
                <% dossier.bons_provisoir.forEach(bp => { %>
                  <tr>
                    <td class="ps-4 font-monospace fw-bold text-primary">
                      <%= bp.numero %>
                      <a href="/bons/<%= bp.id %>/pdf" target="_blank" class="ms-1 text-danger" title="Voir PDF"><i class="bi bi-file-earmark-pdf-fill"></i></a>
                    </td>
                    <td>
                      <%= bp.demandeur ? bp.demandeur.prenom + ' ' + bp.demandeur.nom : 'Inconnu' %> 
                      <small class="text-muted d-block" style="font-size: 0.72rem;">(<%= bp.service %>)</small>
                    </td>
                    <td class="text-wrap" style="max-width: 200px;"><%= bp.objet %></td>
                    <td class="font-monospace fw-bold"><%= bp.montant_demande.toLocaleString('fr-FR') %> F</td>
                    <td>
                      <% if (bp.etat === 'APPROUVE') { %>
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Approuvé</span>
                      <% } else if (bp.etat === 'REJETE') { %>
                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">Rejeté</span>
                      <% } else { %>
                        <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill">En attente</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (bp.approver) { %>
                        <small class="fw-semibold"><%= bp.approver.nom %></small>
                        <div class="text-xxs text-muted" style="font-size: 0.65rem;">le <%= bp.approved_at ? new Date(bp.approved_at).toLocaleDateString('fr-FR') : '' %></div>
                      <% } else { %>
                        <span class="text-danger text-xs">Non approuvé/rejeté</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (bp.bon_reel) { %>
                        <span class="font-monospace text-slate-700 fw-semibold">BR-<%= bp.bon_reel.id %></span>
                      <% } else { %>
                        <span class="text-muted text-xs">Non requis/non régularisé</span>
                      <% } %>
                    </td>
                    <td class="font-monospace">
                      <% if (bp.bon_reel) { %>
                        <%= bp.bon_reel.montant_reel.toLocaleString('fr-FR') %> F
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td class="font-monospace">
                      <% if (bp.bon_reel) { %>
                        <% const gap = bp.bon_reel.ecart; %>
                        <% if (gap > 0) { %>
                          <span class="text-success fw-bold">+<%= gap.toLocaleString('fr-FR') %> F</span>
                        <% } else if (gap < 0) { %>
                          <span class="text-danger fw-bold"><%= gap.toLocaleString('fr-FR') %> F</span>
                        <% } else { %>
                          <span class="text-secondary fw-semibold">0 F</span>
                        <% } %>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td class="pe-4">
                      <% if (bp.bon_reel) { %>
                        <% if (bp.bon_reel.confirme_par) { %>
                          <span class="badge bg-success-subtle text-success border border-success-subtle">Confirmé</span>
                          <div class="text-xxs text-muted" style="font-size: 0.65rem;">Par <%= bp.bon_reel.confirme_par.nom %> le <%= new Date(bp.bon_reel.confirme_at).toLocaleDateString('fr-FR') %></div>
                        <% } else { %>
                          <span class="badge bg-warning-subtle text-warning border border-warning-subtle">À confirmer</span>
                          <div class="text-xxs text-muted" style="font-size: 0.65rem;">Soumis par <%= bp.bon_reel.soumis_par.nom %></div>
                        <% } %>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="10" class="text-center text-muted py-4">
                    <i class="bi bi-wallet2 display-6 text-slate-300 d-block mb-2"></i>
                    Aucun Bon de débour enregistré pour ce dossier.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Section A — "Chronologie" (activity timeline) -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white py-3 border-bottom border-light">
        <h5 class="mb-0 fw-bold font-sans text-dark" style="font-size: 1rem;">
          <i class="bi bi-clock-history text-secondary me-2"></i>Section A — Chronologie d'Activité de Transit
        </h5>
      </div>
      <div class="card-body">
        <% if (logs && logs.length > 0) { %>
          <div class="timeline-container px-2" style="max-height: 550px; overflow-y: auto;">
            <% logs.forEach((log, index) => { %>
              <% 
                // Dynamically select beautiful custom class tags and iconography representing transit activities
                let icon = "bi-dot";
                let badgeClass = "bg-light text-slate-800 border";
                let actionLabel = log.action;
                
                switch (log.action) {
                  case "CREATION_DOSSIER":
                  case "OUVERTURE_DOSSIER":
                    icon = "bi-folder-plus text-primary";
                    badgeClass = "bg-primary-subtle text-primary border-primary-subtle fw-bold";
                    actionLabel = "Ouverture de Dossier";
                    break;
                  case "DOSSIER_SOUMIS_GUCE":
                    icon = "bi-send-fill text-info";
                    badgeClass = "bg-info-subtle text-info border-info-subtle fw-bold";
                    actionLabel = "Soumission GUCE";
                    break;
                  case "DOSSIER_VALIDE_GUCE":
                    icon = "bi-patch-check-fill text-success";
                    badgeClass = "bg-success-subtle text-success border-success-subtle fw-bold";
                    actionLabel = "Validation Douanes GUCE";
                    break;
                  case "DOSSIER_SOUMIS_VALIDATION":
                    icon = "bi-shield-fill-exclamation text-warning";
                    badgeClass = "bg-warning-subtle text-warning-emphasis border-warning-subtle fw-bold";
                    actionLabel = "Soumission pour Validation";
                    break;
                  case "DOSSIER_VALIDATION_APPROUVEE":
                    icon = "bi-shield-fill-check text-success";
                    badgeClass = "bg-success-subtle text-success border-success-subtle fw-bold";
                    actionLabel = "Dossier Approuvé pour Transit";
                    break;
                  case "DOSSIER_VALIDATION_REJETEE":
                    icon = "bi-shield-fill-x text-danger";
                    badgeClass = "bg-danger-subtle text-danger border-danger-subtle fw-bold";
                    actionLabel = "Validation Rejetée";
                    break;
                  case "BON_PROVISOIR_CREE":
                    icon = "bi-file-earmark-plus-fill text-warning";
                    badgeClass = "bg-warning-subtle text-warning border-warning-subtle fw-bold";
                    actionLabel = "Demande Bon Provisoire";
                    break;
                  case "BON_PROVISOIR_APPROUVE":
                    icon = "bi-check-circle-fill text-success";
                    badgeClass = "bg-success-subtle text-success border-success-subtle fw-bold";
                    actionLabel = "Bon Provisoire Approuvé";
                    break;
                  case "BON_PROVISOIR_REJETE":
                    icon = "bi-x-circle-fill text-danger";
                    badgeClass = "bg-danger-subtle text-danger border-danger-subtle fw-bold";
                    actionLabel = "Bon Provisoire Rejeté";
                    break;
                  case "BON_REEL_SOUMIS":
                    icon = "bi-cash-coin text-purple";
                    badgeClass = "bg-purple-subtle text-purple border-purple-subtle fw-bold";
                    actionLabel = "Régularisation Soumise (Bon Réel)";
                    break;
                  case "FONDS_DECAISSES":
                    icon = "bi-cash text-success";
                    badgeClass = "bg-success-subtle text-success border-success-subtle fw-bold";
                    actionLabel = "Fonds Réels Décaisés";
                    break;
                  case "fichier.uploaded":
                    icon = "bi-paperclip text-info";
                    badgeClass = "bg-info-subtle text-info border-info-subtle fw-bold";
                    actionLabel = "Pièce Justificative Ajoutée";
                    break;
                  case "comment.added":
                    icon = "bi-chat-dots-fill text-purple";
                    badgeClass = "bg-secondary-subtle text-secondary-emphasis border-secondary-subtle fw-bold";
                    actionLabel = "Commentaire Discussion";
                    break;
                  case "tache.status":
                    icon = "bi-bookmark-check-fill text-success";
                    badgeClass = "bg-success-subtle text-success border-success-subtle fw-bold";
                    actionLabel = "Jalon Logistique Validé";
                    break;
                  case "DOSSIER_CLOTURE_ARCHIVE":
                    icon = "bi-archive-fill text-danger";
                    badgeClass = "bg-danger text-white border-danger fw-bold";
                    actionLabel = "Dossier Clôturé & Archivé";
                    break;
                }
              %>
              <div class="d-flex mb-3.5 text-start position-relative">
                <!-- Timeline Dot Line divider -->
                <% if (index < logs.length - 1) { %>
                  <div class="position-absolute" style="left: 13.5px; top: 28px; bottom: -20px; width: 2px; background-color: #e2e8f0;"></div>
                <% } %>
                <div class="rounded-circle d-flex align-items-center justify-content-center border" style="width: 28px; height: 28px; background-color: #f8fafc; z-index: 10;">
                  <i class="bi <%= icon %>" style="font-size: 0.9rem;"></i>
                </div>
                <div class="ms-3 flex-grow-1">
                  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="badge <%= badgeClass %>" style="font-size: 0.72rem;"><%= actionLabel %></span>
                    <span class="text-slate-500 font-monospace text-xs">
                      <%= new Date(log.created_at).toLocaleDateString('fr-FR', {day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit'}) %>
                    </span>
                  </div>
                  
                  <!-- Formatter for user role and specifics details -->
                  <p class="mb-0 text-slate-700 small mt-1.5" style="font-size: 0.85rem;">
                    Exécuté par <strong class="text-slate-900"><%= log.user ? log.user.nom : 'Système' %></strong>
                    <span class="badge bg-light text-slate-600 border px-1.5 py-0.5 font-sans ms-1" style="font-size: 0.65rem; font-weight: normal;"><%= log.user ? log.user.role.toUpperCase() : 'ROBOT' %></span>
                  </p>
                  
                  <% if (log.meta) { %>
                    <% 
                      let metaObj = {};
                      try {
                        metaObj = JSON.parse(log.meta);
                      } catch (err) {}
                    %>
                    <div class="bg-light p-2 rounded mt-2 text-xxs text-slate-600 border border-light-subtle" style="font-size: 0.75rem; word-break: break-all;">
                      <% if (metaObj.filename) { %>
                        <i class="bi bi-file-earmark-arrow-down me-1"></i> Fichier : <strong><%= metaObj.filename %></strong>
                      <% } else if (metaObj.task_titre) { %>
                        <i class="bi bi-bookmark-fill me-1"></i> Étape : <strong><%= metaObj.task_titre %></strong> — <%= metaObj.preview || '' %>
                      <% } else if (metaObj.titre) { %>
                        <i class="bi bi-activity me-1"></i> Action : <%= metaObj.titre %> 
                        <% if (metaObj.from && metaObj.to) { %>
                          (<%= metaObj.from %> → <%= metaObj.to %>)
                        <% } %>
                      <% } else { %>
                        <%= log.meta %>
                      <% } %>
                    </div>
                  <% } else if (log.entity_id) { %>
                    <span class="text-slate-400 text-xxs block mt-0.5" style="font-size: 0.68rem;">ID Référence: <%= log.entity %> (<%= log.entity_id %>)</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-clock-history text-slate-300 display-4 d-block mb-3"></i>
            Aucun historique d'activité d'exploitation ou financier n'a encore été enregistré sur ce dossier.
          </div>
        <% } %>
      </div>
    </div>

<!-- Modal Quick Task -->
<div class="modal fade" id="quickTaskModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-slate-900 text-white">
        <h5 class="modal-title fw-bold text-white fs-6">Saisir un Jalon d'expédition rapide</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/dossiers/<%= dossier.id %>/taches/new" method="POST">
        <div class="modal-body text-start">
          <div class="mb-3">
            <label class="form-label small fw-semibold">Intitulé du jalon <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="titre" placeholder="Ex: Livraison d'acconage à l'entrepôt" required>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Assigner un agent transit :</label>
            <select class="form-select" name="intervenant_id">
              <option value="">-- Non assigné --</option>
              <% if (users && users.length > 0) { %>
                <% users.forEach(u => { %>
                  <option value="<%= u.id %>"><%= u.nom %> (<%= u.role %>)</option>
                <% }) %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Échéances / Date limite :</label>
            <input type="date" class="form-control" name="deadline" value="2026-06-15" required>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Observations initiales / BL :</label>
            <textarea class="form-control" name="observations" rows="3" placeholder="Saisir informations importantes..."></textarea>
          </div>
        </div>
        <div class="modal-footer bg-light">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
          <button type="submit" class="btn btn-primary btn-sm">Enregistrer le jalon</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Edit Custom Specifications and Client -->
<div class="modal fade" id="editCustomFieldsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow text-start">
      <div class="modal-header bg-slate-900 text-white">
        <h5 class="modal-title fw-bold text-white fs-6">Ajuster les Spécifications Logistiques & Douane</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/dossiers/<%= dossier.id %>/update-custom" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label small fw-semibold text-slate-700">Client / Donneur d'ordre <span class="text-danger">*</span></label>
            <select class="form-select" name="client_id" required>
              <% if (clients && clients.length > 0) { %>
                <% clients.forEach(cl => { %>
                  <option value="<%= cl.id %>" <%= cl.id === dossier.client_id ? 'selected' : '' %>><%= cl.nom %></option>
                <% }) %>
              <% } %>
            </select>
            <div class="form-text" style="font-size: 0.72rem;">Vous pouvez modifier l'association du client si nécessaire.</div>
          </div>

          <div class="mb-3">
            <label class="form-label small fw-semibold text-slate-700">Numéro de BL / Connaissement <span class="text-danger">*</span></label>
            <input type="text" class="form-control font-monospace" name="bl" value="<%= dossier.bl || '' %>" placeholder="Ex: MSCU1234567" required>
          </div>

          <div class="mb-3">
            <label class="form-label small fw-semibold text-slate-700">Marchandises du conteneur (Contenu)</label>
            <input type="text" class="form-control" name="contenu" value="<%= dossier.contenu || '' %>" placeholder="Ex: 120 cartons de matériel informatique">
          </div>

          <div class="mb-3">
            <label class="form-label small fw-semibold text-slate-700">Valeur en Douane estimée (FCFA)</label>
            <input type="number" step="any" min="0" class="form-control" name="valeur_douane" value="<%= dossier.valeur_douane || '' %>" placeholder="Ex: 15000000">
          </div>

          <div class="mb-3">
            <label class="form-label small fw-semibold text-slate-700">Montant des droits de douane (FCFA)</label>
            <input type="number" step="any" min="0" class="form-control" name="droits_douane" value="<%= dossier.droits_douane || '' %>" placeholder="Ex: 3500000">
          </div>

          <div class="mb-3 mt-4">
            <div class="form-check form-switch p-1 d-flex align-items-center gap-2">
              <input class="form-check-input ms-0" type="checkbox" id="modal_validation" name="validation" style="width: 2.2rem; height: 1.1rem; cursor: pointer;" <%= dossier.validation ? 'checked' : '' %>>
              <label class="form-check-label small fw-bold text-slate-800 cursor-pointer" for="modal_validation">
                <i class="bi bi-shield-fill-check text-success"></i> Déclarer validé par l'administration des douanes
              </label>
            </div>
          </div>
        </div>
        <div class="modal-footer bg-light">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
          <button type="submit" class="btn btn-primary btn-sm">Enregistrer les modifications</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Ajax script for checklist toggling -->
<script>
document.addEventListener("DOMContentLoaded", function() {
  const checkboxes = document.querySelectorAll(".task-toggle-checkbox");
  
  checkboxes.forEach(function(box) {
    box.addEventListener("change", function() {
      const taskId = this.getAttribute("data-task-id");
      const isChecked = this.checked;
      
      // Determine new status payload
      const statusValue = isChecked ? "FAIT" : "EN_COURS";
      
      // Instant PATCH to server
      fetch(`/taches/${taskId}/status`, {
        method: "PATCH",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ etat: statusValue })
      })
      .then(response => {
        if (!response.ok) {
          throw new Error("Erreur lors de la mise à jour");
        }
        return response.json();
      })
      .then(data => {
        if (data.success) {
          // 1. Update status badge & text-decoration
          const statusBadge = document.getElementById(`status-badge-${taskId}`);
          const labelText = document.getElementById(`label-text-${taskId}`);
          const rowItem = document.getElementById(`task-row-${taskId}`);
          
          if (isChecked) {
            statusBadge.textContent = "VALIDÉ";
            statusBadge.className = "badge rounded-pill px-2.5 py-1 text-xs font-monospace fw-bold bg-success text-white";
            labelText.classList.add("text-decoration-line-through", "text-slate-500");
            rowItem.style.backgroundColor = "#fbfdfb";
            rowItem.style.opacity = "0.9";
          } else {
            statusBadge.textContent = "EN COURS";
            statusBadge.className = "badge rounded-pill px-2.5 py-1 text-xs font-monospace fw-bold bg-warning text-dark";
            labelText.classList.remove("text-decoration-line-through", "text-slate-500");
            rowItem.style.backgroundColor = "";
            rowItem.style.opacity = "";
          }
          
          // 2. Recalculate global progress percentage on client side instantly!
          recalculateProgressBar();
        } else {
          // Revert checkbox state if failed
          this.checked = !isChecked;
          alert("Impossible de modifier le statut : " + (data.message || "Erreur système"));
        }
      })
      .catch(error => {
        this.checked = !isChecked;
        console.error("Erreur toggle checkbox :", error);
        alert("Une erreur de réseau s'est produite lors de l'enregistrement instantané.");
      });
    });
  });

  function recalculateProgressBar() {
    const allBoxes = document.querySelectorAll(".task-toggle-checkbox");
    const totalCount = allBoxes.length;
    
    if (totalCount === 0) return;
    
    let checkedCount = 0;
    allBoxes.forEach(b => {
      if (b.checked) checkedCount++;
    });
    
    const pct = Math.round((checkedCount / totalCount) * 100);
    
    // Update DOM indicators
    const progressBar = document.getElementById("dossier-progress-bar");
    const progressLabel = document.getElementById("progress-percent-label");
    const doneSummary = document.getElementById("progress-done-summary");
    
    if (progressBar) {
      progressBar.style.width = pct + "%";
      progressBar.setAttribute("aria-valuenow", pct);
    }
    if (progressLabel) {
      progressLabel.textContent = pct + "%";
    }
    if (doneSummary) {
      doneSummary.textContent = checkedCount + " sur " + totalCount + " jalons de dédouanement validés";
    }
  }
});
</script>

