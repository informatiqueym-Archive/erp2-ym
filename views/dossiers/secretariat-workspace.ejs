<%- include('../partials/header') %>

<div class="row mb-4">
  <div class="col-12 py-2 text-start">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2" style="font-size: 0.85rem;">
        <li class="breadcrumb-item"><a href="/dashboard">Tableau de bord</a></li>
        <li class="breadcrumb-item active" aria-current="page">Espace Secrétariat</li>
      </ol>
    </nav>
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h1 class="h3 mb-1 text-slate-800 font-sans fw-bold">
          Espace Secrétariat — Bonjour <%= user.nom %>
        </h1>
        <p class="text-muted mb-0">Gérez vos dossiers de transit étape par étape</p>
      </div>
    </div>
  </div>
</div>

<!-- Three Control Panel Cards -->
<div class="row g-4 mb-5 text-start">
  <!-- CARD 1 — CRÉATION CLIENT -->
  <div class="col-md-4">
    <div class="card h-100 border-0 shadow-sm transition-hover" style="border-top: 4px solid #1D4ED8 !important; background-color: #EFF6FF;">
      <div class="card-body d-flex flex-column justify-content-between p-4">
        <div>
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title fw-bold font-sans mb-0" style="color: #1D4ED8;">Création Client</h5>
            <i class="bi bi-person-plus-fill" style="font-size: 1.8rem; color: #1D4ED8;"></i>
          </div>
          <p class="card-text text-slate-700" style="font-size: 0.95rem;">
            Enregistrer un nouveau client avec ses documents d'identité
          </p>
        </div>
        <div class="mt-4">
          <div class="text-slate-500 small mb-3 fw-semibold">
            <i class="bi bi-people me-1"></i><%= totalClients %> clients enregistrés
          </div>
          <a href="/clients/create" class="btn w-full fw-bold text-white shadow-sm d-flex align-items-center justify-content-center gap-2" style="background-color: #1D4ED8; border-radius: 8px; padding: 10px 16px;">
            <i class="bi bi-person-plus"></i> Nouveau Client
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- CARD 2 — CRÉATION DOC -->
  <div class="col-md-4">
    <div class="card h-100 border-0 shadow-sm transition-hover" style="border-top: 4px solid #065F46 !important; background-color: #ECFDF5;">
      <div class="card-body d-flex flex-column justify-content-between p-4">
        <div>
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title fw-bold font-sans mb-0" style="color: #065F46;">Création Dossier</h5>
            <i class="bi bi-folder-plus" style="font-size: 1.8rem; color: #065F46;"></i>
          </div>
          <p class="card-text text-slate-700" style="font-size: 0.95rem;">
            Ouvrir un nouveau dossier de transit douanier
          </p>
        </div>
        <div class="mt-4">
          <div class="text-slate-500 small mb-3 fw-semibold">
            <i class="bi bi-calendar-check me-1"></i><%= monthDossiersCount %> dossiers ce mois
          </div>
          <a href="/dossiers/create" class="btn w-full fw-bold text-white shadow-sm d-flex align-items-center justify-content-center gap-2" style="background-color: #065F46; border-radius: 8px; padding: 10px 16px;">
            <i class="bi bi-folder-plus"></i> Créer un Dossier
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- CARD 3 — LISTE DOC -->
  <div class="col-md-4">
    <div class="card h-100 border-0 shadow-sm transition-hover" style="border-top: 4px solid #7C2D12 !important; background-color: #FFF7ED;">
      <div class="card-body d-flex flex-column justify-content-between p-4">
        <div>
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title fw-bold font-sans mb-0" style="color: #7C2D12;">Liste des Dossiers</h5>
            <i class="bi bi-list-ul" style="font-size: 1.8rem; color: #7C2D12;"></i>
          </div>
          <p class="card-text text-slate-700" style="font-size: 0.95rem;">
            Consulter, éditer et modifier vos dossiers
          </p>
        </div>
        <div class="mt-4">
          <div class="text-slate-500 small mb-3 fw-semibold">
            <i class="bi bi-clock-history me-1"></i><%= dossiersCreeCount %> dossiers en cours
          </div>
          <a href="/dossiers/liste" class="btn w-full fw-bold text-white shadow-sm d-flex align-items-center justify-content-center gap-2" style="background-color: #7C2D12; border-radius: 8px; padding: 10px 16px;">
            <i class="bi bi-eye"></i> Voir mes dossiers
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Mes Dossiers Récents Table -->
<div class="card border-0 shadow-sm text-start mb-5">
  <div class="card-header bg-white border-0 py-3 d-flex align-items-center justify-content-between">
    <h5 class="mb-0 fw-bold text-slate-800 font-sans">
      <i class="bi bi-clock text-secondary me-2"></i>Mes dossiers récents
    </h5>
    <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded-pill" style="font-size: 0.75rem;">Les 5 derniers créés</span>
  </div>
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead style="background-color: #1E3A5F; color: #ffffff;">
        <tr>
          <th class="ps-4 py-3 border-0 text-white" style="font-size: 0.85rem; font-weight: 600;">N° DOSSIER</th>
          <th class="py-3 border-0 text-white" style="font-size: 0.85rem; font-weight: 600;">CLIENT</th>
          <th class="py-3 border-0 text-white text-center" style="font-size: 0.85rem; font-weight: 600;">STATUT PIPELINE</th>
          <th class="py-3 border-0 text-white" style="font-size: 0.85rem; font-weight: 600;">DATE CRÉATION</th>
          <th class="pe-4 py-3 border-0 text-end text-white" style="font-size: 0.85rem; font-weight: 600;">ACTIONS</th>
        </tr>
      </thead>
      <tbody>
        <% if (recentDossiers && recentDossiers.length > 0) { %>
          <% recentDossiers.forEach((ds, index) => { %>
            <tr style="background-color: <%= index % 2 === 0 ? '#ffffff' : '#F8FAFC' %>;">
              <td class="ps-4 py-3 fw-bold text-slate-800 font-monospace">
                <%= ds.numero %>
              </td>
              <td class="py-3 text-slate-700">
                <%= ds.client ? ds.client.nom : 'Inconnu' %>
                <% if (ds.representant_obj) { %>
                  <div class="text-xs mt-1" style="color: #4f46e5;"><i class="bi bi-person-badge"></i> <%= ds.representant_obj.nom %> <%= ds.representant_obj.prenom || "" %></div>
                <% } else if (ds.representant_libre) { %>
                  <div class="text-xs mt-1" style="color: #4f46e5;"><i class="bi bi-person-badge"></i> <%= ds.representant_libre %></div>
                <% } %>
              </td>
              <td class="py-3 text-center">
                <% if (ds.pipeline_status === 'CREE') { %>
                  <span class="badge" style="background-color: #DBEAFE; color: #1E3A8A; font-weight: 600; font-size: 0.78rem; padding: 0.35em 0.65em;">CREE</span>
                <% } else if (ds.pipeline_status === 'GUCE') { %>
                  <span class="badge" style="background-color: #FEF3C7; color: #92400E; font-weight: 600; font-size: 0.78rem; padding: 0.35em 0.65em;">GUCE</span>
                <% } else if (ds.pipeline_status === 'VALIDATION') { %>
                  <span class="badge" style="background-color: #E0E7FF; color: #3730A3; font-weight: 600; font-size: 0.78rem; padding: 0.35em 0.65em;">VALIDATION</span>
                <% } else if (ds.pipeline_status === 'EN_TRAITEMENT') { %>
                  <span class="badge" style="background-color: #DCFCE7; color: #166534; font-weight: 600; font-size: 0.78rem; padding: 0.35em 0.65em;">EN_TRAITEMENT</span>
                <% } else if (ds.pipeline_status === 'ARCHIVE') { %>
                  <span class="badge" style="background-color: #F3F4F6; color: #6B7280; font-weight: 600; font-size: 0.78rem; padding: 0.35em 0.65em;">ARCHIVE</span>
                <% } else { %>
                  <span class="badge bg-secondary"><%= ds.pipeline_status %></span>
                <% } %>
              </td>
              <td class="py-3 text-slate-500" style="font-size: 0.88rem;">
                <%= new Date(ds.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
              </td>
              <td class="pe-4 py-3 text-end">
                <div class="d-inline-flex gap-2">
                  <a href="/dossiers/<%= ds.id %>/print" target="_blank" class="btn btn-xs btn-outline-info d-inline-flex align-items-center gap-1 py-1 px-2.5 rounded-pill" style="font-size: 0.75rem;" title="Éditer la fiche d'impression">
                    <i class="bi bi-printer"></i> Éditer
                  </a>
                  <% if (ds.pipeline_status === 'CREE') { %>
                    <a href="/dossiers/<%= ds.id %>/edit" class="btn btn-xs btn-outline-primary d-inline-flex align-items-center gap-1 py-1 px-2.5 rounded-pill" style="font-size: 0.75rem;" title="Modifier le dossier">
                      <i class="bi bi-pencil"></i> Modifier
                    </a>
                  <% } else { %>
                    <button class="btn btn-xs btn-outline-secondary d-inline-flex align-items-center gap-1 py-1 px-2.5 rounded-pill opacity-50" style="font-size: 0.75rem;" disabled title="Modification impossible (dossier soumis)">
                      <i class="bi bi-lock"></i> Modifier
                    </button>
                  <% } %>
                  <a href="/dossiers/<%= ds.id %>" class="btn btn-outline-secondary btn-sm rounded-circle p-1" title="Voir les détails">
                    <i class="bi bi-eye"></i>
                  </a>
                </div>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="5" class="py-5 text-center text-muted">
              <i class="bi bi-folder2-open d-block mb-2" style="font-size: 2rem;"></i>
              Aucun dossier récent n'a été créé pour le moment.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<style>
.transition-hover {
  transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}
.transition-hover:hover {
  transform: translateY(-3px);
  box-shadow: 0 .5rem 1rem rgba(0,0,0,.08)!important;
}
.btn-xs {
  padding: .2rem .4rem;
  font-size: .75rem;
  border-radius: .2rem;
}
</style>

<%- include('../partials/footer') %>
