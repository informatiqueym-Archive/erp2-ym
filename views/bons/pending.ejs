<%- include('../partials/header') %>

<div class="mb-4 d-flex justify-content-between align-items-center">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/dashboard">Accueil</a></li>
        <li class="breadcrumb-item active" aria-current="page">Bons provisoires en attente</li>
      </ol>
    </nav>
    <h1 class="h2 font-display text-slate-800">Validation des Bons Provisoires</h1>
    <p class="text-muted">Consultez, approuvez ou rejetez les demandes de décaissement de caisse soumises par les opérationnels.</p>
  </div>
</div>

<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
  <div class="card-header bg-white border-bottom py-3">
    <h5 class="mb-0 text-slate-700 fw-bold"><i class="bi bi-hourglass-split me-2 text-warning"></i>Demandes en attente d'approbation</h5>
  </div>
  
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light text-slate-600 font-sans uppercase text-xs tracking-wider">
        <tr>
          <th class="ps-4 py-3">N° Bon</th>
          <th class="py-3">Dossier</th>
          <th class="py-3">Service / Rôle</th>
          <th class="py-3">Demandeur</th>
          <th class="py-3">Objet du décaissement</th>
          <th class="py-3 text-end">Montant demandé</th>
          <th class="py-3">Date de demande</th>
          <th class="pe-4 py-3 text-end" style="width: 250px;">Actions</th>
        </tr>
      </thead>
      <tbody class="border-top-0 text-slate-700">
        <% if (bons.length === 0) { %>
          <tr>
            <td colspan="8" class="text-center py-5 text-muted">
              <i class="bi bi-check-circle display-4 d-block mb-3 text-success"></i>
              Aucun bon provisoire en attente d'approbation pour le moment.
            </td>
          </tr>
        <% } else { %>
          <% bons.forEach(bon => { %>
            <tr>
              <td class="ps-4 py-3 fw-bold text-primary">
                <%= bon.numero %>
              </td>
              <td class="py-3 fw-semibold">
                <a href="/dossiers/<%= bon.dossier.id %>"><%= bon.dossier.numero %></a>
              </td>
              <td class="py-3">
                <span class="badge bg-secondary-subtle text-secondary small uppercase"><%= bon.service %></span>
              </td>
              <td class="py-3">
                <%= bon.demandeur.prenom || '' %> <%= bon.demandeur.nom %>
              </td>
              <td class="py-3">
                <%= bon.objet %>
              </td>
              <td class="py-3 text-end fw-extrabold text-slate-800">
                <%= bon.montant_demande.toLocaleString('fr-FR') %> F
              </td>
              <td class="py-3 small text-muted">
                <%= new Date(bon.created_at).toLocaleString('fr-FR') %>
              </td>
              <td class="pe-4 py-3 text-end">
                <div class="d-flex justify-content-end gap-2">
                  <button onclick="approveBon(<%= bon.id %>)" class="btn btn-success btn-sm rounded-pill px-3">
                    <i class="bi bi-check-lg me-1"></i> Approuver
                  </button>
                  <button onclick="showRejectModal(<%= bon.id %>, '<%= bon.numero %>')" class="btn btn-danger btn-sm rounded-pill px-3">
                    <i class="bi bi-x-lg me-1"></i> Rejeter
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal Reject -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-danger text-white py-3">
        <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Rejeter le Bon <span id="rejectBonNum"></span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <div class="mb-3">
          <label class="form-label fw-bold">Motif du rejet <span class="text-danger">*</span></label>
          <textarea id="motifRejetInput" class="form-control" rows="3" placeholder="Saisissez la raison précise du rejet du bon..." required></textarea>
        </div>
      </div>
      <div class="modal-footer p-3 bg-light border-top-0">
        <button type="button" class="btn btn-secondary rounded-pill px-3" data-bs-dismiss="modal">Annuler</button>
        <button type="button" id="confirmRejectBtn" class="btn btn-danger rounded-pill px-4">Soumettre le rejet</button>
      </div>
    </div>
  </div>
</div>

<script>
  let activeRejectId = null;

  async function approveBon(id) {
    if(!confirm("Êtes-vous sûr de vouloir approuver ce bon provisoire ? Cela autorisera le décaissement de caisse.")) return;
    try {
      const res = await fetch(`/bons/provisoir/${id}/approuver`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" }
      });
      const data = await res.json();
      if(data.ok) {
        alert(data.message);
        window.location.reload();
      } else {
        alert("Erreur: " + data.message);
      }
    } catch (e) {
      console.error(e);
      alert("Une erreur de communication est survenue.");
    }
  }

  function showRejectModal(id, numero) {
    activeRejectId = id;
    document.getElementById("rejectBonNum").innerText = numero;
    document.getElementById("motifRejetInput").value = "";
    const modal = new bootstrap.Modal(document.getElementById("rejectModal"));
    modal.show();
  }

  document.getElementById("confirmRejectBtn").addEventListener("click", async () => {
    const motif = document.getElementById("motifRejetInput").value;
    if(!motif || motif.trim() === "") {
      alert("Le motif de rejet est obligatoire.");
      return;
    }
    try {
      const res = await fetch(`/bons/provisoir/${activeRejectId}/rejeter`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ motif_rejet: motif })
      });
      const data = await res.json();
      if(data.ok) {
        alert(data.message);
        window.location.reload();
      } else {
        alert("Erreur: " + data.message);
      }
    } catch (e) {
      console.error(e);
      alert("Une erreur est survenue.");
    }
  });
</script>

<%- include('../partials/footer') %>
