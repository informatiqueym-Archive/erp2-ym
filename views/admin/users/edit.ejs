<%- include('../../partials/header') %>

<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/dashboard">Accueil</a></li>
      <li class="breadcrumb-item"><a href="/admin/users">Utilisateurs</a></li>
      <li class="breadcrumb-item active" aria-current="page">Modifier <%= targetUser.nom %></li>
    </ol>
  </nav>
  <h1 class="h2 font-display text-slate-800">Modifier l'utilisateur</h1>
  <p class="text-muted">Éditez les habilitations ou suspendez temporairement l'accès de ce compte de l'ERP YM-TRANSIT.</p>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm rounded-3">
      <form action="/admin/users/edit/<%= targetUser.id %>" method="POST" class="card-body p-4">
        <h5 class="card-title text-slate-800 fw-bold border-bottom pb-2 mb-4"><i class="bi bi-pencil-square me-2"></i>Détails du compte #<%= targetUser.id %></h5>
        
        <div class="row mb-3">
          <div class="col-md-6 mb-3 mb-md-0">
            <label class="form-label fw-semibold">Nom de famille <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-person"></i></span>
              <input type="text" name="nom" class="form-control" value="<%= targetUser.nom %>" required>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Prénom</label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-person"></i></span>
              <input type="text" name="prenom" class="form-control" value="<%= targetUser.prenom || '' %>">
            </div>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-6 mb-3 mb-md-0">
            <label class="form-label fw-semibold">Adresse Email <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-envelope"></i></span>
              <input type="email" name="email" class="form-control" value="<%= targetUser.email %>" required>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Société / Entité <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-building"></i></span>
              <input type="text" name="societe" class="form-control" value="<%= targetUser.societe %>" required>
            </div>
          </div>
        </div>

        <div class="row mb-4">
          <div class="col-md-6 mb-3 mb-md-0">
            <label class="form-label fw-semibold">Niveau d'accès / Rôle ERP <span class="text-danger">*</span></label>
            <div class="input-group mb-2">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-shield-lock"></i></span>
              <select id="role-select" name="role" class="form-select" required>
                <option value="operationnel" <%= targetUser.role === 'operationnel' ? 'selected' : '' %>>Operational - Tâches, Tiers & Dossiers uniquement (operationnel)</option>
                <option value="commercial" <%= targetUser.role === 'commercial' ? 'selected' : '' %>>Commercial - Ventes, Facturation client & Analytics (commercial)</option>
                <option value="comptable" <%= targetUser.role === 'comptable' ? 'selected' : '' %>>Comptable - Grand Livre, Balance & Fournisseurs (comptable)</option>
                <option value="magasinier" <%= targetUser.role === 'magasinier' ? 'selected' : '' %>>Magasinier - Stocks & Achats (magasinier)</option>
                <option value="rh" <%= targetUser.role === 'rh' ? 'selected' : '' %>>Ressources Humaines (RH) (rh)</option>
                <option value="super_admin" <%= targetUser.role === 'super_admin' ? 'selected' : '' %>>Super Administrateur - Tout accès + Gestion Comptes (super_admin)</option>
                <option value="lecture" <%= targetUser.role === 'lecture' ? 'selected' : '' %>>Lecture seule (Auditeur) - Aucun droit de modification (lecture)</option>
                
                <option value="secretariat" <%= targetUser.role === 'secretariat' ? 'selected' : '' %>>Secrétariat — Suivi & Tiers (secretariat)</option>
                <option value="validation_role" <%= targetUser.role === 'validation_role' ? 'selected' : '' %>>Validation — Dossiers (validation_role)</option>
                <option value="guce" <%= targetUser.role === 'guce' ? 'selected' : '' %>>GUCE — Guichet Unique (guce)</option>
                <option value="acconage" <%= targetUser.role === 'acconage' ? 'selected' : '' %>>Acconage — Opérations & Bons (acconage)</option>
                <option value="enlevement" <%= targetUser.role === 'enlevement' ? 'selected' : '' %>>Enlèvement — Livraison & Bons (enlevement)</option>
                <option value="direction" <%= targetUser.role === 'direction' ? 'selected' : '' %>>Direction — Décisions & Budgets (direction)</option>
                <option value="agent_payeur" <%= targetUser.role === 'agent_payeur' ? 'selected' : '' %>>Agent Payeur — Trésorerie & Décaissements (agent_payeur)</option>
                <option value="finances" <%= targetUser.role === 'finances' ? 'selected' : '' %>>Finances — Devis, Dossiers & Tiers (finances)</option>
                <option value="comptable_ops" <%= targetUser.role === 'comptable_ops' ? 'selected' : '' %>>Comptabilité d'Opérations — Comptes & Budgets (comptable_ops)</option>
              </select>
            </div>
            <!-- Warning Alert Box for role changes -->
            <div id="role-change-warning" class="alert alert-warning mb-2 py-2 px-3 small d-none">
              <i class="bi bi-exclamation-triangle-fill me-1"></i>
              Attention : changer le rôle modifiera les accès de cet utilisateur dès sa prochaine connexion.
            </div>
            <!-- Live module preview container -->
            <div id="live-module-preview" class="border rounded p-2 bg-light small text-muted">
              <strong>Modules autorisés :</strong> <span id="live-module-list">...</span>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">État d'activité</label>
            <div class="d-flex gap-3 align-items-center mt-2">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="actif" id="rActifTrue" value="true" <%= targetUser.actif ? 'checked' : '' %>>
                <label class="form-check-input-label fw-medium text-success" for="rActifTrue">
                  <i class="bi bi-check-circle-fill me-1"></i>Compte Actif
                </label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="actif" id="rActifFalse" value="false" <%= !targetUser.actif ? 'checked' : '' %>>
                <label class="form-check-input-label fw-medium text-danger" for="rActifFalse">
                  <i class="bi bi-slash-circle-fill me-1"></i>Suspendre le Compte
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="mb-4">
          <div class="form-check form-switch bg-light p-3 rounded-3 border">
            <input class="form-check-input ms-0 me-2" type="checkbox" name="force_pwd_change" id="chkForce" value="true" <%= targetUser.force_pwd_change ? 'checked' : '' %>>
            <label class="form-check-label fw-bold text-slate-800" for="chkForce">
              <i class="bi bi-shield-exclamation text-warning me-1"></i> Forcer le renouvellement de mot de passe
            </label>
            <div class="form-text text-muted ms-4">Si sélectionné, l'utilisateur sera invité à configurer un nouveau mot de passe aussitôt reconnecté.</div>
          </div>
        </div>

        <div class="d-flex justify-content-end gap-2 border-top pt-4">
          <a href="/admin/users" class="btn btn-outline-secondary rounded-pill px-4">Annuler</a>
          <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i>Appliquer les modifications
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const roleModulesMap = {
    super_admin: ["admin", "clients", "dossiers", "taches", "facturation", "stock", "comptabilite", "achats", "analytics", "rh"],
    comptable: ["clients", "facturation", "stock", "comptabilite", "achats", "analytics"],
    commercial: ["clients", "dossiers", "taches", "facturation", "analytics"],
    operationnel: ["clients", "dossiers", "taches"],
    magasinier: ["stock", "achats"],
    rh: ["rh"],
    lecture: ["clients", "dossiers", "taches", "facturation", "stock", "comptabilite", "achats", "analytics"],
    secretariat: ["dashboard", "dossiers", "clients"],
    validation_role: ["dashboard", "dossiers"],
    guce: ["dashboard", "dossiers"],
    acconage: ["dashboard", "dossiers", "bons"],
    enlevement: ["dashboard", "dossiers", "bons"],
    direction: ["dashboard", "bons", "analytics"],
    agent_payeur: ["dashboard", "bons"],
    finances: ["dashboard", "documents", "dossiers", "clients"],
    comptable_ops: ["dashboard", "documents", "dossiers", "accounting", "reports"]
  };

  const initialRole = "<%= targetUser.role %>";
  const roleSelect = document.getElementById('role-select');
  const roleChangeWarning = document.getElementById('role-change-warning');
  const liveModuleList = document.getElementById('live-module-list');

  function updateEditUI() {
    const currentRole = roleSelect.value;
    
    // Show/hide warning banner
    if (currentRole !== initialRole) {
      roleChangeWarning.classList.remove('d-none');
    } else {
      roleChangeWarning.classList.add('d-none');
    }

    // Update live modules preview
    const modules = roleModulesMap[currentRole] || [];
    liveModuleList.textContent = modules.join(', ') || 'aucun';
  }

  roleSelect.addEventListener('change', updateEditUI);
  updateEditUI();
</script>

<%- include('../../partials/footer') %>
