<%- include('../../partials/header', { title: 'Utilisateurs & Droits' }) %>

<div class="content-wrapper p-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h4 mb-0">Utilisateurs & Droits d'accès</h1>
      <p class="text-muted mb-0 small">Gérez les comptes et assignez les services</p>
    </div>
    <a href="/admin/users/create" class="btn btn-primary">
      <i class="bi bi-person-plus me-2"></i>Nouvel utilisateur
    </a>
  </div>

  <% if (typeof error_msg !== 'undefined' && error_msg) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i><%= error_msg %></div>
  <% } %>
  <% if (typeof success_msg !== 'undefined' && success_msg) { %>
    <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i><%= success_msg %></div>
  <% } %>

  <%
  const DEPT_CONFIG = [
    { key:'administration', label:'Administration', color:'#993C1D', bg:'#FAECE7', icon:'bi-building',
      roles:['pdg','dg','dga','daf','auditeur1','auditeur2','super_admin'] },
    { key:'transit', label:'Transit', color:'#0F6E56', bg:'#E1F5EE', icon:'bi-truck',
      roles:['secretariat','guce','validation_role','acconage','enlevement'] },
    { key:'finance', label:'Finance', color:'#854F0B', bg:'#FAEEDA', icon:'bi-cash-coin',
      roles:['finances','fiscalite','cloture'] },
    { key:'comptabilite', label:'Comptabilité', color:'#185FA5', bg:'#E6F1FB', icon:'bi-journal-check',
      roles:['caisse'] },
    { key:'analyse', label:'Analyse', color:'#534AB7', bg:'#EEEDFE', icon:'bi-graph-up',
      roles:['analyste'] },
    { key:'archives', label:'Archives', color:'#5F5E5A', bg:'#F1EFE8', icon:'bi-archive',
      roles:['archiviste'] }
  ];
  const ROLE_LABELS = {
    super_admin:'Super Admin', pdg:'PDG', dg:'DG', dga:'DGA', daf:'DAF',
    auditeur1:'Auditeur 1', auditeur2:'Auditeur 2',
    secretariat:'Secrétariat', guce:'GUCE', validation_role:'Validation CAMCIS',
    acconage:'Acconage', enlevement:'Enlèvement & Livraison',
    finances:'Facturation', fiscalite:'Fiscalité', cloture:'Clôture',
    caisse:'Caisse', analyste:'Analyste', archiviste:'Archives',
    comptable:'Comptable', direction:'Direction', agent_payeur:'Agent Payeur',
    commercial:'Commercial', operationnel:'Opérationnel', comptable_ops:'Compta Ops'
  };
  %>

  <!-- Stats row -->
  <div class="row g-3 mb-4">
    <div class="col-sm-3">
      <div class="card text-center p-3">
        <div class="h2 mb-0 fw-bold text-primary"><%= users.length %></div>
        <div class="text-muted small">Total utilisateurs</div>
      </div>
    </div>
    <div class="col-sm-3">
      <div class="card text-center p-3">
        <div class="h2 mb-0 fw-bold text-success"><%= users.filter(u=>u.actif).length %></div>
        <div class="text-muted small">Comptes actifs</div>
      </div>
    </div>
    <div class="col-sm-3">
      <div class="card text-center p-3">
        <div class="h2 mb-0 fw-bold text-danger"><%= users.filter(u=>!u.actif).length %></div>
        <div class="text-muted small">Comptes inactifs</div>
      </div>
    </div>
    <div class="col-sm-3">
      <div class="card text-center p-3">
        <div class="h2 mb-0 fw-bold text-info"><%= DEPT_CONFIG.length %></div>
        <div class="text-muted small">Départements</div>
      </div>
    </div>
  </div>

  <!-- Department groups -->
  <% DEPT_CONFIG.forEach(dept => {
    const deptUsers = users.filter(u => dept.roles.includes(u.role));
  %>
  <div class="card mb-3 shadow-sm">
    <div class="card-header d-flex align-items-center justify-content-between py-2" style="background:<%= dept.bg %>">
      <div class="d-flex align-items-center gap-2">
        <i class="bi <%= dept.icon %>" style="color:<%= dept.color %>;font-size:1.1rem"></i>
        <span class="fw-semibold" style="color:<%= dept.color %>"><%= dept.label %></span>
        <span class="badge rounded-pill" style="background:<%= dept.color %>;color:white"><%= deptUsers.length %> personne(s)</span>
      </div>
      <a href="/admin/users/create?dept=<%= dept.key %>" class="btn btn-sm" style="background:<%= dept.color %>;color:white;font-size:0.75rem">
        <i class="bi bi-person-plus me-1"></i>Ajouter
      </a>
    </div>
    <% if (deptUsers.length > 0) { %>
    <div class="card-body p-0">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th class="ps-3">Nom</th>
            <th>Service / Rôle</th>
            <th>Email</th>
            <th>Dernière connexion</th>
            <th>Statut</th>
            <th class="text-end pe-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% deptUsers.forEach(u => { %>
          <tr>
            <td class="ps-3">
              <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                     style="width:32px;height:32px;background:<%= dept.color %>;font-size:0.75rem;flex-shrink:0">
                  <%= u.nom.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div class="fw-semibold small"><%= u.nom %></div>
                  <div class="text-muted" style="font-size:0.72rem"><%= u.prenom || '' %></div>
                </div>
              </div>
            </td>
            <td><span class="badge rounded-pill" style="background:<%= dept.bg %>;color:<%= dept.color %>"><%= ROLE_LABELS[u.role] || u.role %></span></td>
            <td class="small text-muted"><%= u.email %></td>
            <td class="small text-muted"><%= u.last_login ? new Date(u.last_login).toLocaleDateString('fr-FR') : 'Jamais' %></td>
            <td>
              <% if (u.actif) { %>
                <span class="badge bg-success-subtle text-success">Actif</span>
              <% } else { %>
                <span class="badge bg-danger-subtle text-danger">Inactif</span>
              <% } %>
            </td>
            <td class="text-end pe-3">
              <div class="d-flex gap-1 justify-content-end">
                <a href="/admin/users/<%= u.id %>/edit" class="btn btn-sm btn-outline-primary py-0 px-2" title="Modifier">
                  <i class="bi bi-pencil"></i>
                </a>
                <form method="POST" action="/admin/users/<%= u.id %>/toggle" class="d-inline">
                  <button type="submit" class="btn btn-sm <%= u.actif ? 'btn-outline-warning' : 'btn-outline-success' %> py-0 px-2"
                    title="<%= u.actif ? 'Désactiver' : 'Activer' %>"
                    onclick="return confirm('<%= u.actif ? 'Désactiver' : 'Activer' %> ce compte ?')">
                    <i class="bi <%= u.actif ? 'bi-person-dash' : 'bi-person-check' %>"></i>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/reset-password" class="d-inline">
                  <input type="hidden" name="new_password" value="transit2026!">
                  <button type="submit" class="btn btn-sm btn-outline-secondary py-0 px-2"
                    title="Réinitialiser mdp → transit2026!"
                    onclick="return confirm('Réinitialiser le mot de passe à transit2026! ?')">
                    <i class="bi bi-key"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="card-body text-center text-muted py-3 small">
      <i class="bi bi-person-x me-1"></i>Aucun utilisateur dans ce département.
      <a href="/admin/users/create?dept=<%= dept.key %>" class="ms-2">Ajouter quelqu'un</a>
    </div>
    <% } %>
  </div>
  <% }) %>
</div>

<%- include('../../partials/footer') %>
