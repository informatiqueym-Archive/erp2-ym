<%- include('../../partials/header', { title: 'Créer un utilisateur' }) %>

<div class="content-wrapper p-4">
  <div class="d-flex align-items-center mb-4">
    <a href="/admin/users" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <div>
      <h1 class="h4 mb-0">Créer un utilisateur</h1>
      <p class="text-muted mb-0 small">Ajoutez un nouveau membre et assignez-le à son service</p>
    </div>
  </div>

  <% if (typeof error_msg !== 'undefined' && error_msg) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i><%= error_msg %></div>
  <% } %>

  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <form action="/admin/users/create" method="POST">

            <div class="row mb-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Nom <span class="text-danger">*</span></label>
                <input type="text" name="nom" class="form-control" required placeholder="Ex: Mbarga">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Prénom</label>
                <input type="text" name="prenom" class="form-control" placeholder="Ex: Jean-Pierre">
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
              <input type="email" name="email" class="form-control" required placeholder="prenom.nom@ym-transit.cm">
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Département <span class="text-danger">*</span></label>
              <select id="dept-select" class="form-select" onchange="updateRoles(this.value)" required>
                <option value="">-- Choisir le département --</option>
                <option value="administration">🏢 Administration (PDG, DG, DGA, DAF, Auditeurs)</option>
                <option value="transit">🚛 Transit (Secrétariat, GUCE, Validation, Gestion des Bours)</option>
                <option value="finance">💰 Finance (Facturation, Fiscalité, Clôture)</option>
                <option value="comptabilite">📒 Comptabilité (Caisse)</option>
                <option value="analyse">📊 Analyse (Analyste, Auditeurs)</option>
                <option value="archives">🗂 Archives</option>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Service / Rôle <span class="text-danger">*</span></label>
              <select name="role" id="role-select" class="form-select" required>
                <option value="">-- Sélectionnez d'abord le département --</option>
              </select>
              <div id="role-desc" class="form-text text-muted mt-1"></div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Mot de passe temporaire <span class="text-danger">*</span></label>
              <input type="password" name="password" class="form-control" required minlength="6" placeholder="Minimum 6 caractères">
              <div class="form-text">L'utilisateur pourra le changer depuis son profil.</div>
            </div>

            <div class="mb-4">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="actif" id="actif" value="true" checked>
                <label class="form-check-label" for="actif">Compte actif (l'utilisateur peut se connecter)</label>
              </div>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary px-4"><i class="bi bi-person-plus me-2"></i>Créer l'utilisateur</button>
              <a href="/admin/users" class="btn btn-outline-secondary">Annuler</a>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm border-0" style="background:#f8fafc">
        <div class="card-body p-3">
          <h6 class="fw-semibold mb-3">Accès par département</h6>
          <div id="module-preview" class="text-muted small">Sélectionnez un service pour voir les accès.</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const DEPT_ROLES = {
  administration: [
    { value: "pdg",       label: "PDG — Président Directeur Général",   desc: "Accès complet · Visa Bons · Analytics" },
    { value: "dg",        label: "DG — Directeur Général",              desc: "Accès complet · Visa Bons · Analytics" },
    { value: "dga",       label: "DGA — Directeur Général Adjoint",     desc: "Accès Bons · Dossiers · Analytics" },
    { value: "daf",       label: "DAF — Directeur Administratif & Fin", desc: "Accès Bons · Finance · Dossiers" },
    { value: "auditeur1", label: "Auditeur 1",                          desc: "Audit interne · Comptabilité · Analyse" },
    { value: "auditeur2", label: "Auditeur 2",                          desc: "Audit interne · Analytics · Dossiers" },
    { value: "super_admin", label: "Super Administrateur Système",      desc: "Accès total au système" }
  ],
  transit: [
    { value: "secretariat",    label: "Secrétariat — Création des dossiers",  desc: "Clients · Dossiers · Tâches" },
    { value: "guce",           label: "GUCE — Assurance · DESC · RVC",        desc: "Dossiers · Attachement de fichiers · Manifeste" },
    { value: "validation_role",label: "Validation — CAMCIS",                  desc: "Dossiers · Validation des fichiers téléchargés" },
    { value: "acconage",       label: "Acconage — Gestion des Bours",         desc: "Dossiers · Bon Provisoir · Bon Réel" },
    { value: "enlevement",     label: "Enlèvement & Livraison",               desc: "Dossiers · Bon Provisoir · Bon Réel" }
  ],
  finance: [
    { value: "finances",    label: "Facturation — Factures clients",   desc: "Facturation · Dossiers · Clients" },
    { value: "fiscalite",   label: "Fiscalité — Déclarations fiscales", desc: "Analytics · Travail indépendant du pipeline" },
    { value: "cloture",     label: "Clôture — Finalisation dossiers",  desc: "Dossiers · Envoi aux archives" }
  ],
  comptabilite: [
    { value: "caisse",   label: "Caisse — Agent Payeur",               desc: "Bons · Paiements · Décaissements · Facturation" }
  ],
  analyse: [
    { value: "analyste",   label: "Analyste — Rapports & Statistiques", desc: "Dashboard · Analytics · Rapports" },
    { value: "auditeur1",  label: "Auditeur 1 (accès Analyse aussi)",  desc: "Analytics · Comptabilité · Admin" },
    { value: "auditeur2",  label: "Auditeur 2 (accès Analyse aussi)",  desc: "Analytics · Dossiers" }
  ],
  archives: [
    { value: "archiviste", label: "Archiviste — Consultation archives", desc: "Dossiers archivés en lecture seule uniquement" }
  ]
};

const MODULE_LABELS = {
  administration: "✅ Bons provisoirs (visa)\n✅ Tous les dossiers\n✅ Analytics & Rapports\n✅ Gestion des utilisateurs (admin)\n✅ Vue globale de l'entreprise",
  transit: "✅ Dossiers de transit\n✅ Clients\n✅ Tâches\n✅ Bons (Acconage/Enlèvement seulement)",
  finance: "✅ Facturation clients\n✅ Dossiers\n✅ Analytics (Fiscalité)",
  comptabilite: "✅ Caisse & Décaissements\n✅ Bons approuvés\n✅ Facturation",
  analyse: "✅ Dashboard complet\n✅ Analytics & Statistiques\n✅ Rapports financiers",
  archives: "✅ Consultation archives (lecture seule)\n❌ Aucune modification"
};

function updateRoles(dept) {
  const roleSelect = document.getElementById('role-select');
  const preview = document.getElementById('module-preview');
  const desc = document.getElementById('role-desc');
  roleSelect.innerHTML = '<option value="">-- Choisir le service --</option>';
  desc.textContent = '';
  if (!dept || !DEPT_ROLES[dept]) { preview.textContent = 'Sélectionnez un service pour voir les accès.'; return; }
  DEPT_ROLES[dept].forEach(r => {
    const opt = document.createElement('option');
    opt.value = r.value; opt.textContent = r.label; opt.dataset.desc = r.desc;
    roleSelect.appendChild(opt);
  });
  preview.innerHTML = '<strong>Accès du département :</strong><br><pre style="font-size:0.8rem;margin-top:6px;white-space:pre-wrap;background:none;border:none;padding:0">' + (MODULE_LABELS[dept] || '') + '</pre>';
}

// Pre-select from query param
const urlParams = new URLSearchParams(window.location.search);
const preselectedDept = urlParams.get('dept');
if (preselectedDept) {
  const deptSel = document.getElementById('dept-select');
  deptSel.value = preselectedDept;
  updateRoles(preselectedDept);
}

document.getElementById('role-select').addEventListener('change', function() {
  const opt = this.options[this.selectedIndex];
  document.getElementById('role-desc').textContent = opt.dataset.desc || '';
});
</script>

<%- include('../../partials/footer') %>
